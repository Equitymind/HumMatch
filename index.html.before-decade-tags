// ── Song page slug lookup (500 songs with vocal range guide pages) ──
function toSlug(s) {
  return s.toLowerCase().replace(/[^a-z0-9 -]/g,'').replace(/\s+/g,'-').replace(/-+/g,'-').replace(/^-|-$/g,'');
}

// Generate slug for song page link (all songs have pages now)
function getSongPageSlug(title, artist) {
  return toSlug(title) + '-' + toSlug(artist);
}

// ════════════════════════════════════════════════════════════
// MIDI helpers
// ════════════════════════════════════════════════════════════
const NOTE_NAMES = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
function midiToName(midi) {
  const oct = Math.floor(midi / 12) - 1;
  return NOTE_NAMES[midi % 12] + oct;
}
function freqToMidi(hz) {
  return Math.round(12 * Math.log2(hz / 440) + 69);
}

// ════════════════════════════════════════════════════════════
// PITCH DETECTION: autocorrelation
// ════════════════════════════════════════════════════════════
function detectPitch(buf, sampleRate) {
  const SIZE = buf.length;
  const MAX_SAMPLES = Math.floor(SIZE / 2);
  // Min/max lag for 50Hz to 1400Hz
  const MIN_LAG = Math.floor(sampleRate / 1400);
  const MAX_LAG = Math.min(MAX_SAMPLES, Math.floor(sampleRate / 50));

  // Normalize autocorrelation (handles varying input levels)
  let rmsTotal = 0;
  for (let i = 0; i < SIZE; i++) rmsTotal += buf[i] * buf[i];
  rmsTotal = Math.sqrt(rmsTotal / SIZE);
  if (rmsTotal < 0.001) return -1;

  let best = -1, bestCorr = -1;
  let prevCorr = 0, rising = false;

  for (let t = MIN_LAG; t < MAX_LAG; t++) {
    let corr = 0;
    for (let i = 0; i < MAX_SAMPLES; i++) corr += buf[i] * buf[i + t];
    corr = corr / (MAX_SAMPLES * rmsTotal * rmsTotal + 0.001);

    if (corr > prevCorr) {
      rising = true;
    } else if (rising && corr < prevCorr) {
      // Just passed a local maximum
      if (prevCorr > bestCorr && prevCorr > 0.45) {
        bestCorr = prevCorr;
        best = t - 1;
      }
      rising = false;
    }
    prevCorr = corr;
    if (bestCorr > 0.92) break; // strong enough, stop early
  }

  if (best < MIN_LAG) return -1;
  // Parabolic interpolation for sub-sample accuracy
  const y1 = best > MIN_LAG ? (() => { let c=0; for(let i=0;i<MAX_SAMPLES;i++) c+=buf[i]*buf[i+best-1]; return c/(MAX_SAMPLES*rmsTotal*rmsTotal+0.001); })() : bestCorr;
  const y3 = best < MAX_LAG-1 ? (() => { let c=0; for(let i=0;i<MAX_SAMPLES;i++) c+=buf[i]*buf[i+best+1]; return c/(MAX_SAMPLES*rmsTotal*rmsTotal+0.001); })() : bestCorr;
  const denom = 2*(2*bestCorr - y1 - y3);
  const refined = best + (denom !== 0 ? (y1 - y3) / denom : 0);
  return sampleRate / refined;
}

// Spectral centroid: proxy for brightness/timbre
function spectralCentroid(freqData) {
  let num = 0, denom = 0;
  for (let i = 0; i < freqData.length; i++) {
    const mag = freqData[i] / 255;
    num += i * mag;
    denom += mag;
  }
  return denom > 0 ? num / denom : 0;
}

