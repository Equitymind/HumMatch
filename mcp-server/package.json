{
  "name": "hummatch-mcp",
  "version": "1.0.0",
  "description": "HumMatch MCP Server — Find songs by vocal range. 3,000+ songs. Powered by HumMatch.me",
  "main": "dist/index.js",
  "bin": {
    "hummatch-mcp": "dist/index.js"
  },
  "scripts": {
    "extract": "node extract-songs.js",
    "build": "node --max-old-space-size=4096 ./node_modules/.bin/tsc",
    "start": "node server-wrapper.js --http",
    "dev": "ts-node src/index.ts",
    "web": "node server-wrapper.js --http"
  },
  "files": [
    "dist/**",
    "songs.json",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "vocal-range",
    "karaoke",
    "singing",
    "music",
    "hummatch",
    "voice-type",
    "songs",
    "baritone",
    "soprano",
    "tenor",
    "alto"
  ],
  "author": "HumMatch <hello@hummatch.me>",
  "license": "MIT",
  "homepage": "https://hummatch.me",
  "repository": {
    "type": "git",
    "url": "https://github.com/hummatch/mcp-server"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}