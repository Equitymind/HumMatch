<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no,viewport-fit=cover"/>
<title>HumMatch | Find Songs That Match My Voice | Vocal Match</title>
<meta name="description" content="Hum 3 notes and instantly find the karaoke songs that match your voice. Free vocal range test. Discover the exact songs your voice was made for."/>
<meta name="keywords" content="songs that match my voice, karaoke songs for my voice, find songs for my voice, vocal range test, what songs can I sing, songs for my voice type, karaoke song finder"/>
<link rel="canonical" href="https://hummatch.me"/>
<link rel="manifest" href="/hummatch-manifest.json"/>
<link rel="apple-touch-icon" href="/hummatch-icon-180.png"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="apple-mobile-web-app-title" content="HumMatch"/>
<meta name="theme-color" content="#a855f7"/>
<meta property="og:title" content="HumMatch | Songs That Match My Voice | Karaoke"/>
<meta property="og:description" content="Hum 3 notes and instantly find the karaoke songs that match your voice. Free vocal range test. Discover the exact songs your voice was made for."/>
<meta property="og:url" content="https://hummatch.me"/>
<meta property="og:type" content="website"/>
<meta property="og:image" content="https://hummatch.me/hummatch-og.jpg"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="HumMatch | Songs That Match My Voice | Karaoke"/>
<meta name="twitter:description" content="Hum 3 notes and instantly find the karaoke songs that match your voice. Free vocal range test."/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  :root {
    --bg: #08060F;
    --surface: #12101A;
    --surface2: #1C1926;
    --accent: #A855F7;
    --accent2: #7C3AED;
    --gold: #F59E0B;
    --green: #22C55E;
    --text1: #FFFFFF;
    --text2: rgba(255,255,255,0.65);
    --text3: rgba(255,255,255,0.35);
  }
  html, body { height: 100%; background: var(--bg); color: var(--text1);
    font-family: -apple-system, 'SF Pro Display', Arial, sans-serif; overflow: hidden; }

  .screen { display: none; flex-direction: column; align-items: center;
    justify-content: space-evenly; min-height: 100vh; padding: 8px 24px;
    text-align: center; position: fixed; inset: 0; overflow-y: auto; }
  .screen.active { display: flex; }

  /* ── WELCOME ── */
  .logo-wrap { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; justify-content: center; }
  .logo-svg { width: 52px; height: 52px; flex-shrink: 0; }
  .app-name { font-size: 2.2rem; font-weight: 900; letter-spacing: -0.04em;
    background: linear-gradient(135deg, #A855F7, #EC4899); -webkit-background-clip: text;
    -webkit-text-fill-color: transparent; background-clip: text; }
  .app-tagline { font-size: 0.85rem; color: var(--text2); margin: 4px 0 10px; line-height: 1.4; max-width: 280px; }


  .cta-btn { background: linear-gradient(135deg, #A855F7, #7C3AED);
    color: #fff; border: none; border-radius: 50px; padding: 18px 48px;
    font-size: 1.05rem; font-weight: 800; cursor: pointer; letter-spacing: 0.02em;
    box-shadow: 0 0 40px rgba(168,85,247,0.35); transition: transform 0.15s, box-shadow 0.15s; }
  .cta-btn:active { transform: scale(0.97); box-shadow: 0 0 20px rgba(168,85,247,0.2); }
  .cta-btn.secondary { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15);
    box-shadow: none; color: var(--text2); font-size: 0.9rem; padding: 14px 36px; margin-top: 12px; }

  .how-it-works { display: flex; gap: 10px; margin: 8px 0; max-width: 320px; }
  .step { flex: 1; background: var(--surface); border-radius: 14px; padding: 16px 10px;
    border: 1px solid rgba(255,255,255,0.07); }
  .step-num { font-size: 1.3rem; margin-bottom: 6px; }
  .step-txt { font-size: 0.68rem; color: var(--text2); line-height: 1.4; }

  /* ── WELCOME SCREEN (mobile scroll fix) ── */
  #screen-welcome { justify-content: flex-start; padding-top: 64px; padding-bottom: max(40px, env(safe-area-inset-bottom, 40px)); overflow-y: auto; -webkit-overflow-scrolling: touch; gap: 0; }
  #screen-welcome > * { flex-shrink: 0; }

  /* ── HUM TEST ── */
  #screen-test { justify-content: flex-start; padding-top: 68px; padding-bottom: max(60px, env(safe-area-inset-bottom, 60px)); overflow-y: auto; -webkit-overflow-scrolling: touch; }
  .test-phase { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
  .test-title { font-size: 1.7rem; font-weight: 900; margin-bottom: 6px; line-height: 1.2; }
  .test-sub { font-size: 0.88rem; color: var(--text2); line-height: 1.5; max-width: 280px; margin-bottom: 28px; }

  .pitch-display { width: 100%; max-width: 360px; background: var(--surface);
    border-radius: 20px; padding: 20px; margin-bottom: 20px;
    border: 1px solid rgba(255,255,255,0.08); }
  .pitch-note { font-size: 3.5rem; font-weight: 900; line-height: 1;
    color: var(--accent); min-height: 60px; display: flex; align-items: center; justify-content: center; }
  .pitch-hz { font-size: 0.8rem; color: var(--text3); margin-top: 4px; }
  .pitch-bar-wrap { width: 100%; height: 8px; background: rgba(255,255,255,0.08);
    border-radius: 4px; margin-top: 14px; overflow: hidden; }
  .pitch-bar { height: 100%; background: linear-gradient(90deg, #7C3AED, #A855F7, #EC4899);
    border-radius: 4px; transition: width 0.1s; width: 0%; }

  .waveform-canvas { width: 100%; max-width: 360px; height: 60px;
    border-radius: 12px; background: var(--surface); display: block; margin-bottom: 20px; }

  .range-summary { width: 100%; max-width: 360px; display: flex; gap: 10px; margin-bottom: 20px; }
  .range-box { flex: 1; background: var(--surface); border-radius: 14px; padding: 14px 10px;
    border: 1px solid rgba(255,255,255,0.08); }
  .range-box-label { font-size: 0.65rem; color: var(--text3); text-transform: uppercase;
    letter-spacing: 0.08em; margin-bottom: 4px; }
  .range-box-value { font-size: 1.3rem; font-weight: 900; color: var(--accent); min-height: 28px; }

  .mic-btn { width: 88px; height: 88px; border-radius: 50%;
    background: linear-gradient(135deg, #A855F7, #7C3AED);
    border: none; cursor: pointer; font-size: 2rem;
    box-shadow: 0 0 0 0 rgba(168,85,247,0.5);
    transition: transform 0.15s; display: flex; align-items: center; justify-content: center;
    position: relative; }
  .mic-btn.recording { animation: pulse-ring 1.2s ease-out infinite; }
  .mic-btn.ready { animation: none; }
  .mic-btn-wrap { position: fixed; bottom: max(32px, env(safe-area-inset-bottom, 32px)); left: 0; right: 0; display: flex; align-items: center; justify-content: center; z-index: 200; }
  .mic-btn-wrap::before { content:''; position:absolute; width:108px; height:108px; border-radius:50%; background: conic-gradient(#EC4899 0deg, #A855F7 120deg, transparent 180deg, transparent 360deg); animation: orbit 1.2s linear infinite; opacity: 0; transition: opacity 0.3s; pointer-events:none; }
  .mic-btn-wrap.ready::before { opacity: 1; }
  @keyframes orbit { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .mic-btn:active { transform: scale(0.95); }
  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(168,85,247,0.6); }
    70% { box-shadow: 0 0 0 24px rgba(168,85,247,0); }
    100% { box-shadow: 0 0 0 0 rgba(168,85,247,0); }
  }
  @keyframes tap-ring {
    0% { box-shadow: 0 0 0 0 rgba(236,72,153,0.7); }
    70% { box-shadow: 0 0 0 28px rgba(236,72,153,0); }
    100% { box-shadow: 0 0 0 0 rgba(236,72,153,0); }
  }
  .mic-label { font-size: 1.15rem; font-weight: 800; color: #fff; margin-top: 10px; letter-spacing: 0.02em; position: fixed; bottom: max(8px, calc(env(safe-area-inset-bottom, 8px) - 8px)); left: 0; right: 0; text-align: center; z-index: 200; text-shadow: 0 1px 8px rgba(0,0,0,0.5); padding: 8px 16px; }
  .mic-countdown { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); font-size: 2rem; font-weight: 900; color: #fff; pointer-events: none; text-shadow: 0 0 12px rgba(168,85,247,0.8); display: none; }
  .mic-countdown.visible { display: block; }
  .hum-step-banner { font-size: 1.3rem; font-weight: 800; color: #fff; text-align: center; padding: 12px 20px; border-radius: 14px; background: linear-gradient(135deg, rgba(168,85,247,0.25), rgba(236,72,153,0.25)); border: 1px solid rgba(168,85,247,0.3); margin-bottom: 12px; min-height: 52px; display: flex; align-items: center; justify-content: center; line-height: 1.3; }
  .phase-flash { position:fixed; top:0; left:0; right:0; bottom:0; display:flex; align-items:center; justify-content:center; z-index:500; pointer-events:none; opacity:0; transition:opacity 0.15s; }
  .phase-flash.show { opacity:1; }
  .phase-flash-text { font-size:5rem; font-weight:900; color:#fff; text-shadow: 0 0 40px rgba(168,85,247,0.9); letter-spacing:0.05em; }

  .phase-dots { display: flex; gap: 12px; margin: 20px 0; align-items: center; }
  .phase-dot { width: 14px; height: 14px; border-radius: 50%; background: rgba(255,255,255,0.15); transition: background 0.3s, transform 0.3s; border: 2px solid rgba(255,255,255,0.1); }
  .phase-dot.active { transform: scale(1.2); border-color: var(--accent); }
  .phase-dot.done { transform: scale(1); border-color: var(--green); }
  .phase-dot.done { background: var(--green); }
  .phase-dot.active { background: var(--accent); }

  /* ── RESULTS ── */
  #screen-results { justify-content: flex-start; padding: 52px 0 160px; overflow-y: scroll; -webkit-overflow-scrolling: touch; height: 100%; gap: 0; }
  .results-sticky-top { position: sticky; top: 0; z-index: 20; background: var(--bg); padding: 12px 16px 0; width: 100%; }
  .results-header { width: 100%; max-width: 400px; margin-bottom: 6px; }
  .voice-badge { display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, rgba(168,85,247,0.2), rgba(124,58,237,0.2));
    border: 1px solid rgba(168,85,247,0.4); border-radius: 50px;
    padding: 6px 16px; font-size: 0.88rem; font-weight: 800;
    color: var(--accent); margin-bottom: 6px; }

  .section-title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--text3); margin: 20px 0 10px; width: 100%; max-width: 400px; text-align: left; }

  .comparison-grid { width: 100%; max-width: 400px; display: grid;
    grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 8px; }
  .comp-card { background: var(--surface); border-radius: 16px; padding: 14px;
    border: 1px solid rgba(255,255,255,0.07); }
  .comp-card.yours { border-color: rgba(168,85,247,0.4); background: rgba(168,85,247,0.06); }
  .comp-card-title { font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; margin-bottom: 10px; }
  .comp-card.yours .comp-card-title { color: var(--accent); }
  .comp-card.generic .comp-card-title { color: var(--text3); }

  /* ── Category Badge (pill) ── */
  .cat-badge { display: inline-flex; align-items: center; gap: 3px;
    border-radius: 50px; padding: 2px 8px; font-size: 0.58rem; font-weight: 700;
    letter-spacing: 0.02em; white-space: nowrap; margin-top: 4px; }
  .cat-best   { background: rgba(16,185,129,0.15); color: #10b981; border: 1px solid rgba(16,185,129,0.3); }
  .cat-top    { background: rgba(250,204,21,0.15); color: #facc15; border: 1px solid rgba(250,204,21,0.3); }
  .cat-stretch{ background: rgba(249,115,22,0.15); color: #f97316; border: 1px solid rgba(249,115,22,0.3); }
  .cat-duet   { background: rgba(168,85,247,0.15); color: #a78bfa; border: 1px solid rgba(168,85,247,0.3); }
  .cat-trans  { background: rgba(96,165,250,0.15); color: #60a5fa; border: 1px solid rgba(96,165,250,0.3); }

  /* ── Confidence Tiers ── */
  .tier-badge { display: inline-flex; align-items: center; gap: 4px;
    border-radius: 50px; padding: 3px 10px; font-size: 0.65rem; font-weight: 800;
    letter-spacing: 0.04em; white-space: nowrap; }
  .tier-nail  { background: rgba(16,185,129,0.18); color: #10b981; border: 1px solid rgba(16,185,129,0.35); }
  .tier-strong{ background: rgba(168,85,247,0.18); color: #a78bfa; border: 1px solid rgba(168,85,247,0.35); }
  .tier-stretch{ background: rgba(251,146,60,0.18); color: #fb923c; border: 1px solid rgba(251,146,60,0.35); }

  /* ── Filter Bar ── */
  .filter-bar { width: 100%; max-width: 400px; display: flex; gap: 8px;
    overflow-x: auto; padding: 8px 0 14px; scrollbar-width: none; -webkit-overflow-scrolling: touch;
    position: relative; z-index: 10; }
  .filter-bar::-webkit-scrollbar { display: none; }
  .filter-chip { flex-shrink: 0; padding: 7px 14px; border-radius: 50px;
    font-size: 0.72rem; font-weight: 700; cursor: pointer; border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.55); transition: all 0.15s; }
  .filter-chip.active { background: rgba(168,85,247,0.25); border-color: rgba(168,85,247,0.7);
    color: #c4b5fd; }
  .filter-chip:active { transform: scale(0.95); }

  /* ── Song List ── */
  .song-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .song-item { display: flex; flex-direction: column; padding: 12px 14px;
    background: rgba(255,255,255,0.04); border-radius: 14px;
    border: 1px solid rgba(255,255,255,0.06); cursor: pointer; transition: border-color 0.15s; }
  .song-item:active { border-color: rgba(168,85,247,0.5); background: rgba(168,85,247,0.07); }
  .song-item-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; }
  .song-title { font-size: 0.82rem; font-weight: 800; line-height: 1.25; flex: 1; }
  .song-meta { font-size: 0.68rem; color: var(--text3); margin-top: 3px; display: flex; align-items: center; gap: 6px; }
  .song-meta .dot { opacity: 0.4; }
  .song-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 8px; }
  .song-item.hidden-song { display: none; }
  .song-item.generic .song-match { color: #EF4444; }
  .sing-btn { font-size: 0.62rem; background: linear-gradient(135deg,#A855F7,#7C3AED);
    color: #fff; padding: 4px 12px; border-radius: 50px; font-weight: 700; white-space: nowrap; }

  /* ── Stretch Section ── */
  .stretch-section { width: 100%; max-width: 400px; margin-top: 8px; }
  .stretch-toggle { width: 100%; text-align: center; padding: 10px;
    background: rgba(251,146,60,0.08); border: 1px dashed rgba(251,146,60,0.3);
    border-radius: 12px; color: #fb923c; font-size: 0.75rem; font-weight: 700; cursor: pointer; }

  .song-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .song-item.generic .song-match { color: #EF4444; }

  .range-bar-wrap { width: 100%; max-width: 400px; background: var(--surface);
    border-radius: 12px; padding: 10px 14px; margin-bottom: 10px;
    border: 1px solid rgba(255,255,255,0.07); }
  .range-bar-label { font-size: 0.65rem; color: var(--text3); text-transform: uppercase;
    letter-spacing: 0.08em; margin-bottom: 10px; }
  .range-bar-track { position: relative; height: 28px; background: rgba(255,255,255,0.05);
    border-radius: 8px; overflow: visible; margin-bottom: 8px; }
  .range-bar-fill { position: absolute; top: 4px; bottom: 4px; border-radius: 6px;
    background: linear-gradient(90deg, #7C3AED, #A855F7, #EC4899); transition: left 0.6s, width 0.6s; }
  .range-bar-ticks { display: flex; justify-content: space-between;
    font-size: 0.58rem; color: var(--text3); }

  .retry-btn { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15);
    color: var(--text2); border-radius: 50px; padding: 14px 36px;
    font-size: 0.88rem; font-weight: 700; cursor: pointer; margin-top: 8px; }

  .confetti-emoji { font-size: 1.8rem; margin-bottom: 2px; }

  /* ── Mobile Header Bar ─────────────────────────────── */
  .hm-header { position:fixed; top:0; left:0; right:0; z-index:10000; display:flex; align-items:center; justify-content:space-between; padding:10px 16px; background:rgba(8,6,15,0.92); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px); border-bottom:1px solid rgba(168,85,247,0.1); }
  .hm-header-logo { text-decoration:none; font-size:1rem; font-weight:800; background:linear-gradient(135deg,#A855F7,#EC4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }

  /* ── Hamburger Nav ──────────────────────────────────── */
  .hm-nav-toggle { background:none; border:none; width:36px; height:36px; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px; cursor:pointer; padding:0; flex-shrink:0; }
  .hm-nav-toggle span { display:block; width:20px; height:2px; background:rgba(168,85,247,0.9); border-radius:2px; transition:all 0.25s; }
  .hm-nav-toggle.open span:nth-child(1) { transform:translateY(7px) rotate(45deg); }
  .hm-nav-toggle.open span:nth-child(2) { opacity:0; }
  .hm-nav-toggle.open span:nth-child(3) { transform:translateY(-7px) rotate(-45deg); }
  .hm-nav-drawer { position:fixed; top:0; left:0; width:240px; height:100%; background:rgba(8,6,15,0.97); backdrop-filter:blur(16px); border-right:1px solid rgba(168,85,247,0.15); z-index:9999; transform:translateX(-100%); visibility:hidden; transition:transform 0.28s cubic-bezier(.4,0,.2,1), visibility 0.28s; padding:70px 0 24px; }
  .hm-nav-drawer.open { transform:translateX(0); visibility:visible; }
  .hm-nav-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:9998; opacity:0; pointer-events:none; transition:opacity 0.28s; }
  .hm-nav-overlay.open { opacity:1; pointer-events:all; }
  .hm-nav-logo { padding:0 20px 20px; border-bottom:1px solid rgba(168,85,247,0.12); margin-bottom:8px; }
  .hm-nav-logo span { font-size:1.1rem; font-weight:800; background:linear-gradient(135deg,#A855F7,#EC4899); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
  .hm-nav-item { display:block; padding:13px 24px; color:rgba(255,255,255,0.6); text-decoration:none; font-size:0.88rem; font-weight:600; transition:color 0.15s, background 0.15s; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .hm-nav-item:hover { color:#fff; background:rgba(168,85,247,0.1); }
  .hm-nav-item.active { color:#A855F7; }
  .hm-nav-divider { height:1px; background:rgba(168,85,247,0.1); margin:8px 20px; }

  /* ── Account indicator ── */
  .hm-account-indicator { display:inline-flex; align-items:center; gap:4px; font-size:0.68rem; font-weight:700; color:var(--text3); margin-left:8px; cursor:pointer; }
  .hm-account-dot { width:8px; height:8px; border-radius:50%; display:inline-block; }
  .hm-account-dot.premium { background:#22c55e; }
  .hm-account-dot.free { background:rgba(255,255,255,0.3); }

  /* ── PRIMER SCREEN ── */
  #screen-primer { justify-content: center; gap: 0; padding: 24px 24px max(40px, env(safe-area-inset-bottom, 40px)); }
  .primer-icon { font-size: 4rem; margin-bottom: 24px; }
  .primer-title { font-size: 1.6rem; font-weight: 900; line-height: 1.25; margin-bottom: 10px; max-width: 280px; }
  .primer-sub { font-size: 0.92rem; color: var(--text2); line-height: 1.6; max-width: 280px; margin-bottom: 28px; }
  .primer-steps { display: flex; flex-direction: column; gap: 14px; width: 100%; max-width: 300px; margin-bottom: 32px; }
  .primer-step { display: flex; align-items: center; gap: 14px; text-align: left; }
  .primer-step-num { width: 36px; height: 36px; border-radius: 50%; background: rgba(168,85,247,0.15); border: 1px solid rgba(168,85,247,0.3); display: flex; align-items: center; justify-content: center; font-size: 0.85rem; font-weight: 800; color: var(--accent); flex-shrink: 0; }
  .primer-step-text { font-size: 0.88rem; color: var(--text2); line-height: 1.4; }
  .primer-step-text strong { color: #fff; }
  .primer-ready-btn { width: 100%; max-width: 300px; padding: 18px; background: linear-gradient(135deg, #A855F7, #7C3AED); color: #fff; border: none; border-radius: 50px; font-size: 1.1rem; font-weight: 800; cursor: pointer; letter-spacing: 0.02em; box-shadow: 0 0 40px rgba(168,85,247,0.35); }
  .primer-ready-btn:active { transform: scale(0.97); }
  .primer-tip { font-size: 0.72rem; color: var(--text3); margin-top: 16px; max-width: 260px; line-height: 1.5; }

  /* ── COUNTDOWN RING (SVG) ── */
  .countdown-ring-wrap { position: relative; width: 120px; height: 120px; margin: 0 auto; }
  .countdown-ring-svg { width: 120px; height: 120px; transform: rotate(-90deg); }
  .countdown-ring-bg { fill: none; stroke: rgba(255,255,255,0.08); stroke-width: 6; }
  .countdown-ring-progress { fill: none; stroke: url(#ring-grad); stroke-width: 6; stroke-linecap: round; stroke-dasharray: 339.292; stroke-dashoffset: 0; transition: stroke-dashoffset 0.1s linear; }
  .countdown-ring-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .countdown-ring-number { font-size: 2.2rem; font-weight: 900; color: #fff; line-height: 1; }
  .countdown-ring-label { font-size: 0.65rem; color: var(--text3); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 2px; }

  /* ── AUTO-FLOW TEST SCREEN ── */
  .auto-phase-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }
  .auto-phase-title { font-size: 1.5rem; font-weight: 900; margin-bottom: 6px; line-height: 1.2; }
  .auto-phase-sub { font-size: 0.85rem; color: var(--text2); line-height: 1.5; max-width: 280px; margin-bottom: 24px; }
  .auto-phase-emoji { font-size: 3rem; margin-bottom: 16px; transition: transform 0.3s; }
  .auto-status { font-size: 0.82rem; color: var(--text2); margin-top: 16px; min-height: 24px; font-weight: 600; }
  .auto-status.listening { color: var(--accent); }
  .auto-status.success { color: var(--green); }

  /* Phase success flash */
  .phase-success-overlay { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; flex-direction: column; z-index: 500; pointer-events: none; opacity: 0; transition: opacity 0.2s; background: rgba(8,6,15,0.85); }
  .phase-success-overlay.show { opacity: 1; }
  .phase-success-check { font-size: 4rem; margin-bottom: 8px; }
  .phase-success-text { font-size: 1.3rem; font-weight: 800; color: #22C55E; }

  /* ── Signup bottom sheet ── */
  .hm-login-sheet { position:fixed; bottom:0; left:0; right:0; z-index:2500; background:rgba(18,16,26,0.98); backdrop-filter:blur(16px); border-top:1px solid rgba(168,85,247,0.25); border-radius:20px 20px 0 0; padding:24px 24px max(24px, env(safe-area-inset-bottom, 24px)); transform:translateY(100%); transition:transform 0.35s cubic-bezier(.4,0,.2,1); max-height:90vh; overflow-y:auto; }
  .hm-login-sheet.show { transform:translateY(0); }
  .hm-login-sheet h3 { font-size:1.05rem; font-weight:800; margin-bottom:8px; }
  .hm-login-sheet p { font-size:0.82rem; color:var(--text2); line-height:1.5; margin-bottom:16px; }
  .hm-login-sheet input { width:100%; padding:14px 16px; background:rgba(255,255,255,0.07); border:1px solid rgba(168,85,247,0.3); border-radius:12px; color:#fff; font-size:0.95rem; outline:none; font-family:inherit; margin-bottom:10px; }
  .hm-login-sheet input:focus { border-color:rgba(168,85,247,0.7); }
  .hm-login-sheet .hm-login-btn { width:100%; padding:14px; background:linear-gradient(135deg,#7c3aed,#a855f7); color:#fff; border:none; border-radius:12px; font-size:0.95rem; font-weight:800; cursor:pointer; font-family:inherit; }
  .hm-login-sheet .hm-login-btn:disabled { opacity:0.5; cursor:default; }
  .hm-login-dismiss { background:none; border:none; color:rgba(255,255,255,0.3); font-size:0.82rem; cursor:pointer; margin-top:10px; width:100%; text-align:center; font-family:inherit; }
  .hm-login-sheet .hm-field-error { color:#ef4444; font-size:0.75rem; margin:-6px 0 8px 4px; display:none; }
  .hm-login-sheet .hm-sheet-link { color:#a78bfa; font-size:0.82rem; text-align:center; display:block; margin-top:8px; cursor:pointer; background:none; border:none; font-family:inherit; }

  @media (min-width: 768px) {
    body { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
    .app-tagline { max-width: 900px; }
    .how-it-works { max-width: 1000px; }
    .test-sub { max-width: 900px; }
    .pitch-display { max-width: 1000px; }
    .waveform-canvas { max-width: 1000px; }
    .range-summary { max-width: 1000px; }
    .results-header { max-width: 1200px; }
    .comparison-grid { max-width: 1200px; grid-template-columns: repeat(3, 1fr); }
    .filter-bar { max-width: 1200px; }
    .dashboard-container { max-width: 1600px; margin: 0 auto; }
    .hum-card { max-width: 1200px; }
  }

  @media (max-width: 767px) {
    #screen-welcome {
      padding-bottom: max(80px, env(safe-area-inset-bottom, 80px));
      overscroll-behavior-y: contain;
    }
    footer {
      position: relative;
      margin-top: 40px;
      padding-bottom: max(32px, env(safe-area-inset-bottom, 32px)) !important;
    }
  }

  /* ── Interest Selector ── */
  .interest-chips { display:flex; flex-wrap:wrap; gap:7px; }
  .interest-chip {
    padding: 6px 13px;
    border-radius: 50px;
    font-size: 0.76rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid rgba(124,58,237,0.3);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.5);
    transition: all 0.15s;
    user-select: none;
  }
  .interest-chip.selected {
    background: linear-gradient(135deg,#7c3aed,#db2777);
    border-color: transparent;
    color: #fff;
  }
  #interest-selector-panel {
    display: none;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(124,58,237,0.22);
    border-radius: 14px;
    padding: 18px 16px;
    margin-top: 10px;
    width: 100%;
    max-width: 380px;
  }
  #interest-active-badge {
    display: none;
    font-size: 0.72rem;
    color: #a855f7;
    font-weight: 600;
    text-align: center;
    margin-top: 6px;
    cursor: pointer;
  }

</style>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-M2LE5Q48EG">
  // Set language to English for main site
  localStorage.setItem('hummatch_lang', 'en');
</script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag("js", new Date());
  gtag("config", "G-M2LE5Q48EG");
</script>
<script>
// PWA auto-update: check build version on load, force reload if stale
(function() {
  const KEY = 'hm_build_v';
  fetch('/api/hummatch/version', { cache: 'no-store' })
    .then(r => r.json())
    .then(data => {
      const stored = localStorage.getItem(KEY);
      if (stored && stored !== data.v) {
        localStorage.setItem(KEY, data.v);
        location.reload(true);
      } else {
        localStorage.setItem(KEY, data.v);
      }
    })
    .catch(() => {}); // silent fail, never block the app
})();
</script>
</head>
<body>
<!-- Header Bar -->
<header class="hm-header">
  <a class="hm-header-logo" href="/">HumMatch</a>
