// Sort SONGS by Spotify popularity BEFORE any matching
// Use real Spotify 'popularity' field (0-100) where available
// Songs with Spotify data (2,300+) float to top automatically
SONGS.sort((a, b) => {
  const popDiff = (b.popularity || 0) - (a.popularity || 0);
  if (popDiff !== 0) return popDiff;
  // Tie-breaker: year (newer first)
  return (b.year || 0) - (a.year || 0);
});

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');,
    "language": "es"
}

// ── Interest Selector ──────────────────────────────────────────────────────
(function initInterestSelector() {
  const GENRES  = [
    { id:'pop',       label:'Pop' },
    { id:'rock',      label:'Rock' },
    { id:'country',   label:'Country' },
    { id:'rnb',       label:'R&B' },
    { id:'hiphop',    label:'Hip-Hop' },
    { id:'latin',     label:'Latin' },
    { id:'indie',     label:'Indie' },
    { id:'disco',     label:'Disco' },
    { id:'50s60s',    label:'50s-60s' },
    { id:'70s',       label:'70s' },
  ];
  const DECADES = [
    { id:'80s',    label:'80s' },
    { id:'90s',    label:'90s' },
    { id:'2000s',  label:'2000s' },
    { id:'2010s',  label:'2010s' },
    { id:'2020s',  label:'2020s' },
  ];

  function buildChips(containerId, items, selectedIds) {
    const el = document.getElementById(containerId);
    if (!el) return;
    el.innerHTML = items.map(item => `
      <div class="interest-chip${selectedIds.includes(item.id) ? ' selected' : ''}"
           data-id="${item.id}"
           onclick="toggleChip(this,'${containerId}')">
        ${item.label}
      </div>`).join('');
  }

  // Load saved prefs
  let saved = { genres: [], decades: [] };
  try { saved = JSON.parse(localStorage.getItem('hm_interests') || 'null') || { genres: [], decades: [] }; } catch(_) {}

  buildChips('genre-chips',  GENRES,  saved.genres  || []);
  buildChips('decade-chips', DECADES, saved.decades || []);

  // Show active badge if filter is on
  if ((saved.genres && saved.genres.length) || (saved.decades && saved.decades.length)) {
    const badge = document.getElementById('interest-active-badge');
    if (badge) badge.style.display = 'block';
  }
})();

window.toggleChip = function(el, containerId) {
  el.classList.toggle('selected');
};

window.toggleInterestPanel = function() {
  const panel  = document.getElementById('interest-selector-panel');
  const badge  = document.getElementById('interest-active-badge');
  const btn    = document.getElementById('interest-toggle-btn');
  const isOpen = panel.style.display !== 'none';
  panel.style.display = isOpen ? 'none' : 'block';
  if (btn) btn.style.display = isOpen ? 'inline-block' : 'none';
  if (badge && isOpen) badge.style.display = 'none';
};

window.saveInterests = function() {
  const genres  = [...document.querySelectorAll('#genre-chips .interest-chip.selected')].map(c => c.dataset.id);
  const decades = [...document.querySelectorAll('#decade-chips .interest-chip.selected')].map(c => c.dataset.id);
  localStorage.setItem('hm_interests', JSON.stringify({ genres, decades }));
  const panel = document.getElementById('interest-selector-panel');
  const btn   = document.getElementById('interest-toggle-btn');
  const badge = document.getElementById('interest-active-badge');
  if (panel) panel.style.display = 'none';
  if (btn)   btn.style.display   = 'inline-block';
  if (badge) badge.style.display = (genres.length || decades.length) ? 'block' : 'none';
};

window.skipInterests = function() {
  localStorage.setItem('hm_interests', JSON.stringify({ genres: [], decades: [] }));
  const panel = document.getElementById('interest-selector-panel');
  const btn   = document.getElementById('interest-toggle-btn');
  const badge = document.getElementById('interest-active-badge');
  if (panel) panel.style.display = 'none';
  if (btn)   btn.style.display   = 'inline-block';
  if (badge) badge.style.display = 'none';
};

window.clearInterests = function() {
  localStorage.setItem('hm_interests', JSON.stringify({ genres: [], decades: [] }));
  // Reset chips
  document.querySelectorAll('.interest-chip').forEach(c => c.classList.remove('selected'));
  const badge = document.getElementById('interest-active-badge');
  if (badge) badge.style.display = 'none';
  // Re-run results with no filter
  showResults();
};
// ── End Interest Selector ──────────────────────────────────────────────────

function retryHum() {
  // Clean up no-match banner if present
  const banner = document.getElementById('no-match-banner');
  if (banner) banner.remove();
  showScreen('screen-welcome');
}

function applyPromoCode() {
  const input = document.getElementById('promo-input');
  const msg = document.getElementById('promo-msg');
  const code = (input ? input.value.trim().toUpperCase() : '');
  const validCodes = ['HMFRIEND', 'HUMMATCH20'];
  if (validCodes.includes(code)) {
    localStorage.setItem('hm_premium', 'true');
    localStorage.removeItem('hm_hum_count');
    if (msg) { msg.style.color = '#22c55e'; msg.textContent = '✅ Code applied! Enjoy unlimited hums.'; }
    setTimeout(() => {
      const modal = document.getElementById('limit-modal');
      if (modal) modal.remove();
      startTest();
    }, 1200);
  } else {
    if (msg) { msg.style.color = '#f87171'; msg.textContent = 'Invalid code. Try again.'; }
    if (input) input.value = '';
  }
}

// ── startTest: route to primer screen (checks hum limit first) ──
async function startTest() {
  // Check free hum limit (10 hums per month for non-premium)
  const isPremium = localStorage.getItem('hm_premium') === 'true';
  if (!isPremium) {
    const monthKey = new Date().toISOString().slice(0,7);
    const storedMonth = localStorage.getItem('hm_hum_month');
    if (storedMonth !== monthKey) {
      localStorage.setItem('hm_hum_month', monthKey);
      localStorage.setItem('hm_hum_count', '0');
    }
    const humCount = parseInt(localStorage.getItem('hm_hum_count') || '0');
    if (humCount >= 5) {
      showScreen('screen-welcome');
      const modal = document.createElement('div');
      modal.id = 'limit-modal';
      modal.style.cssText = 'position:fixed;inset:0;z-index:3000;background:rgba(8,6,15,0.96);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;text-align:center;';
      const isLoggedIn = !!localStorage.getItem('hm_token');
      const limitSubtext = isLoggedIn
        ? 'Unlock Squad Leader for unlimited hums and exports.'
        : 'Create a free account to track your usage across devices, or unlock Squad Leader.';
      modal.innerHTML = `
        <div style="font-size:2.5rem;margin-bottom:16px;">🎤</div>
        <h2 style="font-size:1.4rem;font-weight:900;margin-bottom:12px;">Free hums available when invited by a Squad Leader</h2>
        <p style="color:rgba(255,255,255,0.6);font-size:0.95rem;line-height:1.6;margin-bottom:28px;max-width:300px;">${limitSubtext}</p>

        <div style="width:100%;max-width:300px;margin-bottom:8px;">
          <div style="display:flex;gap:8px;">
            <input id="promo-input" type="text" placeholder="Promo code" autocapitalize="characters" style="flex:1;padding:12px 14px;background:rgba(255,255,255,0.07);border:1px solid rgba(168,85,247,0.3);border-radius:10px;color:#fff;font-size:0.95rem;outline:none;"/>
            <button onclick="applyPromoCode()" style="padding:12px 16px;background:rgba(168,85,247,0.2);border:1px solid rgba(168,85,247,0.4);border-radius:10px;color:#a855f7;font-size:0.9rem;font-weight:700;cursor:pointer;">Apply</button>
          </div>
          <div id="promo-msg" style="font-size:0.8rem;margin-top:6px;min-height:18px;"></div>
        </div>
        <button onclick="document.getElementById('limit-modal').remove()" style="background:none;border:none;color:rgba(255,255,255,0.35);font-size:0.85rem;cursor:pointer;padding:8px;">Not now</button>
      `;
      document.body.appendChild(modal);
      return;
    }
    localStorage.setItem('hm_hum_count', humCount + 1);
    if (typeof hmSyncCounts === 'function') hmSyncCounts();
  }
  // Show primer screen instead of jumping straight to test
  showScreen('screen-primer');
}

// ── beginAutoCapture: the drunk-proof tap-once auto-flow ──
async function beginAutoCapture() {
  // Create AudioContext (must be inside gesture handler on iOS)
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  if (audioCtx.state === 'suspended') {
    try { await audioCtx.resume(); } catch(e) {}
  }
  try {
    stream = await navigator.mediaDevices.getUserMedia({ audio: { echoCancellation: false, noiseSuppression: false, autoGainControl: true } });
  } catch(e) {
    alert('Microphone access is required. Please allow mic access and try again.');
    return;
  }
  analyser = audioCtx.createAnalyser();
  analyser.fftSize = 4096;
  source = audioCtx.createMediaStreamSource(stream);
  source.connect(analyser);
  if (audioCtx.state === 'suspended') {
    try { await audioCtx.resume(); } catch(e) {}
  }

  phase = 0;
  capturedNotes = [null, null, null];
  capturedBrightness = [null, null, null];
  capturing = false;

  updatePhaseUI();
  showScreen('screen-test');

  // Auto-start first capture after a brief pause to let user see the instruction
  setTimeout(() => runPhaseCapture(), 800);
}

// ── Countdown ring animation ──
const RING_CIRCUMFERENCE = 2 * Math.PI * 54; // ~339.292
let ringAnimFrame = null;

function animateRing(durationMs, onComplete) {
  const ring = document.getElementById('countdown-ring');
  const numEl = document.getElementById('ring-number');
  const labelEl = document.getElementById('ring-label');
  if (!ring) return;

  ring.style.strokeDasharray = RING_CIRCUMFERENCE;
  ring.style.strokeDashoffset = '0';
  ring.style.transition = 'none';

  const startTime = performance.now();
  let lastSecond = Math.ceil(durationMs / 1000);
  if (numEl) numEl.textContent = lastSecond;
  if (labelEl) labelEl.textContent = 'seconds';

  function tick(now) {
    const elapsed = now - startTime;
    const progress = Math.min(elapsed / durationMs, 1);
    const offset = progress * RING_CIRCUMFERENCE;
    ring.style.strokeDashoffset = offset;

    // Update countdown number
    const remaining = Math.ceil((durationMs - elapsed) / 1000);
    if (remaining !== lastSecond && remaining >= 0) {
      lastSecond = remaining;
      if (numEl) numEl.textContent = remaining <= 0 ? '✓' : remaining;
    }

    if (progress < 1) {
      ringAnimFrame = requestAnimationFrame(tick);
    } else {
      if (numEl) numEl.textContent = '✓';
      if (labelEl) labelEl.textContent = '';
      if (onComplete) onComplete();
    }
  }
  ringAnimFrame = requestAnimationFrame(tick);
}

function resetRing() {
  if (ringAnimFrame) { cancelAnimationFrame(ringAnimFrame); ringAnimFrame = null; }
  const ring = document.getElementById('countdown-ring');
  if (ring) { ring.style.strokeDashoffset = '0'; ring.style.transition = 'none'; }
  const numEl = document.getElementById('ring-number');
  if (numEl) numEl.textContent = '3';
}

// ── Phase success flash ──
function showPhaseSuccess(text) {
  return new Promise(resolve => {
    const overlay = document.getElementById('phase-success');
    const textEl = document.getElementById('phase-success-text');
    if (textEl) textEl.textContent = text || 'Got it!';
    if (overlay) overlay.classList.add('show');
    setTimeout(() => {
      if (overlay) overlay.classList.remove('show');
      resolve();
    }, 900);
  });
}

// ── Update phase UI for auto-flow ──
function updatePhaseUI() {
  const p = PHASES[phase];
  document.getElementById('phase-label').textContent = p.label;
  document.getElementById('phase-title').textContent = p.title;
  document.getElementById('phase-sub').textContent = p.sub;
  const emojiEl = document.getElementById('phase-emoji');
  if (emojiEl) emojiEl.textContent = p.emoji || '🎵';
  const statusEl = document.getElementById('auto-status');
  if (statusEl) { statusEl.textContent = '🎤 Listening...'; statusEl.className = 'auto-status listening'; }
  resetRing();
  [0,1,2].forEach(i => {
    const dot = document.getElementById('dot-'+i);
    if (!dot) return;
    dot.classList.remove('active','done');
    if (i < phase) dot.classList.add('done');
    if (i === phase) dot.classList.add('active');
  });
}

// ── Run a single phase capture (auto-flow: no tap needed) ──
function runPhaseCapture() {
  if (capturing) return;
  hmTrack('hum_start', { phase: phase });
  capturing = true;

  const statusEl = document.getElementById('auto-status');
  if (statusEl) { statusEl.innerHTML = '<span style="color:#A855F7;">Humming... hold it steady</span>'; statusEl.className = 'auto-status listening'; }

  const pitches = [];
  const brightnesses = [];
  const buf = new Float32Array(analyser.fftSize);
  const freqBuf = new Uint8Array(analyser.frequencyBinCount);

  // Start the countdown ring
  animateRing(3000, null);

  const interval = setInterval(() => {
    analyser.getFloatTimeDomainData(buf);
    analyser.getByteFrequencyData(freqBuf);

    let rms = 0;
    for (let i = 0; i < buf.length; i++) rms += buf[i] * buf[i];
    rms = Math.sqrt(rms / buf.length);
    if (rms < 0.001) {
      if (statusEl) statusEl.innerHTML = '🎤 Listening... hum now!';
      return;
    }

    const freq = detectPitch(buf, audioCtx.sampleRate);
    if (freq > 50 && freq < 1400) {
      const midi = freqToMidi(freq);
      pitches.push(midi);
      brightnesses.push(spectralCentroid(freqBuf));

      // Update hidden elements (still used by results engine)
      document.getElementById('pitch-note').textContent = midiToName(midi);
      document.getElementById('pitch-hz').textContent = Math.round(freq) + ' Hz';
      const pct = Math.min(100, Math.max(0, ((midi - 36) / 54) * 100));
      document.getElementById('pitch-bar').style.width = pct + '%';

      if (statusEl) {
        if (rms > 0.02) { statusEl.innerHTML = '<span style="color:#22C55E;">✓ Good, keep humming!</span>'; }
        else { statusEl.innerHTML = '<span style="color:#F59E0B;">Hum a bit louder</span>'; }
      }
    } else {
      if (statusEl && rms > 0.001) statusEl.innerHTML = '<span style="color:#F59E0B;">Hum a bit louder</span>';
    }
  }, 100);

  captureTimer = setTimeout(async () => {
    clearInterval(interval);
    capturing = false;

    if (pitches.length < 3) {
      // Not enough signal, retry this phase automatically
      if (statusEl) { statusEl.innerHTML = '<span style="color:#F59E0B;">Didn\'t catch that, trying again...</span>'; }
      resetRing();
      setTimeout(() => runPhaseCapture(), 1200);
      return;
    }

    // Median pitch for stability
    pitches.sort((a, b) => a - b);
    const median = pitches[Math.floor(pitches.length / 2)];
    capturedNotes[phase] = median;

    const avgBrightness = brightnesses.reduce((a, b) => a + b, 0) / brightnesses.length;
    const normBrightness = Math.min(100, Math.round((avgBrightness / (analyser.frequencyBinCount / 8)) * 100));
    capturedBrightness[phase] = normBrightness;

    const ids = ['low-note', 'mid-note', 'high-note'];
    document.getElementById(ids[phase]).textContent = midiToName(median);

    if (phase < 2) {
      // Show success flash, then auto-advance
      await showPhaseSuccess('Got it! ' + midiToName(median));
      phase++;
      updatePhaseUI();
      // Auto-start next phase after a brief breath
      setTimeout(() => runPhaseCapture(), 600);
    } else {
      // All 3 phases done
      await showPhaseSuccess('All done!');
      if (statusEl) { statusEl.innerHTML = '<span style="color:#22C55E;">🔍 Analyzing your voice...</span>'; }
      setTimeout(showResults, 500);
    }
  }, 3000);
}

function startWaveform() {
  const canvas = document.getElementById('waveform-canvas');
  const ctx = canvas.getContext('2d');
  const buf = new Float32Array(analyser ? analyser.fftSize : 512);

  function draw() {
    waveRaf = requestAnimationFrame(draw);
    if (!analyser) return;
    analyser.getFloatTimeDomainData(buf);
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.strokeStyle = 'rgba(168,85,247,0.7)';
    ctx.lineWidth = 2;
    ctx.beginPath();
    const sliceW = canvas.width / buf.length;
    let x = 0;
    for (let i = 0; i < buf.length; i++) {
      const y = (buf[i] + 1) / 2 * canvas.height;
      i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      x += sliceW;
    }
    ctx.stroke();
  }
  draw();
}

function showResults() {
  try {
    console.log('[DEBUG] showResults() started');
  if (waveRaf) { cancelAnimationFrame(waveRaf); waveRaf = null; }
  if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
  if (audioCtx) { audioCtx.close(); audioCtx = null; }

  // Determine user's range
  const notes = capturedNotes.filter(n => n !== null);
  if (notes.length < 2) { showScreen('screen-welcome'); return; }

  // Apply generous range extrapolation, humming 3 notes captures the comfortable middle
  // Real singing range extends ~4 semitones below and ~8-10 above the hummed range
  // This corrects the common problem of narrow hum range → too few song matches
  const humLow  = Math.min(...notes);
  const humHigh = Math.max(...notes);
  const humSpan = humHigh - humLow;
  // If span is very narrow (<8 semitones), user likely only hummed comfortable middle, expand
  const extraLow  = humSpan < 10 ? 4 : 2;
  const extraHigh = humSpan < 10 ? 10 : 4;
  const userLow  = humLow  - extraLow;
  const userHigh = humHigh + extraHigh;
  const userBrightness = capturedBrightness.filter(b => b !== null).reduce((a, b) => a + b, 0) /
                         capturedBrightness.filter(b => b !== null).length;

  // Determine voice type
  let voiceType = 'Baritone';
  const span = userHigh - userLow;
  if (userLow <= 40 && userHigh <= 62) voiceType = 'Bass';
  else if (userLow <= 43 && userHigh <= 68) voiceType = 'Bass-Baritone';
  else if (userLow <= 47 && userHigh <= 72) voiceType = 'Baritone';
  else if (userLow <= 51 && userHigh <= 76) voiceType = 'Tenor';
  else if (userLow >= 48 && userLow <= 54 && userHigh <= 72) voiceType = 'Alto/Contralto';
  else if (userLow >= 50 && userHigh <= 76) voiceType = 'Mezzo-soprano';
  else if (userLow >= 52 && userHigh >= 76) voiceType = 'Soprano';
  else if (userHigh >= 74) voiceType = 'Tenor';

  const typeEmoji = { 'Bass':'🔊','Bass-Baritone':'🎸','Baritone':'🎭','Tenor':'🌟','Alto/Contralto':'🍷','Mezzo-soprano':'🔥','Soprano':'✨' };

  // Find closest artist match (range overlap + brightness similarity)
  const scored = ARTISTS.map(a => {
    const overlapLo = Math.max(userLow, a.low);
    const overlapHi = Math.min(userHigh, a.high);
    const overlap = Math.max(0, overlapHi - overlapLo);
    const rangeCover = overlap / Math.max(1, a.high - a.low);
    const brightnessDiff = Math.abs(userBrightness - a.brightness) / 100;
    const score = rangeCover * 0.7 + (1 - brightnessDiff) * 0.3;
    return { ...a, score };
  }).sort((a, b) => b.score - a.score);

  const topArtist = scored[0];
  const topArtists = scored.slice(0, 4);

  // Match songs to user range + brightness, keep top matches
  // Detect likely gender based on vocal range to filter out mismatches
  const isMaleVoice = userHigh <= 65;  // C#4 or below = likely male
  const isFemaleVoice = userLow >= 48; // C3 or above = likely female

  // ── TIERED DISCOVERY SYSTEM ──
  // Organize verified songs into tiers based on humMatchScore (Spotify popularity)
  // Tier 1: Top 2,000 songs (primary matching)
  // Tier 2: Songs ranked 2,001-5,000 (secondary, on-demand)
  // Tier 3: Everything beyond 5,000 (tertiary, on-demand)

  // Filter by language: English site shows English songs, Spanish site shows Spanish
  const userLang = localStorage.getItem('hummatch_lang') || 'en';
  const verifiedSongs = SONGS.filter(s => {
    if (!s.verified) return false;
    const songLang = (s.language || 'en').toLowerCase();
    // On English site: show English + both (bilingual)
    // On Spanish site: show Spanish + both (bilingual)
    if (userLang === 'es') return songLang === 'es' || songLang === 'spanish' || songLang === 'both' || !s.language;
    return songLang !== 'es' && songLang !== 'spanish' || songLang === 'both';
  }).sort((a, b) => (b.humMatchScore || 0) - (a.humMatchScore || 0));

  const TIER_1_SIZE = 2000;
  const TIER_2_SIZE = 5000;
  const tier1Songs = verifiedSongs.slice(0, TIER_1_SIZE);
  const tier2Songs = verifiedSongs.slice(TIER_1_SIZE, TIER_2_SIZE);
  const tier3Songs = verifiedSongs.slice(TIER_2_SIZE);

  // Helper: match a set of songs against user's vocal range + brightness
  function matchSongsAgainstUser(songsToMatch) {
    return songsToMatch
      .map(s => {
        const overlapLo = Math.max(userLow, s.lo);
        const overlapHi = Math.min(userHigh, s.hi);
        const overlap = Math.max(0, overlapHi - overlapLo);
        const rangeFit = overlap / Math.max(1, s.hi - s.lo);
        const brightFit = 1 - Math.abs(userBrightness - s.brightness) / 100;
        return { ...s, score: rangeFit * 0.65 + brightFit * 0.35 };
      })
      .filter(s => {
        // Gender filtering: DUAL approach (tessitura + brightness)
        // Female songs center around C4-C5 (60-72) AND are brighter (55+)
        // Male songs center around G2-G3 (43-55) AND are darker (30-55)
        const songMidpoint = (s.lo + s.hi) / 2;

        // MALE VOICE FILTERING:
        // Block songs with clearly female tessitura (midpoint >= 65 = F4+)
        // AND bright timbre (brightness > 70)
        // Must satisfy BOTH conditions to block — prevents false filtering of male artists
        if (isMaleVoice && songMidpoint >= 65 && s.brightness > 70) return false;

        // FEMALE VOICE FILTERING:
        // Block songs with clearly male tessitura (midpoint < 48 = C3)
        // AND dark timbre (brightness < 30)
        if (isFemaleVoice && songMidpoint < 48 && s.brightness < 30) return false;

        return s.score > 0.3; // Lower threshold to allow more matches
      });
  }

  // Helper: sort and deduplicate matched songs
  function processMatchedSongs(matched) {
    return matched
      .sort((a, b) => {
        // Sort by MATCH SCORE (rangeFit 65% + brightFit 35%) - determines best vocal fit
        return b.score - a.score;
      })
      .reduce((acc, s) => {
        // Cap at 2 songs per artist to prevent Johnny Cash monopoly
        const artistCount = acc.filter(x => x.artist === s.artist).length;
        if (artistCount < 2) acc.push(s);
        return acc;
      }, [])
      .slice(0, 60);  // Keep full pool for dismissal backfill + show-more variety
  }

  // Match all three tiers upfront
  const tier1Matches = processMatchedSongs(matchSongsAgainstUser(tier1Songs));
  const tier2Matches = processMatchedSongs(matchSongsAgainstUser(tier2Songs));
  const tier3Matches = processMatchedSongs(matchSongsAgainstUser(tier3Songs));

  // Combine tiers: if Tier 1 < 10 matches, auto-include Tier 2
  let matchedSongs;
  if (tier1Matches.length < 10) {
    matchedSongs = [...tier1Matches, ...tier2Matches];
  } else {
    matchedSongs = tier1Matches;
  }

  // Store all tier matches globally for progressive loading
  window._hmTier1Matches = tier1Matches;
  window._hmTier2Matches = tier2Matches;
  window._hmTier3Matches = tier3Matches;
  window._hmTier2Count = tier2Matches.length;
  window._hmTier3Count = tier3Matches.length;

  // Helper: deduplicate by normalized title
  function deduplicateSongs(songs) {
    const seenTitles = new Set();
    return songs.filter(s => {
      const norm = s.title.toLowerCase().replace(/^(i |the |a |an )/,'').trim();
      if (seenTitles.has(norm)) return false;
      seenTitles.add(norm);
      return true;
    });
  }

  // Deduplicate all tier matches
  const deduped = deduplicateSongs(matchedSongs);
  const deduped2 = deduplicateSongs(tier2Matches);
  const deduped3 = deduplicateSongs(tier3Matches);

  // Store all deduplicated tiers for tier navigation
  window._hmTier1Deduped = deduplicateSongs(tier1Matches);
  window._hmTier2Deduped = deduped2;
  window._hmTier3Deduped = deduped3;

  // Store full pool globally, dismissals pull next song from here
  window._hmFullPool = deduped;
  // Restore dismissed songs from localStorage so they persist across sessions
  const savedDismissed = JSON.parse(localStorage.getItem('hm_dismissed') || '[]');
  window._hmDismissed = new Set(savedDismissed);

  // ── RENDER ──
  document.getElementById('voice-badge').innerHTML = `${typeEmoji[voiceType] || '🎤'} ${voiceType} Hummer`;
  document.getElementById('result-emoji').textContent = (topArtist && topArtist.emoji) ? topArtist.emoji : '🎉';

  // Brightness descriptor based on score (only if captured)
  if (userBrightness && !isNaN(userBrightness)) {
    const brightnessLabel = userBrightness >= 70 ? 'Very Bright' :
                            userBrightness >= 55 ? 'Bright' :
                            userBrightness >= 45 ? 'Neutral' :
                            userBrightness >= 30 ? 'Dark & Warm' : 'Very Dark';
    document.getElementById('brightness-text').textContent =
      `✨ Timbre: ${Math.round(userBrightness)}/100 (${brightnessLabel})`;
  }

  document.getElementById('range-text').textContent =
    `${midiToName(userLow)} to ${midiToName(userHigh)} · ${span} semitone range`;

  // Range bar
  const fullSpan = 90 - 36;
  const leftPct = ((userLow - 36) / fullSpan * 100).toFixed(1);
  const widthPct = (((userHigh - userLow)) / fullSpan * 100).toFixed(1);
  document.getElementById('range-bar-fill').style.left = leftPct + '%';
  document.getElementById('range-bar-fill').style.width = widthPct + '%';

  // Share data (topSong set after confidentSongs is built below)
  shareVoiceType = voiceType;
  shareMatchPct = topArtist ? Math.round(topArtist.score * 100) : 0;
  hmTrack("hum_complete", { voice_type: voiceType, score: shareMatchPct });

  // ── Log hum to user's hum_history (if logged in) ──
  const _humToken = typeof hmGetToken === 'function' ? hmGetToken() : null;
  function logHumMatch(title, artist, confidence) {
    if (!_humToken) return;
    fetch('/api/hummatch/hum', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-HM-Token': _humToken },
      body: JSON.stringify({ song_title: title, artist: artist, confidence: confidence })
    }).catch(() => {});
  }

  // ── Confidence tier assignment ──
  function getTier(score) {
    if (score >= 0.78) return { key: 'nail',   label: '✅ Nail It',    cls: 'tier-nail' };
    if (score >= 0.60) return { key: 'strong', label: '🎯 Strong Fit', cls: 'tier-strong' };
    return                     { key: 'stretch',label: '💪 Stretch',   cls: 'tier-stretch' };
  }

  // Familiar song keywords, crowd-recognizable titles
  const FAMILIAR_WORDS = ['love','night','dream','heart','world','baby','fire','home','run','free','time','life','forever','angel','sky','gold','girl','dancing','shine','feel','hello','don\'t','can\'t','won\'t','isn\'t'];
  function isFamiliar(title) {
    const t = title.toLowerCase();
    return FAMILIAR_WORDS.some(w => t.includes(w));
  }

  // Genre/mood/context tagging
  function getTags(s) {
    const t = (s.title + ' ' + s.artist).toLowerCase();
    const tags = [];
    if (/elvis|sinatra|cash|dean martin|tony bennett|nat king/i.test(t)) tags.push('classic');
    if (/beatles|queen|bowie|journey|bon jovi|aerosmith|petty|springsteen|eagles|guns n roses|led zeppelin|u2|the who|rolling stones|david bowie|fleetwood mac|creedence|lynyrd skynyrd|acdc|ac\/dc|metallica|iron maiden|black sabbath|ozzy|nirvana|pearl jam|soundgarden|alice in chains|foo fighters|green day|weezer|radiohead|oasis|blur|the strokes|arctic monkeys|the killers|the cure|depeche mode|linkin park|system of a down|tool|pantera|megadeth|slayer|judas priest|van halen/i.test(t)) tags.push('rock');
    if (/ed sheeran|bruno mars|michael jackson|katy perry|taylor swift|adele|beyonce|lady gaga|ariana grande|justin bieber|selena gomez|dua lipa|charlie puth|shawn mendes|halsey|billie eilish|olivia rodrigo|harry styles|the weeknd|post malone|lizzo|meghan trainor|sam smith|john legend|sia|kelly clarkson|pink|britney spears|backstreet boys|nsync|spice girls|one direction|coldplay|imagine dragons|maroon 5|train|onerepublic|jason mraz|colbie caillat/i.test(t)) tags.push('pop');
    if (/cash|stapleton|morgan wallen|luke combs|zach bryan|tyler childers|luke bryan|blake shelton|keith urban|kenny chesney|garth brooks|tim mcgraw|alan jackson|carrie underwood|miranda lambert|kacey musgraves|maren morris|dolly parton|willie nelson|kenny rogers|hank williams|patsy cline|merle haggard|waylon jennings|loretta lynn|george jones|randy travis|shania twain|faith hill|brooks & dunn|george strait|reba mcentire|toby keith|zac brown|jason aldean|eric church|dierks bentley|thomas rhett|john denver|brad paisley|jimmie allen|brett eldredge|old dominion|little big town|chris young/i.test(t)) tags.push('country');
    // R&B
    if (/beyonce|alicia keys|marvin gaye|sam cooke|otis redding|al green|stevie wonder|aretha franklin|amy winehouse|usher|chris brown|rihanna|frank ocean|john legend|d'angelo|erykah badu|maxwell|brian mcknight|boyz ii men|boys ii men|r kelly|joe|neyo|ne-yo|toni braxton|mary j blige|lauryn hill|whitney houston|janet jackson|sza|h.e.r|her|giveon|daniel caesar/i.test(t)) tags.push('rnb');
    // Hip-Hop
    if (/drake|kanye|kendrick lamar|jay.z|eminem|post malone|travis scott|lil wayne|lil baby|future|21 savage|cardi b|nicki minaj|j cole|big sean|chance|childish gambino|logic|macklemore|old school rap|hip.hop|hip hop|rap/i.test(t)) tags.push('hiphop');
    // Latin
    if (/shakira|j balvin|bad bunny|marc anthony|luis miguel|jennifer lopez|ricky martin|enrique iglesias|pitbull|maluma|ozuna|daddy yankee|reggaeton|latin|bachata|salsa|juan gabriel|jose jose|camila cabello|gloria estefan|carlos santana|celia cruz/i.test(t)) tags.push('latin');
    // Christian/Gospel
    if (/lauren daigle|hillsong|chris tomlin|casting crowns|lecrae|tauren wells|for king|david crowder|tobymac|toby mac|matthew west|michael w. smith|michael w smith|amy grant|steven curtis chapman|dc talk|skillet|third day|newsboys|mercy me|mercyme|mandisa|plumb|bebo norman|jeremy camp|elevation|bethel|maverick|cain|brandon lake|zach williams|phil wickham|gateway worship|kristian stanfill/i.test(t)) tags.push('christian');
    // Indie
    if (/radiohead|arcade fire|death cab|the national|fleet foxes|bon iver|sufjan stevens|iron & wine|vampire weekend|the strokes|modest mouse|of montreal|beirut|jose gonzalez|jose gonzález|the lumineers|mumford|the head|lord huron|father john misty|phoebe bridgers|boygenius|lucy dacus|hozier|james blake|alt.j|alt j|tame impala|king krule|frank turner/i.test(t)) tags.push('indie');
    // Metal
    if (/metallica|iron maiden|black sabbath|ozzy osbourne|slayer|megadeth|pantera|tool|korn|linkin park|system of a down|disturbed|slipknot|five finger|breaking benjamin|halestorm|evanescence|within temptation|nightwish|epica|dimmu borgir|children of bodom|lamb of god|as i lay dying/i.test(t)) tags.push('metal');
    // Jazz / Standards
    if (/sinatra|nat king cole|ella fitzgerald|michael bublé|michael buble|chet baker|billie holiday|louis armstrong|tony bennett|dean martin|miles davis|john coltrane|diana krall|norah jones|frank sinatra|johnny hartman|peggy lee|sarah vaughan|bossa nova|swing|big band/i.test(t)) tags.push('jazz');
    // Disco / Funk
    if (/abba|bee gees|donna summer|earth wind|kool & the gang|kool and the gang|chic|sister sledge|gloria gaynor|village people|rick james|sly & the family|sly and the family|george clinton|parliament|funkadelic|james brown|jackson 5|michael jackson.*disco|disco|funky/i.test(t)) tags.push('disco');

    if (/party|dance|tonight|celebrate|good time/i.test(t)) tags.push('party');
    if (isFamiliar(s.title)) tags.push('familiar');
    // Context tags
    if (/don\'t stop|bohemian|sweet home|livin\' on a prayer|born to run|highway|take me home|africa|september|tiny dancer|mr\. brightside|rolling|journey|survivor|eye of the tiger|thunder|sweet caroline|don\'t stop believin|shake it off|uptown funk|can\'t stop/i.test(t)) tags.push('car');
    if (tags.includes('rock') || tags.includes('classic')) tags.push('car');
    if (/falling|alone|missing|broken|hold on|without you|one more|someone like|fix you|yellow|hallelujah|tears|cry|prayer|believe|in my life|yesterday|imagine|hero/i.test(t)) tags.push('solo');
    if (/love shack|september|sweet caroline|living on a prayer|don\'t stop believin|thriller|girls just|shake it|dancing queen|i will survive|mr\. brightside|africa|uptown|happy|party|tonight|everyone|group|together/i.test(t)) tags.push('group');
    if (tags.includes('party')) tags.push('group');
    return tags;
  }

  // Decade tag from year
  function getDecadeTag(s) {
    const yr = s.year || 0;
    if (yr >= 2020) return '2020s';
    if (yr >= 2010) return '2010s';
    if (yr >= 2000) return '2000s';
    if (yr >= 1990) return '90s';
    if (yr >= 1980) return '80s';
    if (yr >= 1970) return '70s';
    return '50s60s'; // pre-1970 or unknown
  }

  // Extend matchedSongs with tiers + tags + decade
  const tieredSongs = deduped.map(s => ({
    ...s,
    tier: getTier(s.score),
    tags: getTags(s),
    decade: getDecadeTag(s),
    familiar: isFamiliar(s.title)
  }));

  // ── Apply user interest filter ──
  const _interests = (function() {
    try { return JSON.parse(localStorage.getItem('hm_interests') || 'null'); } catch(_) { return null; }
  })();
  // Merge genres and decades into one filter (decades are now genre tags)
  const _allFilters = [];
  if (_interests) {
    if (_interests.genres) _allFilters.push(..._interests.genres);
    if (_interests.decades) _allFilters.push(..._interests.decades);
  }
  const _hasFilter = _allFilters.length > 0;
  console.log('[FILTER DEBUG] _allFilters:', _allFilters);
  console.log('[FILTER DEBUG] _hasFilter:', _hasFilter);
  function _matchesInterests(s) {
    if (!_hasFilter) return true;
    if (!s.tags || !s.tags.length) return false;
    const matches = s.tags.some(tag => _allFilters.includes(tag));
    return matches;
  }

  // Separate confident songs from stretch
  // Filter out previously dismissed songs
  const isDismissed = s => window._hmDismissed && window._hmDismissed.has((s.title + '__' + s.artist).replace(/['"]/g,''));

  // Sort by match percentage descending (best matches first)
  function sessionShuffle(songs) {
    // Sort by popularity first, then by match score
    return songs.slice().sort((a, b) => {
      const popDiff = (b.humMatchScore || 0) - (a.humMatchScore || 0);
      if (popDiff !== 0) return popDiff;
      return b.score - a.score;
    });
  }

  const _confidentRaw = tieredSongs.filter(s => s.tier.key !== 'stretch' && !isDismissed(s));
  console.log('[FILTER DEBUG] _confidentRaw count:', _confidentRaw.length);
  console.log('[FILTER DEBUG] First 3 songs tags:', _confidentRaw.slice(0,3).map(s => ({title: s.title, tags: s.tags})));
  const _confidentFiltered = _confidentRaw.filter(_matchesInterests);
  console.log('[FILTER DEBUG] _confidentFiltered count:', _confidentFiltered.length);

  // If genre/decade filter results in too few songs (<10), include stretch songs that match filter
  const needMoreSongs = _hasFilter && _confidentFiltered.length < 10;
  const _stretchFiltered = needMoreSongs ? tieredSongs.filter(s => s.tier.key === 'stretch' && !isDismissed(s) && _matchesInterests(s)) : [];

  // Respect genre/decade filters, but fall back if empty (prevents stuck state)
  // For tiered discovery, include all tiers (Tier 1, 2, 3) so they can be progressively loaded
  const allTieredSongs = [...deduped, ...deduped2, ...deduped3];
  const tieredWithMeta = allTieredSongs.map(s => ({
    ...s,
    tier: getTier(s.score),
    tags: getTags(s),
    decade: getDecadeTag(s),
    familiar: isFamiliar(s.title)
  }));

  const confidentSongs = sessionShuffle(
    _hasFilter && _confidentFiltered.length > 0
      ? [..._confidentFiltered, ..._stretchFiltered]
      : _confidentRaw
  );
  const _tasteFilterActive = _hasFilter && _confidentFiltered.length > 0;
  const stretchSongs   = tieredSongs.filter(s => s.tier.key === 'stretch' && !isDismissed(s));

  // Set share song data now that confidentSongs is available
  const topSong = confidentSongs[0] || deduped[0];
  shareArtistName = topSong ? topSong.title + ' by ' + topSong.artist : (topArtist ? topArtist.name : '');
  shareTopSong = topSong ? { title: topSong.title, artist: topSong.artist } : null;

  // ── Store hum data for retroactive save (if user signs up after) ──
  window._pendingHumData = {
    low_note: capturedNotes[0],
    normal_note: capturedNotes[1],
    high_note: capturedNotes[2],
    voice_type: voiceType,
    top_song: topSong ? topSong.title : '',
    top_artist: topSong ? topSong.artist : '',
    match_score: topSong ? Math.round((topSong.score || 0) * 100) : 0
  };

  // ── Immediately sync hum_count + log hum session to server ──
  if (typeof hmSyncCounts === 'function') hmSyncCounts();
  if (_humToken) {
    const humCount = parseInt(localStorage.getItem('hm_hum_count') || '0');
    fetch('/api/hummatch/hum/session', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-HM-Token': _humToken },
      body: JSON.stringify({
        low_note: capturedNotes[0],
        normal_note: capturedNotes[1],
        high_note: capturedNotes[2],
        voice_type: voiceType,
        top_song: topSong ? topSong.title : '',
        top_artist: topSong ? topSong.artist : '',
        match_score: topSong ? Math.round((topSong.score || 0) * 100) : 0,
        hum_count: humCount
      })
    }).catch(() => {});
  }

  // Store globally for filter re-render
  window._hmSongs = tieredSongs;
  window._hmStretch = stretchSongs;

  // ── SquadMatch: store songs for squad creation ──
  // Always save top 20 songs to localStorage so SquadMatch can pick them up
  const _squadSongs = confidentSongs.slice(0, 20).map(s => ({ title: s.title, artist: s.artist, score: s.score || 0 }));
  try {
    localStorage.setItem('hm_squad_my_songs', JSON.stringify(_squadSongs));
    if (voiceType) localStorage.setItem('hm_squad_voice_type', voiceType);
  } catch(_) {}

  // If returning from squad join flow (index.html?squad=X&member=Y), submit results to squad
  (function() {
    const _sqp = new URLSearchParams(location.search);
    const _sqId = _sqp.get('squad');
    const _sqMid = _sqp.get('member');
    if (_sqId && _sqMid) {
      const _sqSongs = confidentSongs.slice(0, 20).map(s => ({ title: s.title, artist: s.artist, score: s.score || 0 }));
      const _sqRange = window._humRange || { lo: userLow, hi: userHigh };
      fetch('/api/hummatch/squad/' + _sqId + '/hum', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          member_id: parseInt(_sqMid),
          songs: _sqSongs,
          voice_type: voiceType || '',
          voice_low: _sqRange.lo || userLow,
          voice_high: _sqRange.hi || userHigh
        })
      }).then(() => {
        // Hide squad prompt, show "submitted" message then redirect
        const prompt = document.getElementById('squad-prompt-module');
        if (prompt) {
          prompt.innerHTML = '<div style="background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.25);border-radius:14px;padding:18px 20px;text-align:center"><div style="color:#4ade80;font-weight:700;font-size:0.92rem;margin-bottom:6px">✓ Results submitted to your squad!</div><div style="font-size:0.78rem;color:rgba(255,255,255,0.45);margin-bottom:12px">Redirecting to your SquadMatch...</div><a href="/squadmatch?squad=' + _sqId + '" style="display:inline-block;padding:10px 20px;background:linear-gradient(135deg,#A855F7,#EC4899);color:#fff;font-size:0.82rem;font-weight:700;border-radius:10px;text-decoration:none;">See Squad Progress</a></div>';
        }
        setTimeout(() => { window.location = '/squadmatch?squad=' + _sqId; }, 2000);
      }).catch(() => {});
    }
  })();

  // Era tagging
  function getEra(s) {
    const yr = s.year || 0;
    if (yr >= 2015) return 'recent';
    if (yr >= 2000) return '2000s';
    if (yr >= 1990) return '90s';
    if (yr >= 1980) return '80s';
    if (yr >= 1970) return '70s';
    return 'classic';
  }

  // Render song card
  let _renderIdx = 0;
  function renderSongCard(s) {
    const idx = _renderIdx++;
    hmTrack("song_matched", { title: s.title, artist: s.artist, score: Math.round((s.score || 0) * 100) });
    logHumMatch(s.title, s.artist, Math.round((s.score || 0) * 100));
    const tags = s.tags || [];
    const era  = getEra(s);
    const tierBadge = `<span class="tier-badge ${s.tier.cls}">${s.tier.label}</span>`;
    // Category badge logic
    const scorePct = Math.round((s.score || 0) * 100);
    const songRange = (s.hi || 0) - (s.lo || 0);
    const hiDiff = Math.abs((s.hi || 0) - userHigh);
    const isDuet = /duet/i.test(s.title) || songRange >= 20;
    const isStretchRange = s.tier.key === 'stretch';
    let catBadge = '';
    if (scorePct >= 85) { catBadge = '<span class="cat-badge cat-best">🎯 Best Match</span>'; }
    else if (idx < 3) { catBadge = '<span class="cat-badge cat-top">⭐ Top Pick</span>'; }
    else if (hiDiff <= 2 && s.hi > userHigh) { catBadge = '<span class="cat-badge cat-stretch">🔥 Stretch</span>'; }
    else if (isDuet) { catBadge = '<span class="cat-badge cat-duet">🎤 Great Duet</span>'; }
    else if (isStretchRange) { catBadge = '<span class="cat-badge cat-trans">🔑 Try with Transposition</span>'; }
    const titleSafe  = s.title.replace(/'/g,"\\'");
    const artistSafe = s.artist.replace(/'/g,"\\'");
    const songKey = (s.title + '__' + s.artist).replace(/['"]/g,'');
    const genreLabel = tags.includes('rock') ? 'Rock' : tags.includes('pop') ? 'Pop' : tags.includes('country') ? 'Country' : tags.includes('classic') ? 'Classic' : '';
    const pageSlug = toSlug(s.title) + '-' + toSlug(s.artist);
    const guideLink = `<a href="${getSongLink(pageSlug)}" style="color:rgba(168,85,247,0.7);font-size:0.68rem;font-weight:600;text-decoration:none;white-space:nowrap;" title="Vocal range guide for ${s.title}">Range Guide →</a>`;
    return `<li class="song-item"
      id="song-${songKey}"
      data-tier="${s.tier.key}"
      data-tags="${tags.join(',')}"
      data-era="${era}"
      data-lang="${s.lang || 'en'}"
      data-familiar="${s.familiar}">
      <div class="song-item-top">
        <span class="song-title" onclick="openKaraoke('${titleSafe}','${artistSafe}')">${s.title}</span>
        ${tierBadge}
      </div>
      <div class="song-meta">
        <span>${s.artist}</span>
        ${genreLabel ? `<span class="dot">·</span><span>${genreLabel}</span>` : ''}
        ${s.year    ? `<span class="dot">·</span><span>${s.year}</span>` : ''}
        ${s.score ? `<span class="dot">·</span><span style="color:#4ade80;font-weight:700;">✓ ${Math.round(s.score * 100)}% match</span>` : ''}
      </div>
      ${catBadge}
      <div class="song-bottom">
        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;color:rgba(255,255,255,0.4);font-size:0.68rem;font-weight:600;user-select:none;">
          <input type="checkbox" class="hm-song-check" data-title="${s.title.replace(/"/g,'&quot;')}" data-artist="${s.artist.replace(/"/g,'&quot;')}" onchange="togglePlaylistSong(this.dataset.title,this.dataset.artist,this.checked)" style="accent-color:#A855F7;width:14px;height:14px;cursor:pointer;flex-shrink:0;"/>
          Add to playlist
        </label>
        ${guideLink}
        <a href="${getSongLink(s.title.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'')+'-'+s.artist.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,''))}" class="sing-btn" style="text-decoration:none;color:inherit;display:inline-block;">▶ Sing It</a>
      </div>
    </li>`;
  }

  // Render all confident songs
  _renderIdx = 0; // reset category badge index
  const yourSongsEl = document.getElementById('your-songs');
  if (!confidentSongs.length) {
    hmTrack("no_match");
    // Fallback: loosen threshold and show top 3 range-based suggestions
    const fallbackSongs = verifiedSongs
      .map(s => {
        const overlapLo = Math.max(userLow, s.lo);
        const overlapHi = Math.min(userHigh, s.hi);
        const overlap = Math.max(0, overlapHi - overlapLo);
        const rangeFit = overlap / Math.max(1, s.hi - s.lo);
        const brightFit = 1 - Math.abs(userBrightness - s.brightness) / 100;
        return { ...s, score: rangeFit * 0.65 + brightFit * 0.35 };
      })
      .filter(s => s.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 3);

    if (fallbackSongs.length) {
      yourSongsEl.innerHTML = fallbackSongs.map(renderSongCard).join('');
      // Insert fallback header before the list
      yourSongsEl.insertAdjacentHTML('beforebegin', `
        <div id="no-match-banner" style="width:100%;max-width:400px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:14px 16px;margin-bottom:12px;text-align:center;">
          <div style="font-size:0.8rem;font-weight:700;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">Best Range Match</div>
          <div style="font-size:0.78rem;color:rgba(255,255,255,0.4);margin-bottom:12px;">We could not find a perfect fit. Here are 3 songs worth trying based on your range.</div>
          <button onclick="retryHum()" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);border-radius:50px;padding:8px 20px;font-size:0.82rem;cursor:pointer;font-family:inherit;">🎤 Want to try again?</button>
        </div>`);
    } else {
      yourSongsEl.insertAdjacentHTML('beforebegin', `
        <div id="no-match-banner" style="width:100%;max-width:400px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:14px 16px;margin-bottom:12px;text-align:center;">
          <div style="font-size:0.8rem;font-weight:700;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">No Match Found</div>
          <div style="font-size:0.78rem;color:rgba(255,255,255,0.4);margin-bottom:12px;">Try humming in a quieter space and hold each note for a full 2 seconds.</div>
          <button onclick="retryHum()" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);border-radius:50px;padding:8px 20px;font-size:0.82rem;cursor:pointer;font-family:inherit;">🎤 Want to try again?</button>
        </div>`);
      yourSongsEl.innerHTML = '';
    }
  } else {
    // ── Taste filter banner ──
    const _existingTasteBanner = document.getElementById('hm-taste-banner');
    if (_existingTasteBanner) _existingTasteBanner.remove();
    if (_tasteFilterActive) {
      const _filterLabels = { pop:'Pop', rock:'Rock', country:'Country', rnb:'R&B', hiphop:'Hip-Hop', latin:'Latin', indie:'Indie', disco:'Disco', '50s60s':'50s/60s', '70s':'70s', '80s':'80s', '90s':'90s', '2000s':'2000s', '2010s':'2010s', '2020s':'2020s' };
      const _filterDesc = _allFilters.map(f => _filterLabels[f] || f).join(', ');
      yourSongsEl.insertAdjacentHTML('beforebegin', `
        <div id="hm-taste-banner" style="width:100%;max-width:400px;background:rgba(168,85,247,0.08);border:1px solid rgba(168,85,247,0.22);border-radius:12px;padding:12px 16px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;gap:10px;">
          <div>
            <div style="font-size:0.78rem;font-weight:700;color:#c084fc;margin-bottom:2px;">🎯 ${confidentSongs.length} songs match your voice &amp; taste</div>
            <div style="font-size:0.68rem;color:rgba(255,255,255,0.35);">${_filterDesc}</div>
          </div>
          <button onclick="clearInterests()" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.45);border-radius:8px;padding:5px 10px;font-size:0.68rem;cursor:pointer;font-family:inherit;white-space:nowrap;flex-shrink:0;">Show All</button>
        </div>`);
    }

    const PAGE_SIZE = 10;

    // Tier system: 2K → 5K → Everything
    // Use pre-computed tier matches with full metadata
    window._hmTier1AllSongs = deduped.map(s => ({
      ...s,
      tier: getTier(s.score),
      tags: getTags(s),
      decade: getDecadeTag(s),
      familiar: isFamiliar(s.title)
    }));
    window._hmTier2AllSongs = deduped2.map(s => ({
      ...s,
      tier: getTier(s.score),
      tags: getTags(s),
      decade: getDecadeTag(s),
      familiar: isFamiliar(s.title)
    }));
    window._hmTier3AllSongs = deduped3.map(s => ({
      ...s,
      tier: getTier(s.score),
      tags: getTags(s),
      decade: getDecadeTag(s),
      familiar: isFamiliar(s.title)
    }));

    // For backwards compatibility, also set confidentSongs
    window._hmConfidentAll = confidentSongs;
    window._hmConfidentPage = 0;
    window._hmActiveTier = 1; // Start with tier 1

    function getActiveTierSongs() {
      if (window._hmActiveTier === 1) return window._hmTier1AllSongs;
      else if (window._hmActiveTier === 2) {
        // Tier 2 is shown after Tier 1
        return [...window._hmTier1AllSongs, ...window._hmTier2AllSongs];
      }
      else return [...window._hmTier1AllSongs, ...window._hmTier2AllSongs, ...window._hmTier3AllSongs];
    }

    function renderSongPage() {
      const tierSongs = getActiveTierSongs();
      const page = window._hmConfidentPage;
      const slice = tierSongs.slice(0, (page + 1) * PAGE_SIZE);
      yourSongsEl.innerHTML = slice.map(renderSongCard).join('');

      // Remove old buttons
      const existingMore = document.getElementById('hm-show-more');
      const existingTierOld = document.getElementById('hm-tier-buttons');
      const existingTierNav = document.getElementById('hm-tier-nav');
      if (existingMore) existingMore.remove();
      if (existingTierOld) existingTierOld.remove();
      if (existingTierNav) existingTierNav.remove();

      // Show tier navigation buttons (side-by-side)
      if (slice.length < tierSongs.length || window._hmActiveTier < 3) {
        const tierDiv = document.createElement('div');
        tierDiv.id = 'hm-tier-nav';
        tierDiv.style.cssText = 'display:flex;gap:8px;margin:16px auto 0;max-width:400px;flex-wrap:wrap;justify-content:center;';

        // "Load 10 More" if more in current tier
        if (slice.length < tierSongs.length) {
          const remaining = tierSongs.length - slice.length;
          const btn = document.createElement('button');
          btn.textContent = `Load ${Math.min(PAGE_SIZE, remaining)} More`;
          btn.style.cssText = 'flex:1;min-width:140px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.7);border-radius:10px;padding:12px 20px;font-size:0.85rem;font-weight:700;cursor:pointer;font-family:inherit;';
          btn.onclick = () => { window._hmConfidentPage++; renderSongPage(); setTimeout(restorePlaylistChecks, 50); };
          tierDiv.appendChild(btn);
        }

        // "Explore Deeper 🎵" tier button (from Tier 1 to Tier 2)
        if (window._hmActiveTier === 1) {
          const btn = document.createElement('button');
          const tier2Count = window._hmTier2Count || 0;
          const countText = tier2Count > 0 ? ` (${tier2Count} more)` : '';
          btn.textContent = `Explore Deeper 🎵${countText}`;
          btn.style.cssText = 'flex:1;min-width:140px;background:linear-gradient(135deg,#7c3aed,#db2777);color:#fff;border:none;border-radius:10px;padding:12px 20px;font-size:0.85rem;font-weight:700;cursor:pointer;font-family:inherit;';
          btn.onclick = () => { window._hmActiveTier = 2; window._hmConfidentPage = Math.floor(TIER_1_LIMIT / PAGE_SIZE); renderSongPage(); setTimeout(restorePlaylistChecks, 50); };
          tierDiv.appendChild(btn);
        } else if (window._hmActiveTier === 2) {
          const btn = document.createElement('button');
          const tier3Count = window._hmTier3Count || 0;
          const countText = tier3Count > 0 ? ` (${tier3Count} more)` : '';
          btn.textContent = `Dig Even Deeper 🎶${countText}`;
          btn.style.cssText = 'flex:1;min-width:140px;background:linear-gradient(135deg,#7c3aed,#db2777);color:#fff;border:none;border-radius:10px;padding:12px 20px;font-size:0.85rem;font-weight:700;cursor:pointer;font-family:inherit;';
          btn.onclick = () => { window._hmActiveTier = 3; window._hmConfidentPage = Math.floor(TIER_2_LIMIT / PAGE_SIZE); renderSongPage(); setTimeout(restorePlaylistChecks, 50); };
          tierDiv.appendChild(btn);
        }

        yourSongsEl.after(tierDiv);
      }

    }
    renderSongPage();
    window._hmRenderSongPage = renderSongPage;
    setTimeout(restorePlaylistChecks, 50);
  }
  // Store full confident list for language filter re-pagination
  window._hmConfidentAllFull = confidentSongs.filter ? confidentSongs.filter(s => s.tier.key !== 'stretch') : [];

  // Render stretch section
  const stretchEl = document.getElementById('stretch-songs');
  const stretchSec = document.getElementById('stretch-section');
  if (stretchSongs.length > 0) {
    stretchEl.innerHTML = stretchSongs.map(renderSongCard).join('');
    stretchSec.style.display = 'block';
  } else {
    stretchSec.style.display = 'none';
  }

  const topScore = confidentSongs[0] ? Math.round((confidentSongs[0].score || 0) * 100) : 0;
  hmTrack('results_view', { voice_type: voiceType, score: topScore });

  // State-based CTA logic
  const isLoggedIn = typeof hmGetCurrentUser === 'function' && hmGetCurrentUser();
  const isPremium = isLoggedIn && (hmGetCurrentUser().is_premium || false);

  // Show appropriate CTA stack
  const ctaLoggedOut = document.getElementById('cta-logged-out');
  const ctaLoggedIn = document.getElementById('cta-logged-in');
  const premiumSoftSell = document.getElementById('premium-soft-sell');
  const exportFallback = document.querySelectorAll('.export-btn-fallback');

  if (!isLoggedIn) {
    // LOGGED-OUT: Create Account > Share > Challenge
    ctaLoggedOut.style.display = 'block';
    ctaLoggedIn.style.display = 'none';
    premiumSoftSell.style.display = 'block'; // Show premium soft-sell
    exportFallback.forEach(btn => btn.style.display = 'inline-block'); // Show export as fallback
  } else if (!isPremium) {
    // LOGGED-IN FREE: Save/Export > Try SquadMatch > Share
    ctaLoggedOut.style.display = 'none';
    ctaLoggedIn.style.display = 'block';
    premiumSoftSell.style.display = 'block'; // Show premium upsell
    exportFallback.forEach(btn => btn.style.display = 'none');
  } else {
    // PREMIUM: Save/Export > Try SquadMatch > Share
    ctaLoggedOut.style.display = 'none';
    ctaLoggedIn.style.display = 'block';
    premiumSoftSell.style.display = 'none'; // Hide premium upsell
    exportFallback.forEach(btn => btn.style.display = 'none');
  }

  showScreen('screen-results');
  // Show SquadMatch prompt (if not already dismissed)
  try {
    if (!localStorage.getItem('hm_squad_prompt_dismissed')) {
      const sqEl = document.getElementById('squad-results-prompt');
      if (sqEl) sqEl.style.display = 'block';
    }
  } catch(e) {}
  // Restore saved language filter (default to English for new users)
  const savedLangFilter = (() => { try { return localStorage.getItem('hm_lang_filter'); } catch(e) { return null; } })();
  const langToApply = (savedLangFilter && ['en','es','all'].includes(savedLangFilter)) ? savedLangFilter : 'en';
  const langChip = document.querySelector(`.filter-chip[data-filter="${langToApply}"]`);
  if (langChip) setTimeout(() => setFilter(langToApply, langChip), 50);
  saveProfile();
  checkSavedProfile(); // refresh welcome screen button
  setTimeout(() => { restorePlaylistChecks(); updateExportCount(); }, 100);
  // Show login prompt after first hum + update account badge
  if (typeof hmMaybeShowLoginPrompt === 'function') hmMaybeShowLoginPrompt();
  if (typeof hmUpdateAccountBadge === 'function') hmUpdateAccountBadge();
  // Show A2HS banner after first successful result
  setTimeout(() => showA2HSBanner('results-banner'), 800);
  } catch (err) {
    console.error('[ERROR] showResults crashed:', err);
    alert('Error loading results: ' + err.message + '. Please refresh and try again.');
    showScreen('screen-welcome');
  }
}

const YT_KEY = 'AIzaSyBCLnGsgv3Ocimiu5jlB7lwwn27t_EiWPY'; // restricted to hummatch.me only in GCP console

// ── Filter bar logic ──────────────────────────────────────────────────────────
function setFilter(filter, el) {
  // Update chip styles
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  if (el) el.classList.add('active');

  const songs = document.querySelectorAll('#your-songs .song-item');
  const titleEl = document.getElementById('songs-section-title');
  const titles = {
    all:      'SONGS YOU CAN CONFIDENTLY SING',
    nail:     '✅ SONGS YOU CAN NAIL',
    car:      '🚗 SONGS TO DOMINATE THE CAR',
    solo:     '🎧 SONGS FOR WHEN IT\'S JUST YOU',
    group:    '👯 SONGS TO KILL IT AT KARAOKE',
    familiar: '⭐ SONGS YOU LIKELY KNOW',
    pop:      '🎤 POP MATCHES',
    rock:     '🎸 ROCK MATCHES',
    country:  '🤠 COUNTRY MATCHES',
    classic:  '🕰 CLASSIC MATCHES',
    party:    '🎉 CROWD PLEASER MATCHES',
    stretch:  '💪 STRETCH SONGS',
    recent:   '🔥 RECENT SONGS YOU CAN NAIL',
    '90s':    '📼 90s SONGS IN YOUR RANGE',
    '80s':    '🕹 80s SONGS IN YOUR RANGE',
    en:       '🇺🇸 ENGLISH SONGS IN YOUR RANGE',
    es:       '🇪🇸 CANCIONES EN TU RANGO'
  };
  if (titleEl) titleEl.textContent = titles[filter] || 'YOUR SONGS';
  try { localStorage.setItem('hm_lang_filter', filter); } catch(e) {}

  // Show/hide stretch section
  const stretchSec = document.getElementById('stretch-section');
  if (filter === 'stretch') {
    // Move stretch songs into main list temporarily
    const stretchEl = document.getElementById('stretch-songs');
    const mainEl = document.getElementById('your-songs');
    if (stretchEl && mainEl) mainEl.innerHTML = stretchEl.innerHTML;
    if (stretchSec) stretchSec.style.display = 'none';
    window._hmInStretch = true;
    const existing = document.getElementById('hm-show-more');
    if (existing) existing.remove();
    return;
  }

  // Restore from stretch: re-paginate using the proper render function
  if (window._hmInStretch) {
    window._hmInStretch = false;
    const full = window._hmConfidentAllFull || (window._hmSongs || []).filter(s => s.tier.key !== 'stretch');
    window._hmConfidentAll = full;
    window._hmConfidentAllFull = full;
    window._hmConfidentPage = 0;
    if (window._hmRenderSongPage) { window._hmRenderSongPage(); setTimeout(restorePlaylistChecks, 50); }
    if (window._hmStretch && window._hmStretch.length && stretchSec) stretchSec.style.display = 'block';
  }

  // Language filters: re-paginate from full dataset so all pages are filtered
  if (filter === 'en' || filter === 'es') {
    const all = window._hmConfidentAllFull || window._hmConfidentAll || [];
    if (!window._hmConfidentAllFull) window._hmConfidentAllFull = all.slice();
    const filtered = all.filter(s => {
      const slang = s.lang || 'en';
      const stags = s.tags || [];
      if (filter === 'en') return slang !== 'es' && !stags.includes('latin');
      return slang === 'es' || stags.includes('latin');
    });
    window._hmConfidentAll = filtered;
    window._hmConfidentPage = 0;
    if (window._hmRenderSongPage) { window._hmRenderSongPage(); setTimeout(restorePlaylistChecks, 50); }
    return;
  }

  // Non-language filter after language filter: restore full list
  if (window._hmConfidentAllFull && window._hmConfidentAll !== window._hmConfidentAllFull) {
    window._hmConfidentAll = window._hmConfidentAllFull.slice();
    window._hmConfidentPage = 0;
    if (window._hmRenderSongPage) { window._hmRenderSongPage(); setTimeout(restorePlaylistChecks, 50); }
  }

  // Apply show/hide filter to visible songs
  document.querySelectorAll('#your-songs .song-item').forEach(item => {
    const tier  = item.dataset.tier || '';
    const tags  = (item.dataset.tags || '').split(',');
    const fam   = item.dataset.familiar === 'true';
    const era   = item.dataset.era  || '';
    const lang  = item.dataset.lang || 'en';
    let show = false;
    if (filter === 'all')       show = true;
    else if (filter === 'nail')     show = tier === 'nail';
    else if (filter === 'familiar') show = fam;
    else if (filter === 'car')      show = tags.includes('car');
    else if (filter === 'solo')     show = tags.includes('solo');
    else if (filter === 'group')    show = tags.includes('group');
    else if (filter === 'pop')      show = tags.includes('pop');
    else if (filter === 'rock')     show = tags.includes('rock');
    else if (filter === 'country')  show = tags.includes('country');
    else if (filter === 'classic')  show = tags.includes('classic');
    else if (filter === 'party')    show = tags.includes('party');
    else if (filter === 'recent')   show = era === 'recent' || era === '2000s';
    else if (filter === '90s')      show = era === '90s';
    else if (filter === '80s')      show = era === '80s';
    else if (filter === 'en')       show = lang !== 'es' && !(item.dataset.tags && item.dataset.tags.includes('latin'));
    else if (filter === 'es')       show = lang === 'es' || (item.dataset.tags && item.dataset.tags.includes('latin'));
    item.style.display = show ? '' : 'none';
  });
}

// ── Dismiss song ("Don't know it") → replace with next best from pool ────────
function dismissSong(songKey, btn) {
  const parts = songKey.split('__');
  hmTrack("song_dismissed", { title: parts[0] || songKey, artist: parts[1] || "" });
  const li = document.getElementById('song-' + songKey);
  if (!li) return;

  // Mark dismissed + persist to localStorage
  window._hmDismissed = window._hmDismissed || new Set();
  window._hmDismissed.add(songKey);
  localStorage.setItem('hm_dismissed', JSON.stringify([...window._hmDismissed]));

  // Animate out
  li.style.transition = 'opacity 0.2s, transform 0.2s';
  li.style.opacity = '0';
  li.style.transform = 'translateX(30px)';

  setTimeout(() => {
    li.remove();
    // Find next undismissed, unshown song from full pool
    const shown = new Set(
      Array.from(document.querySelectorAll('#your-songs .song-item, #stretch-songs .song-item'))
        .map(el => el.id.replace('song-',''))
    );
    const pool = window._hmFullPool || [];
    const next = pool.find(s => {
      const k = (s.title + '__' + s.artist).replace(/['"]/g,'');
      return !window._hmDismissed.has(k) && !shown.has(k);
    });

    if (next) {
      // Re-tag + tier the replacement
      next.tags = next.tags || getTags ? getTags(next) : [];
      next.tier = next.tier || (next.score >= 0.78 ? {key:'nail',label:'✅ Nail It',cls:'tier-nail'} : next.score >= 0.60 ? {key:'strong',label:'🎯 Strong Fit',cls:'tier-strong'} : {key:'stretch',label:'💪 Stretch',cls:'tier-stretch'});
      next.familiar = next.familiar !== undefined ? next.familiar : false;
      const html = renderSongCard(next);
      const container = document.getElementById('your-songs');
      if (container) {
        const tmp = document.createElement('ul');
        tmp.innerHTML = html;
        const newLi = tmp.firstElementChild;
        newLi.style.opacity = '0';
        newLi.style.transform = 'translateX(-20px)';
        container.appendChild(newLi);
        requestAnimationFrame(() => {
          newLi.style.transition = 'opacity 0.25s, transform 0.25s';
          newLi.style.opacity = '1';
          newLi.style.transform = 'translateX(0)';
        });
      }
    }
  }, 200);
}
// ─────────────────────────────────────────────────────────────────────────────

function toggleStretch() {
  const stretchEl = document.getElementById('stretch-songs');
  const btn = document.querySelector('.stretch-toggle');
  if (!stretchEl) return;
  const open = stretchEl.style.display !== 'none';
  stretchEl.style.display = open ? 'none' : 'flex';
  stretchEl.style.flexDirection = 'column';
  if (btn) btn.textContent = open
    ? '💪 Show stretch songs, great with a small key change'
    : '💪 Hide stretch songs';
}
// ─────────────────────────────────────────────────────────────────────────────

// ── PERSISTENT PLAYLIST ──────────────────────────────────────────────────────
const HM_PLAYLIST_KEY = 'hm_playlist';

function loadPlaylist() {
  try { return JSON.parse(localStorage.getItem(HM_PLAYLIST_KEY) || '[]'); } catch(e) { return []; }
}

function savePlaylist(list) {
  const isPremium = localStorage.getItem('hm_premium') === 'true';
  // Free users: cap at 20 saved songs
  const capped = isPremium ? list : list.slice(0, 20);
  localStorage.setItem(HM_PLAYLIST_KEY, JSON.stringify(capped));
}

function togglePlaylistSong(title, artist, checked) {
  let list = loadPlaylist();
  const key = title + '__' + artist;
  const isPremium = localStorage.getItem('hm_premium') === 'true';

  if (checked) {
    if (!list.find(s => s.title === title && s.artist === artist)) {
      // Check playlist limit for free users
      if (!isPremium && list.length >= 20) {
        // Show upgrade prompt
        showToast('🎶 Nice playlist! Want to export it?');
        // Show upgrade modal
        setTimeout(() => {
          if (confirm('🎵 Export Your Playlist?\n\n20 songs ready! Upgrade to export to Spotify/Apple Music:\n\n✓ Unlimited playlist exports\n✓ Unlimited saved songs\n✓ Create singing squads\n✓ Share with friends\n\nOnly $7.99/mo (14-day free trial)')) {
            window.location.href = '/pricing';
          }
        }, 500);
        // Uncheck the checkbox
        const checkbox = document.querySelector(`input[data-title="${title.replace(/"/g,'&quot;')}"][data-artist="${artist.replace(/"/g,'&quot;')}"]`);
        if (checkbox) checkbox.checked = false;
        return;
      }
      list.push({ title, artist });
    }
  } else {
    list = list.filter(s => !(s.title === title && s.artist === artist));
  }
  savePlaylist(list);
  updateExportCount();
  if (typeof hmSyncCounts === 'function') hmSyncCounts();
}

function restorePlaylistChecks() {
  const list = loadPlaylist();
  if (!list.length) return;
  const keys = new Set(list.map(s => s.title + '__' + s.artist));
  document.querySelectorAll('.hm-song-check').forEach(cb => {
    const k = cb.dataset.title + '__' + cb.dataset.artist;
    if (keys.has(k)) cb.checked = true;
  });
  updateExportCount();
}

function clearPlaylist() {
  localStorage.removeItem(HM_PLAYLIST_KEY);
  document.querySelectorAll('.hm-song-check').forEach(cb => cb.checked = false);
  updateExportCount();
  showToast('Playlist cleared');
}

function updateExportCount() {
  const label = document.getElementById('export-count-label');
  const clearRow = document.getElementById('playlist-clear-row');
  if (!label) return;
  const isPremium = localStorage.getItem('hm_premium') === 'true';
  const playlist = loadPlaylist();
  const total = playlist.length;
  if (total === 0) {
    label.textContent = '';
    if (clearRow) clearRow.style.display = 'none';
  } else {
    const cap = isPremium ? '' : total >= 10 ? ' · limit reached' : ` · ${10 - total} more free`;
    label.textContent = `${total} song${total !== 1 ? 's' : ''} in your playlist${cap}`;
    if (clearRow) clearRow.style.display = 'block';
  }
}

function exportSongList(mode) {
  // Check monthly export limit for free users
  const isPremiumExport = localStorage.getItem('hm_premium') === 'true';
  if (!isPremiumExport) {
    const monthKey = new Date().toISOString().slice(0,7);
    if (localStorage.getItem('hm_export_month') !== monthKey) {
      localStorage.setItem('hm_export_month', monthKey);
      localStorage.setItem('hm_export_count', '0');
    }
    const exportCount = parseInt(localStorage.getItem('hm_export_count') || '0');
    if (exportCount >= 20) {
      const isLoggedIn = !!localStorage.getItem('hm_token');
      showToast(isLoggedIn
        ? 'Export limit reached. Unlock Squad Leader for unlimited exports. ✨'
        : 'Export limit reached. Create a free account or unlock Squad Leader. ✨');
      return;
    }
    localStorage.setItem('hm_export_count', exportCount + 1);
    if (typeof hmSyncCounts === 'function') hmSyncCounts();
  }

  // Use saved playlist if populated, otherwise export full matched pool
  const playlist = loadPlaylist();
  const pool = playlist.length > 0 ? playlist : (window._hmConfidentAll || window._hmFullPool || []);
  if (!pool.length) { showToast('Hum first to get your song list!'); return; }

  if (mode === 'copy') {
    const text = pool.map((s, i) => `${i + 1}. ${s.title} by ${s.artist}`).join('\n');
    navigator.clipboard.writeText(text)
      .then(() => showToast('Song list copied! Paste in your music app, Notes, or anywhere 📋'))
      .catch(() => {
        // Fallback for browsers that block clipboard
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showToast('Song list copied! 📋');
      });
    hmTrack('export_copy', { count: pool.length });
  }

  if (mode === 'csv') {
    const header = 'Song,Artist,Match %\n';
    const rows = pool.map(s => `"${s.title.replace(/"/g,'""')}","${s.artist.replace(/"/g,'""')}","${Math.round((s.score||0)*100)}%"`).join('\n');
    const blob = new Blob([header + rows], { type: 'text/csv' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'my-hummatch-songs.csv';
    a.click();
    URL.revokeObjectURL(url);
    showToast('CSV downloaded. Open in Excel, Google Sheets, or your music app ⬇');
    hmTrack('export_csv', { count: pool.length });
  }
  // Show A2HS after playlist save action
  setTimeout(() => showA2HSBanner('results-banner'), 1200);
}


async function openKaraoke(title, artist) {
  hmTrack('song_click', { title, artist });
  hmTrack("song_sung", { title, artist });
  const modal = document.getElementById('karaoke-modal');
  document.getElementById('karaoke-title').textContent = title;
  document.getElementById('karaoke-artist').textContent = artist;
  modal.style.display = 'flex';

  const fallbackUrl = `https://www.youtube.com/results?search_query=${encodeURIComponent(title+' '+artist+' karaoke with lyrics')}`;
  document.getElementById('karaoke-yt-btn').onclick = () => window.open(fallbackUrl, '_blank');

  // Show loading state
  const frame = document.getElementById('karaoke-frame');
  const loading = document.getElementById('karaoke-loading');
  frame.style.display = 'none';
  loading.style.display = 'flex';
  document.getElementById('karaoke-yt-btn').textContent = '⏳ Finding track...';

  try {
    const q = encodeURIComponent(title + ' ' + artist + ' karaoke with lyrics');
    const res = await fetch(`https://www.googleapis.com/youtube/v3/search?part=snippet&q=${q}&type=video&maxResults=1&videoCategoryId=10&key=${YT_KEY}`);
    const data = await res.json();
    const videoId = data.items && data.items[0] && data.items[0].id.videoId;
    if (videoId) {
      frame.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&rel=0`;
      frame.style.display = 'block';
      loading.style.display = 'none';
      document.getElementById('karaoke-yt-btn').textContent = '↗ Open in YouTube';
      document.getElementById('karaoke-yt-btn').onclick = () => window.open(`https://www.youtube.com/watch?v=${videoId}`, '_blank');
    } else {
      throw new Error('no results');
    }
  } catch(e) {
    // Fallback, open YouTube directly
    loading.innerHTML = `<div style="font-size:1.5rem;margin-bottom:12px;">🎤</div><div style="font-size:0.85rem;color:rgba(255,255,255,0.5);">Tap below to open on YouTube</div>`;
    document.getElementById('karaoke-yt-btn').textContent = '▶ Now Sing It';
    document.getElementById('karaoke-yt-btn').onclick = () => window.open(fallbackUrl, '_blank');
  }
}

function closeKaraoke() {
  document.getElementById('karaoke-modal').style.display = 'none';
  const frame = document.getElementById('karaoke-frame');
  frame.src = '';
  frame.style.display = 'none';
  document.getElementById('karaoke-loading').style.display = 'flex';
}

// ── VOICE PROFILE PERSISTENCE ──
function saveProfile() {
  const profile = {
    notes: capturedNotes,
    brightness: capturedBrightness,
    savedAt: Date.now(),
    version: 2 // Increment when matching algorithm changes
  };
  try { localStorage.setItem('hummatch_profile', JSON.stringify(profile)); } catch(e) {}
}

function loadSavedProfile() {
  try {
    const raw = localStorage.getItem('hummatch_profile');
    if (!raw) return false;
    const p = JSON.parse(raw);

    // Invalidate profiles from before gender filtering fixes (version 2)
    if (!p.version || p.version < 2) {
      console.log('Old profile detected, clearing...');
      localStorage.removeItem('hummatch_profile');
      return false;
    }

    // Load saved notes and re-run matching algorithm
    // This ensures users get latest algorithm improvements + new songs
    capturedNotes = p.notes || [null, null, null];
    capturedBrightness = p.brightness || [null, null, null];
    showResults(); // Re-run algorithm with current song catalog
    return true;
  } catch(e) { return false; }
}

function checkSavedProfile() {
  try {
    const raw = localStorage.getItem('hummatch_profile');
    if (!raw) return;
    const p = JSON.parse(raw);
    const days = Math.floor((Date.now() - p.savedAt) / 86400000);
    const btn = document.getElementById('saved-profile-btn');
    const lbl = document.getElementById('saved-profile-date');
    if (btn) btn.style.display = 'block';
    if (lbl) lbl.textContent = days === 0 ? 'Saved today' : `Saved ${days} day${days !== 1 ? 's' : ''} ago`;
  } catch(e) {}
}

// PWA install prompt, shown at high-intent moments only
let deferredInstallPrompt = null;
const _a2hsInstalled = window.navigator.standalone || window.matchMedia('(display-mode: standalone)').matches;
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredInstallPrompt = e;
});
window.addEventListener('appinstalled', () => {
  hmTrack("pwa_install");
  deferredInstallPrompt = null;
  document.querySelectorAll('[id^="a2hs-"]').forEach(el => el.style.display = 'none');
});
// Standalone detection, fires on first launch after Add to Home Screen (any browser)
if (_a2hsInstalled) {
  if (!localStorage.getItem('hm_pwa_tracked')) {
    localStorage.setItem('hm_pwa_tracked', '1');
    hmTrack('pwa_install');
  }
}
function _a2hsCanShow(key) {
  if (_a2hsInstalled) return false;
  if (localStorage.getItem('hm_a2hs_dismiss_' + key)) return false;
  return true;
}
function showA2HSBanner(key) {
  if (!_a2hsCanShow(key)) return;
  // On iOS, beforeinstallprompt doesn't fire but we still show the banner
  const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
  if (!deferredInstallPrompt && !isIOS) return;
  const el = document.getElementById('a2hs-' + key);
  if (el) el.style.display = 'block';
}
function dismissA2HS(key) {
  localStorage.setItem('hm_a2hs_dismiss_' + key, '1');
  const el = document.getElementById('a2hs-' + key);
  if (el) el.style.display = 'none';
}
function installHumMatch() {
  hmTrack("a2hs_tap");
  if (deferredInstallPrompt) {
    deferredInstallPrompt.prompt();
    deferredInstallPrompt.userChoice.then(() => { deferredInstallPrompt = null; });
  } else if (/iphone|ipad|ipod/i.test(navigator.userAgent) && !window.navigator.standalone) {
    alert('Tap the Share button ⬆ at the bottom of Safari, then tap "Add to Home Screen" to save HumMatch.');
  } else if (window.navigator.standalone) {
    alert('HumMatch is already on your home screen! ✅');
  } else {
    alert('To save HumMatch: in Chrome tap the menu (⋮) and choose "Add to Home Screen".');
  }
}


// Capture affiliate ref from URL and store
(function() {
  const ref = new URLSearchParams(window.location.search).get('ref');
  if (ref) localStorage.setItem('hm_ref', ref);
})();

// Load songs from API, fall back to inline SONGS array
let SONGS_LOADED = false;
async function loadSongs() {
  // Use hardcoded JS array as authoritative source. DB endpoint is for admin management only
  // This prevents duplicates from DB + inline array merging
  SONGS_LOADED = true;
  hmTrack("page_view");
}

// ── SESSION TIME TRACKING ──────────────────────────────────
const _sessionStart = Date.now();
function _trackSessionEnd() {
  const duration = Math.round((Date.now() - _sessionStart) / 1000);
  if (duration < 3) return; // ignore bounces under 3 seconds
  if (duration > 1800) return; // ignore sessions over 30 min (open tab, analytics dashboard, etc.)
  hmTrack('session_end', { duration_sec: duration });
}
document.addEventListener('visibilitychange', () => {
  if (document.visibilityState === 'hidden') _trackSessionEnd();
});
window.addEventListener('beforeunload', _trackSessionEnd);

// Run on page load
window.addEventListener('DOMContentLoaded', async () => {
  await loadSongs();
  checkSavedProfile();
  checkReturningUser();
});

// Check if returning user and show homepage upgrade CTA
function checkReturningUser() {
  try {
    const isReturningUser = localStorage.getItem('hummatch_visited') === 'true';
    const isLoggedIn = typeof hmGetCurrentUser === 'function' && hmGetCurrentUser();
    const isPremium = isLoggedIn && (hmGetCurrentUser().is_premium || false);

    // Show upgrade CTA if: returning + not premium
    if (isReturningUser && !isPremium) {
      const upgradeEl = document.getElementById('homepage-returning-upgrade');
      if (upgradeEl) upgradeEl.style.display = 'block';
    }

    // Mark as visited for next time
    if (!isReturningUser) {
      localStorage.setItem('hummatch_visited', 'true');
    }
  } catch(e) {
    console.log('checkReturningUser error:', e);
  }
}

function resetTest() {
  phase = 0;
  capturedNotes = [null, null, null];
  capturedBrightness = [null, null, null];
  document.getElementById('low-note').textContent = '-';
  document.getElementById('mid-note').textContent = '-';
  document.getElementById('high-note').textContent = '-';
  document.getElementById('pitch-note').textContent = '-';
  document.getElementById('pitch-hz').textContent = '';
  document.getElementById('pitch-bar').style.width = '0%';
  resetRing();
  // Re-test doesn't count against the free hum limit, it's the same session
  const prev = parseInt(localStorage.getItem('hm_hum_count') || '0');
  if (prev > 0) localStorage.setItem('hm_hum_count', prev - 1);
  // Go straight to primer (skip limit check, already passed)
  showScreen('screen-primer');
}

// ── SHARE FUNCTIONS ──────────────────────────────────────────────
function buildShareCard() {
  const canvas = document.getElementById('share-canvas');
  // Landscape 1200x630 @ 2x for crispness
  const SCALE = 2;
  const W = 1200, H = 630;
  canvas.width  = W * SCALE;
  canvas.height = H * SCALE;
  canvas.style.width  = W + 'px';
  canvas.style.height = H + 'px';
  const ctx = canvas.getContext('2d');
  ctx.scale(SCALE, SCALE);

  // ── Background ──
  const bg = ctx.createLinearGradient(0, 0, W, H);
  bg.addColorStop(0, '#0a0614');
  bg.addColorStop(0.5, '#130a22');
  bg.addColorStop(1, '#0d0618');
  ctx.fillStyle = bg;
  ctx.fillRect(0, 0, W, H);

  // Left glow
  const glowL = ctx.createRadialGradient(320, H/2, 0, 320, H/2, 280);
  glowL.addColorStop(0, 'rgba(168,85,247,0.28)');
  glowL.addColorStop(1, 'rgba(168,85,247,0)');
  ctx.fillStyle = glowL;
  ctx.fillRect(0, 0, W, H);

  // Right glow
  const glowR = ctx.createRadialGradient(W - 260, H/2, 0, W - 260, H/2, 220);
  glowR.addColorStop(0, 'rgba(236,72,153,0.18)');
  glowR.addColorStop(1, 'rgba(236,72,153,0)');
  ctx.fillStyle = glowR;
  ctx.fillRect(0, 0, W, H);

  // Subtle grid lines for depth
  ctx.strokeStyle = 'rgba(168,85,247,0.06)';
  ctx.lineWidth = 1;
  for (let x = 0; x < W; x += 60) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();
  }
  for (let y = 0; y < H; y += 60) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
  }

  // ── LEFT PANEL: Artist result ──────────────────────────────────
  const LX = 320; // center of left panel

  // Mic emoji large
  ctx.font = '110px serif';
  ctx.textAlign = 'center';
  ctx.fillText('🎤', LX, 170);

  // Label
  ctx.font = '600 18px Arial, sans-serif';
  ctx.fillStyle = 'rgba(192,132,252,0.75)';
  ctx.fillText('MY TOP HUMMATCH SONG', LX, 230);

  // Song title, big, white, bold
  ctx.fillStyle = '#ffffff';
  const songTitle = shareTopSong ? shareTopSong.title : shareArtistName;
  const displayTitle = songTitle.length > 20 ? songTitle.substring(0, 20) + '...' : songTitle;
  const titleWords = displayTitle.split(' ');
  if (displayTitle.length > 14) {
    const half = Math.ceil(titleWords.length / 2);
    const l1 = titleWords.slice(0, half).join(' ').toUpperCase();
    const l2 = titleWords.slice(half).join(' ').toUpperCase();
    ctx.font = 'bold 52px Arial, sans-serif';
    ctx.fillText(l1, LX, 300);
    ctx.fillText(l2, LX, 360);
  } else {
    ctx.font = 'bold 58px Arial, sans-serif';
    ctx.fillText(displayTitle.toUpperCase(), LX, 330);
  }

  // Artist name, smaller, below song title
  if (shareTopSong) {
    ctx.font = '500 26px Arial, sans-serif';
    ctx.fillStyle = 'rgba(192,132,252,0.85)';
    const artistY = displayTitle.length > 14 ? 400 : 370;
    ctx.fillText(shareTopSong.artist, LX, artistY);
  }

  // Voice type + match pill
  const pillTxt = `${shareVoiceType}  ·  ${shareMatchPct}% Match`;
  ctx.font = '600 20px Arial, sans-serif';
  const pillW = ctx.measureText(pillTxt).width + 48;
  const pillX = LX - pillW/2;
  const pillY = displayTitle.length > 14 ? 425 : 400;
  ctx.fillStyle = 'rgba(168,85,247,0.22)';
  ctx.strokeStyle = 'rgba(168,85,247,0.55)';
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.roundRect(pillX, pillY, pillW, 44, 22);
  ctx.fill(); ctx.stroke();
  ctx.fillStyle = '#c084fc';
  ctx.fillText(pillTxt, LX, pillY + 28);

  // ── VERTICAL DIVIDER ──
  const divX = 640;
  const grad = ctx.createLinearGradient(divX, 60, divX, H - 60);
  grad.addColorStop(0, 'rgba(168,85,247,0)');
  grad.addColorStop(0.3, 'rgba(168,85,247,0.4)');
  grad.addColorStop(0.7, 'rgba(236,72,153,0.4)');
  grad.addColorStop(1, 'rgba(236,72,153,0)');
  ctx.strokeStyle = grad;
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(divX, 60); ctx.lineTo(divX, H - 60);
  ctx.stroke();

  // ── RIGHT PANEL: CTA ───────────────────────────────────────────
  const RX = divX + (W - divX) / 2; // center of right panel

  // HumMatch logo text
  const logoGrad = ctx.createLinearGradient(RX - 120, 0, RX + 120, 0);
  logoGrad.addColorStop(0, '#A855F7');
  logoGrad.addColorStop(1, '#EC4899');
  ctx.font = 'bold 42px Arial, sans-serif';
  ctx.fillStyle = logoGrad;
  ctx.fillText('HumMatch', RX, 140);

  // Tagline
  ctx.font = '400 24px Arial, sans-serif';
  ctx.fillStyle = 'rgba(255,255,255,0.65)';
  ctx.fillText('What song matches', RX, 210);
  ctx.fillText('YOUR voice?', RX, 246);

  // Hum 3 notes CTA
  ctx.font = '500 20px Arial, sans-serif';
  ctx.fillStyle = 'rgba(192,132,252,0.8)';
  ctx.fillText('Hum 3 notes. Find out in 30 seconds.', RX, 308);

  // CTA button
  const btnW = 340, btnH = 62, btnX = RX - btnW/2, btnY = 340;
  const btnGrad = ctx.createLinearGradient(btnX, 0, btnX + btnW, 0);
  btnGrad.addColorStop(0, '#7C3AED');
  btnGrad.addColorStop(1, '#A855F7');
  ctx.fillStyle = btnGrad;
  ctx.beginPath();
  ctx.roundRect(btnX, btnY, btnW, btnH, 31);
  ctx.fill();
  ctx.font = 'bold 24px Arial, sans-serif';
  ctx.fillStyle = '#ffffff';
  ctx.fillText('Try Free → hummatch.me', RX, btnY + 39);

  // Promo code
  ctx.font = '600 18px Arial, sans-serif';
  ctx.fillStyle = 'rgba(192,132,252,0.7)';
  // Upgrade text removed

  // Hashtag
  ctx.font = '500 18px Arial, sans-serif';
  ctx.fillStyle = 'rgba(168,85,247,0.5)';
  ctx.fillText('#HumMatchChallenge', RX, H - 50);

  // URL large at bottom right panel
  ctx.font = 'bold 22px Arial, sans-serif';
  ctx.fillStyle = 'rgba(168,85,247,0.9)';
  ctx.fillText('hummatch.me', RX, H - 22);

  return canvas;
}

async function shareHumMatch() {
  hmTrack("share_card");
  const canvas = buildShareCard();
  const songLabel = shareTopSong ? ('"' + shareTopSong.title + '" by ' + shareTopSong.artist) : shareArtistName;
  const shareText = 'My top HumMatch song is ' + songLabel + '! \uD83C\uDFA4 Hum 3 notes to find yours \u2192 hummatch.me #HumMatchChallenge';

  // Try Web Share API with image
  if (navigator.share && navigator.canShare) {
    try {
      const blob = await new Promise(res => canvas.toBlob(res, 'image/png'));
      const file = new File([blob], 'my-hummatch.png', { type: 'image/png' });
      if (navigator.canShare({ files: [file] })) {
        await navigator.share({ files: [file], text: shareText });
        return;
      }
    } catch(e) {}
  }
  // Fallback: Web Share without image
  if (navigator.share) {
    try {
      await navigator.share({ text: shareText, url: 'https://hummatch.me' });
      return;
    } catch(e) {}
  }
  // Fallback: save image + copy text
  const link = document.createElement('a');
  link.download = 'my-hummatch.png';
  link.href = canvas.toDataURL('image/png');
  link.click();
  try { await navigator.clipboard.writeText(shareText); } catch(e) {}
  showToast('Image saved! Text copied to clipboard 📋');
}

function challengeFriend() {
  hmTrack("challenge_tap");
  const songLabel = shareTopSong ? ('"' + shareTopSong.title + '" by ' + shareTopSong.artist) : shareArtistName;
  const text = 'My top HumMatch song is ' + songLabel + ' \uD83C\uDFA4 Bet you can match it. Try it \u2192 hummatch.me #HumMatchChallenge';
  if (navigator.share) {
    navigator.share({ text, url: 'https://hummatch.me' }).catch(() => copyChallenge(text));
  } else {
    copyChallenge(text);
  }
}

function copyChallenge(text) {
  navigator.clipboard.writeText(text).then(() => showToast('Challenge copied! Paste it anywhere 🎯')).catch(() => {});
}

function showToast(msg) {
  const t = document.createElement('div');
  t.textContent = msg;
  t.style.cssText = 'position:fixed;bottom:32px;left:50%;transform:translateX(-50%);background:#7c3aed;color:#fff;padding:12px 24px;border-radius:24px;font-size:0.85rem;font-weight:600;z-index:9999;white-space:nowrap;box-shadow:0 4px 20px rgba(124,58,237,0.5);';
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3000);
}
</script>
<script>
function toggleNav() {
  const tog = document.getElementById('navToggle');
  const drw = document.getElementById('navDrawer');
  const ovl = document.getElementById('navOverlay');
  tog.classList.toggle('open');
  drw.classList.toggle('open');
  ovl.classList.toggle('open');
}
function closeNav() {
  document.getElementById('navToggle').classList.remove('open');
  document.getElementById('navDrawer').classList.remove('open');
  document.getElementById('navOverlay').classList.remove('open');
}
// Swap Log In / Sign Up → My HQ if logged in
(function(){
  var t = localStorage.getItem('hm_dash_token') || localStorage.getItem('hm_token');
  if(t){
    var nav = document.getElementById('navLoginItem');
    var foot = document.getElementById('footerLoginItem');
    var signup = document.getElementById('navSignupItem');
    if(nav){ nav.textContent='🎯 My HQ'; nav.href='/dashboard'; }
    if(foot){ foot.textContent='My HQ'; foot.href='/dashboard'; }
    if(signup){ signup.style.display='none'; }
  }
})();

// ── Squad context detection (when joining via ?squad=X&member=Y) ────────────
(function() {
  var p = new URLSearchParams(location.search);
  var sqId  = p.get('squad');
  var sqMid = p.get('member');
  if (sqId && sqMid) {
    var banner = document.getElementById('squad-context-banner');
    if (banner) banner.style.display = 'block';
    // Fetch squad name to personalise the banner
    fetch('/api/hummatch/squad/' + sqId + '/status')
      .then(function(r){ return r.json(); })
      .then(function(d){
        var txt = document.getElementById('squad-banner-text');
        if (txt && d.squad_name) txt.textContent = "You're humming for " + d.squad_name;
      }).catch(function(){});
    // Store member id for post-hum submission
    try { localStorage.setItem('hm_squad_member_' + sqId, sqMid); } catch(_) {}
  }
})();

// ── SquadMatch post-hum prompt functions ────────────────────────────────────
function startSquadMatch() {
  // Songs should already be in localStorage from the hum session
  // If not logged in, redirect to signup with squad intent
  var t = localStorage.getItem('hm_dash_token') || localStorage.getItem('hm_token');
  if (!t) {
    localStorage.setItem('hm_squad_pending_create', '1');
    window.location = '/squadmatch?create=1';
    return;
  }
  window.location = '/squadmatch?create=1';
}

function dismissSquadPrompt() {
  var el = document.getElementById('squad-prompt-module');
  if (el) { el.style.opacity = '0'; setTimeout(function(){ el.style.display = 'none'; }, 250); }
  try { sessionStorage.setItem('hm_squad_dismissed', '1'); } catch(_) {}
}

// ── My HQ Squads loader ─────────────────────────────────────────────────────
(function() {
  var t = localStorage.getItem('hm_dash_token') || localStorage.getItem('hm_token');
  if (!t) return;
  fetch('/api/hummatch/squad', { headers: { 'X-HM-Token': t } })
    .then(function(r){ return r.json(); })
    .then(function(d){
      if (!d.squads || !d.squads.length) return;
      var el = document.getElementById('my-hq-squads');
      var list = document.getElementById('my-squads-list');
      if (!el || !list) return;
      var html = d.squads.slice(0, 3).map(function(sq) {
        var members = sq.members || [];
        var done = members.filter(function(m){ return m.hum_done; }).length;
        var statusText = sq.status === 'complete' ? '✓ Complete' : (done + '/' + members.length + ' hummed');
        var statusColor = sq.status === 'complete' ? '#4ade80' : '#a78bfa';
        return '<div style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.06)">' +
          '<div><div style="font-size:0.84rem;font-weight:700;color:#e2e0f0">' + (sq.squad_name || 'My Squad') + '</div>' +
          '<div style="font-size:0.72rem;color:rgba(255,255,255,0.38);margin-top:2px">' + members.length + ' member' + (members.length!==1?'s':'') + '</div></div>' +
          '<a href="/squadmatch?squad=' + sq.id + '" style="font-size:0.75rem;font-weight:700;color:' + statusColor + ';text-decoration:none;padding:5px 10px;background:rgba(255,255,255,0.04);border-radius:8px">' + statusText + '</a>' +
          '</div>';
      }).join('');
      list.innerHTML = html;
      el.style.display = 'block';
    }).catch(function(){});
})();
</script>

<!-- Signup Bottom Sheet -->
<div class="hm-login-sheet" id="hm-login-sheet">
  <h3>Save your matches</h3>
  <p>Create an account or log in to save your playlist.</p>
  <div style="display:flex;gap:10px;margin-top:16px;">
    <button onclick="window.location.href='/login?mode=signup'" style="flex:1;padding:14px;background:linear-gradient(135deg,#A855F7,#EC4899);border:none;border-radius:12px;color:#fff;font-size:0.9rem;font-weight:700;cursor:pointer;font-family:inherit;">Create Account</button>
    <button onclick="window.location.href='/login?return='+ encodeURIComponent(window.location.pathname)" style="flex:1;padding:14px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);border-radius:12px;color:#fff;font-size:0.9rem;font-weight:600;cursor:pointer;font-family:inherit;">Log In</button>
  </div>
  <button class="hm-login-dismiss" onclick="hmDismissLogin()" style="margin-top:12px;width:100%;padding:10px;background:transparent;border:1px solid rgba(255,255,255,0.1);border-radius:10px;color:rgba(255,255,255,0.5);font-size:0.85rem;font-weight:600;cursor:pointer;font-family:inherit;">Not now</button>
</div>

<script>
// ── HUMMATCH ACCOUNT SYSTEM ───────────────────────────────────────────────────
(function() {
  const TOKEN_KEY = 'hm_token';
  const EMAIL_KEY = 'hm_user_email';
  const DISMISS_KEY = 'hm_login_dismissed';
  const HAS_HUMMED_KEY = 'hm_has_hummed';

  // ── Get / set token ──
  window.hmGetToken = () => localStorage.getItem(TOKEN_KEY);
  window.hmGetEmail = () => localStorage.getItem(EMAIL_KEY);

  // ── Auth: register/login ──
  window.hmSubmitLogin = async function() {
    const input = document.getElementById('hm-login-email');
    const pwInput = document.getElementById('hm-login-password');
    const pwConfirm = document.getElementById('hm-login-password-confirm');
    const pwError = document.getElementById('hm-pw-error');
    const pwConfirmError = document.getElementById('hm-pw-confirm-error');
    const btn = document.getElementById('hm-login-submit');

    // Reset errors
    [input, pwInput, pwConfirm].forEach(el => el.style.borderColor = '');
    pwError.style.display = 'none';
    pwConfirmError.style.display = 'none';

    const email = (input.value || '').trim();
    const password = pwInput.value || '';
    const confirm = pwConfirm.value || '';

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      input.style.borderColor = '#ef4444';
      return;
    }
    if (password.length < 8) {
      pwInput.style.borderColor = '#ef4444';
      pwError.textContent = 'Password must be at least 8 characters';
      pwError.style.display = 'block';
      return;
    }
    if (password !== confirm) {
      pwConfirm.style.borderColor = '#ef4444';
      pwConfirmError.textContent = 'Passwords do not match';
      pwConfirmError.style.display = 'block';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Creating account...';
    try {
      const r = await fetch('/api/hummatch/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      });
      const data = await r.json();
      if (!r.ok) {
        showToast(data.error || 'Registration failed');
        btn.disabled = false;
        btn.textContent = 'Create Account';
        return;
      }
      if (data.token) {
        localStorage.setItem(TOKEN_KEY, data.token);
        localStorage.setItem('hm_dash_token', data.token);
        localStorage.setItem(EMAIL_KEY, data.email || email.toLowerCase());
        if (data.is_premium) localStorage.setItem('hm_premium', 'true');

        // Sync current playlist to server
        const playlist = loadPlaylist();
        const humCount = parseInt(localStorage.getItem('hm_hum_count') || '0');
        const exportCount = parseInt(localStorage.getItem('hm_export_count') || '0');
        await fetch('/api/hummatch/auth/sync', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: data.token, playlist, hum_count: humCount, export_count: exportCount })
        }).catch(() => {});

        hmHideLoginSheet();
        hmUpdateAccountBadge();

        // Retroactively save hum data if user signed up after humming
        if (window._pendingHumData) {
          const humCount = parseInt(localStorage.getItem('hm_hum_count') || '0');
          fetch('/api/hummatch/hum/session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-HM-Token': data.token },
            body: JSON.stringify({ ...window._pendingHumData, hum_count: humCount })
          }).catch(() => {});
          window._pendingHumData = null;
          // Show "saved" state in inline card
          const posthumContent = document.getElementById('hm-posthum-content');
          const posthumSaved = document.getElementById('hm-posthum-saved');
          const posthumCard = document.getElementById('hm-posthum-signup');
          if (posthumContent) posthumContent.style.display = 'none';
          if (posthumSaved) posthumSaved.style.display = 'block';
          if (posthumCard) posthumCard.style.display = 'block';
          showToast('Account created! Results saved.');
        } else {
          showToast('Account created! Playlist synced.');
        }

        hmTrack('account_register', { isNew: true });

        // Update nav links
        var nav = document.getElementById('navLoginItem');
        var foot = document.getElementById('footerLoginItem');
        var signupNav = document.getElementById('navSignupItem');
        if(nav){ nav.textContent='🎯 My HQ'; nav.href='/dashboard'; }
        if(foot){ foot.textContent='My HQ'; foot.href='/dashboard'; }
        if(signupNav){ signupNav.style.display='none'; }
      } else {
        showToast('Something went wrong. Try again.');
      }
    } catch(e) {
      showToast('Connection error. Try again.');
    }
    btn.disabled = false;
    btn.textContent = 'Create Account';
  };

  // ── Dismiss login for 7 days ──
  window.hmDismissLogin = function() {
    localStorage.setItem(DISMISS_KEY, Date.now().toString());
    hmHideLoginSheet();
  };

  function hmHideLoginSheet() {
    const sheet = document.getElementById('hm-login-sheet');
    if (sheet) sheet.classList.remove('show');
  }

  // ── Show inline signup prompt after hum results (once per session) ──
  window.hmMaybeShowLoginPrompt = function() {
    if (localStorage.getItem(TOKEN_KEY)) return; // already logged in
    if (sessionStorage.getItem('hm_signup_prompt_shown')) return; // already shown this session
    sessionStorage.setItem('hm_signup_prompt_shown', '1');
    const card = document.getElementById('hm-posthum-signup');
    if (card) card.style.display = 'block';
  };

  // ── Dismiss inline signup prompt ──
  window.hmDismissPosthumSignup = function() {
    const card = document.getElementById('hm-posthum-signup');
    if (card) card.style.display = 'none';
  };

  // ── Open signup sheet from inline prompt ──
  window.hmOpenSignupFromPrompt = function() {
    window._signupFromPrompt = true;
    const sheet = document.getElementById('hm-login-sheet');
    if (sheet) sheet.classList.add('show');
  };

  // ── Update account badge in results header ──
  window.hmUpdateAccountBadge = function() {
    const badge = document.getElementById('hm-account-badge');
    if (!badge) return;
    const email = localStorage.getItem(EMAIL_KEY);
    if (!email) { badge.style.display = 'none'; return; }
    const isPremium = localStorage.getItem('hm_premium') === 'true';
    const initial = email.charAt(0).toUpperCase();
    badge.innerHTML = `<span class="hm-account-dot ${isPremium ? 'premium' : 'free'}"></span> ${initial}`;
    badge.style.display = 'inline-flex';
  };

  // ── Show account info on badge tap ──
  window.hmShowAccountInfo = function() {
    const email = localStorage.getItem(EMAIL_KEY);
    const isPremium = localStorage.getItem('hm_premium') === 'true';
    if (!email) return;
    showToast(`${email} · ${isPremium ? 'Squad Leader' : 'Free'}`);
  };

  // ── Load user data on page load ──
  window.hmLoadAccount = async function() {
    const token = localStorage.getItem(TOKEN_KEY);
    if (!token) return;
    try {
      const r = await fetch(`/api/hummatch/auth/me?token=${encodeURIComponent(token)}`);
      if (!r.ok) {
        // Invalid token, clear it
        if (r.status === 404) {
          localStorage.removeItem(TOKEN_KEY);
          localStorage.removeItem(EMAIL_KEY);
        }
        return;
      }
      const data = await r.json();
      localStorage.setItem(EMAIL_KEY, data.email);
      if (data.is_premium) {
        localStorage.setItem('hm_premium', 'true');
      }
      // Sync server counts to localStorage
      localStorage.setItem('hm_hum_month', data.month_key);
      localStorage.setItem('hm_hum_count', String(data.hum_count));
      localStorage.setItem('hm_export_month', data.month_key);
      localStorage.setItem('hm_export_count', String(data.export_count));

      // Merge server playlist with local playlist (union, deduplicate)
      const serverPlaylist = data.playlist || [];
      const localPlaylist = loadPlaylist();
      const merged = [...localPlaylist];
      const localKeys = new Set(localPlaylist.map(s => s.title + '__' + s.artist));
      for (const s of serverPlaylist) {
        const k = s.title + '__' + s.artist;
        if (!localKeys.has(k)) {
          merged.push(s);
          localKeys.add(k);
        }
      }
      savePlaylist(merged);

      // If merged playlist differs from server, push back
      if (merged.length !== serverPlaylist.length) {
        fetch('/api/hummatch/auth/sync', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, playlist: merged })
        }).catch(() => {});
      }

      hmUpdateAccountBadge();
    } catch(e) { /* silent fail */ }
  };

  // ── Sync counts to server after hum or export ──
  window.hmSyncCounts = function() {
    const token = localStorage.getItem(TOKEN_KEY);
    if (!token) return;
    const humCount = parseInt(localStorage.getItem('hm_hum_count') || '0');
    const exportCount = parseInt(localStorage.getItem('hm_export_count') || '0');
    const playlist = loadPlaylist();
    fetch('/api/hummatch/auth/sync', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token, playlist, hum_count: humCount, export_count: exportCount })
    }).catch(() => {});
  };

  // Hook into page load
  const origDCL = window.addEventListener;
  document.addEventListener('DOMContentLoaded', () => {
    hmLoadAccount();
  });
})();

function startCheckout(plan) {
  plan = plan || 'monthly';
  const token = localStorage.getItem('hm_token') || localStorage.getItem('hm_dash_token');
  const url = '/api/hummatch/checkout/' + plan + (token ? '?token=' + token : '');
  window.location.href = url;
}
</script>
</body>
</html>
