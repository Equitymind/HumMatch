  <!-- PRIMARY CTA STACK (state-based: logged-out vs logged-in) -->
  <div id="results-cta-stack" style="width:100%;max-width:400px;margin-top:24px;">

    <!-- LOGGED-OUT PRIMARY CTAs -->
    <div id="cta-logged-out" style="display:none;">
      <div style="display:flex;gap:10px;margin-bottom:12px;">
