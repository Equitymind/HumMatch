<!-- KARAOKE MODAL -->
<div id="karaoke-modal" style="display:none;position:fixed;inset:0;z-index:2000;background:rgba(8,6,15,0.98);flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;text-align:center;">
  <button onclick="closeKaraoke()" style="position:absolute;top:20px;right:20px;background:rgba(255,255,255,0.1);border:none;color:#fff;width:38px;height:38px;border-radius:50%;font-size:1.1rem;cursor:pointer;">✕</button>
  <div style="flex:1;display:flex;flex-direction:column;width:100%;position:relative;">
    <!-- Loading state -->
    <div id="karaoke-loading" style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;z-index:1;">
      <div style="font-size:2.5rem;">🎤</div>
      <div style="font-size:0.85rem;color:rgba(255,255,255,0.5);">Finding your track...</div>
    </div>
    <!-- YouTube embed -->
    <iframe id="karaoke-frame" src="" frameborder="0"
      allow="autoplay; encrypted-media; picture-in-picture"
      allowfullscreen style="width:100%;flex:1;border:none;display:none;min-height:240px;border-radius:12px;"></iframe>
  </div>
  <div style="padding:12px 0 4px;text-align:center;flex-shrink:0;">
    <div style="font-size:1rem;font-weight:900;margin-bottom:2px;" id="karaoke-title">-</div>
