  <div class="hm-nav-divider"></div>
  <a class="hm-nav-item" href="/login?return=/" id="navLoginItem">Log In</a>
  <a class="hm-nav-item" href="/login?signup=1" id="navSignupItem" style="background:linear-gradient(135deg,#7c3aed,#db2777);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-weight:700;">Become a Hummer</a>
</nav>


<!-- Squad context banner (shown when joining squad via index.html) -->
<div id="squad-context-banner" style="display:none;background:linear-gradient(135deg,rgba(124,58,237,0.2),rgba(219,39,119,0.15));border-bottom:1px solid rgba(124,58,237,0.3);padding:10px 18px;text-align:center">
  <div style="font-size:0.82rem;color:#e2e0f0;font-weight:600" id="squad-banner-text">You're humming for a SquadMatch</div>
  <div style="font-size:0.72rem;color:rgba(255,255,255,0.48);margin-top:2px">Complete your hum - your results will be added to the squad</div>
</div>

<!-- SCREEN 1: WELCOME -->
<div id="screen-welcome" class="screen active">
  <div style="text-align:center;"><img src="/hummatch-logo.png" alt="HumMatch" style="height:100px;display:inline-block;"/></div>
  <div class="app-tagline" style="font-size:1.05rem;color:var(--text1);font-weight:800;max-width:300px;">Hum for 10 seconds. Find songs made for your voice.</div>
  <div style="font-size:0.78rem;color:var(--text3);max-width:280px;line-height:1.5;margin-bottom:10px;">No singing required. Just hum, we do the rest.</div>

  <div class="how-it-works">
    <div class="step">
      <div class="step-num">🎤</div>
      <div class="step-txt">Tap once and hum 3 notes (we walk you through it)</div>
    </div>
    <div class="step">
      <div class="step-num">🧬</div>
      <div class="step-txt">We map your vocal range and tone in real time</div>
    </div>
    <div class="step">
      <div class="step-num">🎯</div>
      <div class="step-txt">Get a list of songs you can actually nail</div>
    </div>
  </div>

  <!-- Genre filters removed - discovery through popularity tiers instead -->

  <div style="width:100%;max-width:340px;display:flex;flex-direction:column;align-items:center;">
  <button class="cta-btn" style="width:100%;margin-top:12px;" onclick="startTest()">Find My Songs →</button>
  <div id="saved-profile-btn" style="display:none;margin-top:12px;width:100%;max-width:300px;">
    <button class="cta-btn secondary" style="width:100%;" onclick="loadSavedProfile()">🎤 Use My Saved Voice</button>
    <div style="font-size:0.65rem;color:rgba(255,255,255,0.25);margin-top:6px;" id="saved-profile-date"></div>
  </div>

  </div><!-- /cta-wrapper -->

  <!-- SquadMatch Post-Hum Prompt (Screen 1) - MOVED ABOVE UPGRADE CTA -->
  <div id="squad-prompt-module" style="width:100%;max-width:380px;margin-top:16px;padding:0 4px;">
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(124,58,237,0.18);border-radius:14px;padding:24px 20px;position:relative;overflow:hidden;">
      <div style="position:absolute;top:-30px;right:-30px;width:110px;height:110px;background:radial-gradient(circle,rgba(168,85,247,0.14),transparent 70%);pointer-events:none;"></div>
      <div style="font-size:1.05rem;font-weight:800;color:#fff;line-height:1.3;margin-bottom:8px;">Start your SquadMatch</div>
      <div style="font-size:0.82rem;color:rgba(255,255,255,0.55);line-height:1.5;margin-bottom:18px;">Host the session and unlock songs your squad can sing together in harmony.</div>
      <div style="display:flex;gap:8px;margin-bottom:14px;">
        <button id="squad-start-btn" onclick="startSquadMatch()" style="flex:1;padding:11px 8px;background:linear-gradient(135deg,#A855F7,#EC4899);color:#fff;font-size:0.82rem;font-weight:700;border:none;border-radius:10px;cursor:pointer;letter-spacing:0.01em;">Start SquadMatch</button>
        <button onclick="dismissSquadPrompt()" style="flex:1;padding:11px 8px;background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.5);font-size:0.82rem;font-weight:600;border:1px solid rgba(255,255,255,0.1);border-radius:10px;cursor:pointer;">Maybe later</button>
      </div>
      <div style="font-size:0.72rem;color:rgba(255,255,255,0.35);text-align:center;line-height:1.5;">Invite up to 4 friends. Everyone hums once. We do the rest.<br><span style="font-size:0.68rem;margin-top:4px;display:inline-block;">Squad Leaders unlock harmonic group song matching, squad HQ, and exclusive discount codes.</span></div>
    </div>
  </div>

  <!-- RETURNING USER UPGRADE CTA (shown only for returning non-premium users) - MOVED BELOW SQUADMATCH -->
  <div id="homepage-returning-upgrade" style="display:none;margin-top:14px;width:100%;max-width:380px;padding:0 4px;">
    <div style="background:linear-gradient(135deg,rgba(168,85,247,0.08),rgba(236,72,153,0.06));border:1px solid rgba(168,85,247,0.25);border-radius:12px;padding:18px;text-align:left;">
      <div style="font-size:0.95rem;font-weight:800;color:#fff;margin-bottom:8px;">Lead your squad's next singalong</div>
      <div style="font-size:0.78rem;color:rgba(255,255,255,0.7);line-height:1.55;margin-bottom:10px;">
        Invite up to 4 friends and unlock shared song suggestions based on your group's range, timbre, and brightness.
      </div>
      <ul style="list-style:none;padding:0;margin:0 0 10px 0;text-align:left;">
        <li style="font-size:0.76rem;color:rgba(255,255,255,0.7);line-height:1.6;margin-bottom:4px;padding-left:18px;position:relative;"><span style="position:absolute;left:0;">•</span> Track who's hummed</li>
        <li style="font-size:0.76rem;color:rgba(255,255,255,0.7);line-height:1.6;margin-bottom:4px;padding-left:18px;position:relative;"><span style="position:absolute;left:0;">•</span> Save shared playlists in HQ</li>
        <li style="font-size:0.76rem;color:rgba(255,255,255,0.7);line-height:1.6;margin-bottom:10px;padding-left:18px;position:relative;"><span style="position:absolute;left:0;">•</span> Unlock harmonic-fit group song matching</li>
      </ul>
      <div style="font-size:0.73rem;color:rgba(255,255,255,0.5);margin-bottom:14px;font-style:italic;">Only Squad Leaders can issue 20% discount codes.</div>
      <button onclick="window.location.href='/pricing?v=2'" style="width:100%;padding:12px;background:linear-gradient(135deg,#A855F7,#EC4899);border:none;border-radius:10px;color:#fff;font-size:0.85rem;font-weight:700;cursor:pointer;font-family:inherit;">Become a Squad Leader</button>
    </div>
  </div>

  <!-- My HQ: Active Squads Module -->
  <div id="my-hq-squads" style="width:100%;max-width:380px;margin-top:14px;padding:0 4px;display:none;">
    <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(124,58,237,0.12);border-radius:14px;padding:18px 18px;">
      <div style="font-size:0.68rem;color:rgba(255,255,255,0.32);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px;">MY SQUADS</div>
      <div id="my-squads-list"></div>
      <a href="/squadmatch" style="display:block;margin-top:10px;text-align:center;font-size:0.78rem;color:rgba(168,85,247,0.8);font-weight:600;">+ New SquadMatch</a>
    </div>
  </div>

  <!-- Footer -->
  <footer style="width:100%;margin-top:32px;padding:20px 0 max(24px, env(safe-area-inset-bottom, 24px));border-top:1px solid rgba(255,255,255,0.06);">
    <div style="display:flex;flex-direction:row;flex-wrap:wrap;align-items:center;justify-content:center;gap:16px;margin-bottom:14px;">
      <a href="/how-it-works" style="font-size:0.75rem;color:rgba(255,255,255,0.35);text-decoration:none;">How It Works</a>
      <a href="/pricing" style="font-size:0.75rem;color:rgba(255,255,255,0.35);text-decoration:none;">Pricing</a>
      <a href="/squadmatch" style="font-size:0.75rem;text-decoration:none;background:linear-gradient(135deg,#A855F7,#EC4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;font-weight:600;">SquadMatch</a>
      <a href="/es" style="font-size:0.75rem;color:rgba(255,255,255,0.35);text-decoration:none;">Español</a>
      <a href="/affiliate" style="font-size:0.75rem;color:rgba(255,255,255,0.35);text-decoration:none;">Affiliate</a>
      <a href="/songs" style="font-size:0.75rem;color:rgba(255,255,255,0.35);text-decoration:none;">Song Directory</a>
      <a href="/blog" style="font-size:0.75rem;color:rgba(255,255,255,0.35);text-decoration:none;">Blog</a>
      <a href="/contact" style="font-size:0.75rem;color:rgba(255,255,255,0.35);text-decoration:none;">Contact</a>
      <a href="/privacy" style="font-size:0.72rem;color:rgba(255,255,255,0.3);text-decoration:none;">Privacy</a>
      <a href="/terms" style="font-size:0.72rem;color:rgba(255,255,255,0.3);text-decoration:none;">Terms</a>
      <a href="/login?return=/" id="footerLoginItem" style="font-size:0.75rem;color:rgba(255,255,255,0.35);text-decoration:none;">Log In</a>
    </div>
    <div style="text-align:center;font-size:0.65rem;color:rgba(255,255,255,0.2);">&copy; 2026 HumMatch</div>
  </footer>

</div>

<!-- SCREEN: PRIMER (drunk-proof prep screen) -->
<div id="screen-primer" class="screen">
  <div class="primer-icon">🎤</div>
  <div class="primer-title">Quick voice check, takes 10 seconds</div>
  <div class="primer-sub">You'll hum 3 times. No singing, no skill needed. Just make a "hmmmm" sound.</div>

  <div class="primer-steps">
    <div class="primer-step">
      <div class="primer-step-num">1</div>
      <div class="primer-step-text"><strong>Low hum</strong>: as deep as you can go</div>
    </div>
    <div class="primer-step">
      <div class="primer-step-num">2</div>
      <div class="primer-step-text"><strong>Normal voice</strong>: your everyday hum</div>
    </div>
    <div class="primer-step">
      <div class="primer-step-num">3</div>
      <div class="primer-step-text"><strong>High hum</strong>: as high as you can go</div>
    </div>
  </div>

  <button class="primer-ready-btn" onclick="beginAutoCapture()">I'm Ready →</button>
  <div class="primer-tip">We only listen to the pitch. No audio is recorded or stored.</div>
</div>

<!-- SCREEN 2: HUM TEST (auto-flow) -->
<div class="phase-success-overlay" id="phase-success"><div class="phase-success-check">✅</div><div class="phase-success-text" id="phase-success-text">Got it!</div></div>

<div id="screen-test" class="screen">
  <div class="auto-phase-label" id="phase-label">HUM 1 OF 3</div>
  <div class="auto-phase-emoji" id="phase-emoji">⬇️</div>
  <div class="auto-phase-title" id="phase-title">Hum your lowest note</div>
  <div class="auto-phase-sub" id="phase-sub">Go as deep as you comfortably can. Hold it steady.</div>

  <div class="countdown-ring-wrap" id="countdown-ring-wrap">
    <svg class="countdown-ring-svg" viewBox="0 0 120 120">
      <defs><linearGradient id="ring-grad" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#A855F7"/><stop offset="100%" stop-color="#EC4899"/></linearGradient></defs>
      <circle class="countdown-ring-bg" cx="60" cy="60" r="54"/>
      <circle class="countdown-ring-progress" id="countdown-ring" cx="60" cy="60" r="54"/>
    </svg>
    <div class="countdown-ring-center">
      <div class="countdown-ring-number" id="ring-number">3</div>
      <div class="countdown-ring-label" id="ring-label">seconds</div>
    </div>
  </div>

  <div class="auto-status" id="auto-status">🎤 Listening...</div>

  <div class="phase-dots" style="margin-top:20px;">
    <div class="phase-dot active" id="dot-0"></div>
    <div class="phase-dot" id="dot-1"></div>
    <div class="phase-dot" id="dot-2"></div>
  </div>

  <!-- Hidden elements for pitch detection (still needed by audio engine) -->
  <div style="display:none;">
    <div id="pitch-note">-</div>
    <div id="pitch-hz"></div>
    <div id="pitch-bar"></div>
    <div id="signal-status"></div>
    <canvas id="waveform-canvas" width="360" height="60"></canvas>
    <div id="low-note">-</div>
    <div id="mid-note">-</div>
    <div id="high-note">-</div>
  </div>
</div>

<!-- SCREEN 3: RESULTS -->
<div id="screen-results" class="screen">
  <div class="results-sticky-top">
    <div class="results-header">
      <div style="display:flex;align-items:center;justify-content:space-between;">
        <div class="confetti-emoji" id="result-emoji">🎉</div>
        <span id="hm-account-badge" class="hm-account-indicator" style="display:none;" onclick="hmShowAccountInfo()"></span>
      </div>
      <div class="voice-badge" id="voice-badge">⚡ Loading...</div>
      <div style="font-size:0.9rem;color:var(--text2);margin-bottom:4px;" id="range-text"></div>
      <div style="font-size:0.88rem;color:var(--text2);margin-bottom:8px;font-weight:600;" id="brightness-text"></div>
    </div>

    <div class="range-bar-wrap" id="range-bar-section">
      <div class="range-bar-label">Your Vocal Range</div>
      <div class="range-bar-track">
        <div class="range-bar-fill" id="range-bar-fill" style="left:20%;width:40%;"></div>
      </div>
      <div class="range-bar-ticks">
        <span>E1</span><span>A2</span><span>E3</span><span>A4</span><span>E5</span><span>C7</span>
      </div>
    </div>

    <!-- FILTER BAR -->
    <div class="filter-bar" id="filter-bar">
    <div class="filter-chip active" data-filter="all" onclick="setFilter('all',this)">🎵 All Songs</div>
    <div class="filter-chip" data-filter="nail" onclick="setFilter('nail',this)">✅ Nail It</div>
    <div class="filter-chip" data-filter="car" onclick="setFilter('car',this)">🚗 Car Songs</div>
    <div class="filter-chip" data-filter="solo" onclick="setFilter('solo',this)">🎧 Sing Alone</div>
    <div class="filter-chip" data-filter="group" onclick="setFilter('group',this)">👯 Sing Together</div>
    <div class="filter-chip" data-filter="familiar" onclick="setFilter('familiar',this)">⭐ I Know This</div>
    <div class="filter-chip" data-filter="pop" onclick="setFilter('pop',this)">🎤 Pop</div>
    <div class="filter-chip" data-filter="rock" onclick="setFilter('rock',this)">🎸 Rock</div>
    <div class="filter-chip" data-filter="country" onclick="setFilter('country',this)">🤠 Country</div>
    <div class="filter-chip" data-filter="classic" onclick="setFilter('classic',this)">🕰 Classics</div>
    <div class="filter-chip" data-filter="party" onclick="setFilter('party',this)">🎉 Crowd Pleasers</div>
    <div class="filter-chip" data-filter="stretch" onclick="setFilter('stretch',this)">💪 Stretch</div>
    <div class="filter-chip" data-filter="recent" onclick="setFilter('recent',this)">🔥 Recent</div>
    <div class="filter-chip" data-filter="90s" onclick="setFilter('90s',this)">📼 90s</div>
    <div class="filter-chip" data-filter="80s" onclick="setFilter('80s',this)">🕹 80s</div>
    <div class="filter-chip" data-filter="en" onclick="setFilter('en',this)">🇺🇸 English</div>
