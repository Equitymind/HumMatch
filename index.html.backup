    <button id="karaoke-yt-btn" onclick="" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);color:#fff;border-radius:50px;padding:10px 28px;font-size:0.82rem;font-weight:700;cursor:pointer;">
      ↗ Open in YouTube
    </button>
  </div>
</div>

<script>
// ── Analytics tracking ──────────────────────────────────────
function hmTrack(event, data) {
  const lang = document.documentElement.lang === "es" ? "es" : "en";
  fetch("/api/hummatch/event", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ event, lang, data: data || {} })
  }).catch(() => {});
}

