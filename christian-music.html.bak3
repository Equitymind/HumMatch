  <!-- Open Graph -->
  <meta property="og:type"        content="website">
  <meta property="og:title"       content="Top 100 Christian & Gospel Songs to Sing | HumMatch">
  <meta property="og:description" content="Find songs that match your voice from 100 Christian & Gospel picks — with vocal range data, difficulty ratings, and a free vocal range test.">
  <meta property="og:url"         content="https://hummatch.me/christian-music.html">
  <meta property="og:site_name"   content="HumMatch">

  <!-- Structured Data -->
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"CollectionPage","name":"Top 100 Christian & Gospel Songs to Sing","description":"Browse top Christian and Gospel songs with vocal range and difficulty data. Includes contemporary Christian, traditional hymns, and gospel standards.","url":"https://hummatch.me/christian-music.html","isPartOf":{"@type":"WebSite","name":"HumMatch","url":"https://hummatch.me"}}
  </script>
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"HumMatch","item":"https://hummatch.me"},{"@type":"ListItem","position":2,"name":"Christian & Gospel Music","item":"https://hummatch.me/christian-music.html"}]}
  </script>
  <script type="application/ld+json">
  {"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What are easy Christian songs to sing?","acceptedAnswer":{"@type":"Answer","text":"Easy Christian songs include 'Amazing Grace', '10,000 Reasons', 'How Great Thou Art', and 'Oceans' — all rated Easy on HumMatch and spanning fewer than 12 semitones."}},{"@type":"Question","name":"What vocal range do I need for gospel songs?","acceptedAnswer":{"@type":"Answer","text":"Gospel songs typically demand a wide range, often 15–20 semitones. Sopranos and high tenors shine on classics like 'O Happy Day' and Whitney Houston's 'I Will Always Love You' (often sung in church settings). Alto/baritone voices excel at many traditional hymns."}},{"@type":"Question","name":"Are Lauren Daigle songs hard to sing?","acceptedAnswer":{"@type":"Answer","text":"Lauren Daigle's songs like 'You Say' and 'How Can It Be' are moderately difficult — they span 10–14 semitones and include some emotional runs. They're accessible for trained singers but challenging for beginners."}}]}
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:     #0d0b1a;
      --card:   rgba(255,255,255,0.04);
      --border: rgba(124,58,237,0.15);
      --grad:   linear-gradient(135deg, #A855F7, #EC4899);
      --purple: #A855F7;
      --pink:   #EC4899;
      --text:   #e2e0f0;
      --muted:  rgba(255,255,255,0.45);
      --radius: 14px;
    }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; line-height: 1.6; }

    /* NAV */
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 24px; border-bottom: 1px solid var(--border);
      position: sticky; top: 0; z-index: 50;
      background: rgba(13,11,26,0.92); backdrop-filter: blur(12px);
    }
    .logo { font-size: 1.2rem; font-weight: 800; text-decoration: none; background: var(--grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .nav-links { display: flex; gap: 8px; align-items: center; }
    .nav-link { color: var(--muted); text-decoration: none; font-size: 0.875rem; padding: 6px 12px; border-radius: 8px; transition: color 0.15s; }
    .nav-link:hover { color: var(--text); }
    .nav-btn { background: var(--grad); color: #fff; padding: 8px 18px; border-radius: 10px; text-decoration: none; font-weight: 700; font-size: 0.875rem; transition: opacity 0.15s; }
    .nav-btn:hover { opacity: 0.85; }

    /* HERO */
    .hero { max-width: 1000px; margin: 0 auto; padding: 48px 24px 32px; }
    .breadcrumb { font-size: 0.8rem; color: var(--muted); margin-bottom: 20px; }
    .breadcrumb a { color: var(--muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--purple); }
    .breadcrumb span { margin: 0 6px; }
    .hero-badge { display: inline-flex; align-items: center; gap: 6px; background: rgba(168,85,247,0.12); border: 1px solid rgba(168,85,247,0.25); border-radius: 20px; padding: 4px 14px; font-size: 0.78rem; color: var(--purple); margin-bottom: 16px; }
    h1 { font-size: clamp(1.8rem, 5vw, 2.8rem); font-weight: 800; line-height: 1.15; margin-bottom: 10px; }
    .hero-sub { color: var(--muted); font-size: 1rem; margin-bottom: 32px; max-width: 640px; }
    .hero-sub strong { color: var(--text); }

    /* STATS ROW */
    .stats-row { display: flex; gap: 24px; margin-bottom: 36px; flex-wrap: wrap; }
    .stat-chip { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 14px 20px; flex: 1; min-width: 120px; }
    .stat-chip .num { font-size: 1.6rem; font-weight: 800; background: var(--grad); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .stat-chip .lbl { font-size: 0.75rem; color: var(--muted); margin-top: 2px; }

    /* VOCAL RANGE TOOL EMBED */
    .range-embed {
      background: linear-gradient(135deg, rgba(168,85,247,0.1), rgba(236,72,153,0.1));
      border: 1px solid rgba(168,85,247,0.3);
      border-radius: var(--radius); padding: 28px;
      margin-bottom: 36px; text-align: center;
    }
    .range-embed h2 { font-size: 1.15rem; font-weight: 700; margin-bottom: 8px; }
    .range-embed p { color: var(--muted); font-size: 0.9rem; margin-bottom: 20px; }
    .range-embed .voice-types { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 20px; }
    .voice-btn { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 8px 16px; font-size: 0.82rem; color: var(--muted); cursor: pointer; transition: all 0.15s; }
    .voice-btn:hover, .voice-btn.active { border-color: var(--purple); color: var(--purple); background: rgba(168,85,247,0.1); }
    .btn-grad { display: inline-block; background: var(--grad); color: #fff; padding: 11px 28px; border-radius: 11px; font-weight: 700; font-size: 0.9rem; text-decoration: none; transition: opacity 0.15s, transform 0.1s; }
    .btn-grad:hover { opacity: 0.88; transform: translateY(-1px); }

    /* FILTERS */
    .filters { max-width: 1000px; margin: 0 auto; padding: 0 24px 24px; }
    .filter-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 20px; }
    .filter-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 8px; }
    .filter-btn { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 6px 16px; font-size: 0.8rem; color: var(--muted); cursor: pointer; transition: all 0.15s; }
    .filter-btn:hover, .filter-btn.active { border-color: var(--purple); color: var(--purple); background: rgba(168,85,247,0.1); }

    /* SONG GRID */
    .section { max-width: 1000px; margin: 0 auto; padding: 0 24px 48px; }
    .section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
    .section-header h2 { font-size: 1.25rem; font-weight: 700; }
    .section-header .count { font-size: 0.78rem; color: var(--muted); background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 2px 10px; }
    .song-grid { display: grid; gap: 10px; }
    .song-card {
      background: var(--card); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 14px 18px; display: grid;
      grid-template-columns: 2fr 1fr 80px 80px 90px;
      align-items: center; gap: 12px;
      transition: border-color 0.15s, background 0.15s;
    }
    .song-card:hover { border-color: rgba(168,85,247,0.35); background: rgba(168,85,247,0.04); }
    .song-card.hidden { display: none; }
    .song-title { font-weight: 600; font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .song-artist { font-size: 0.78rem; color: var(--muted); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .song-range { font-size: 0.8rem; color: var(--muted); text-align: center; }
    .song-range strong { display: block; font-size: 0.88rem; color: var(--text); }
    .diff-badge { border-radius: 8px; padding: 3px 10px; font-size: 0.72rem; font-weight: 700; text-align: center; text-transform: uppercase; letter-spacing: 0.04em; }
    .diff-easy   { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.25); }
    .diff-medium { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.25); }
    .diff-hard   { background: rgba(239,68,68,0.15);  color: #f87171; border: 1px solid rgba(239,68,68,0.25); }
    .voice-tag { font-size: 0.72rem; color: var(--muted); text-align: right; }
    .voice-tag span { display: inline-block; background: rgba(168,85,247,0.08); border: 1px solid rgba(168,85,247,0.15); border-radius: 6px; padding: 2px 7px; margin-bottom: 3px; }
    .col-hdr { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); padding: 0 18px 8px; display: grid; grid-template-columns: 2fr 1fr 80px 80px 90px; gap: 12px; max-width: 1000px; margin: 0 auto; }

    /* VOICE GUIDE */
    .voice-guide { max-width: 1000px; margin: 0 auto; padding: 0 24px 48px; }
    .voice-guide h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 20px; }
    .voice-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; }
    .voice-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; }
    .voice-card .vname { font-weight: 700; margin-bottom: 4px; }
    .voice-card .vrange { font-size: 0.78rem; color: var(--purple); margin-bottom: 10px; }
    .voice-card ul { list-style: none; }
    .voice-card ul li { font-size: 0.82rem; color: var(--muted); padding: 3px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .voice-card ul li:last-child { border-bottom: none; }
    .voice-card ul li::before { content: "♪ "; color: var(--purple); }

    /* FAQ */
    .faq { max-width: 1000px; margin: 0 auto; padding: 0 24px 56px; }
    .faq h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 20px; }
    .faq-item { border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 10px; overflow: hidden; }
    .faq-q { padding: 16px 20px; font-weight: 600; font-size: 0.92rem; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
    .faq-q:hover { background: rgba(168,85,247,0.05); }
    .faq-a { padding: 0 20px 16px; font-size: 0.88rem; color: var(--muted); line-height: 1.7; display: none; }
    .faq-item.open .faq-a { display: block; }
    .faq-item.open .faq-q { color: var(--purple); }
    .faq-chevron { transition: transform 0.2s; color: var(--muted); }
    .faq-item.open .faq-chevron { transform: rotate(180deg); }

    /* FOOTER */
    footer { border-top: 1px solid var(--border); padding: 32px 24px; text-align: center; color: var(--muted); font-size: 0.82rem; }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: var(--purple); }
    .footer-links { display: flex; gap: 20px; justify-content: center; margin-bottom: 12px; flex-wrap: wrap; }

    @media (max-width: 680px) {
      .song-card { grid-template-columns: 1fr 80px 80px; }
      .song-card .song-range, .voice-tag { display: none; }
      .col-hdr { grid-template-columns: 1fr 80px 80px; }
      .col-hdr span:nth-child(2), .col-hdr span:nth-child(5) { display: none; }
    }
    @media (max-width: 480px) {
      .song-card { grid-template-columns: 1fr 80px; }
      .song-card .voice-tag { display: none; }
    }
  </style>
</head>
<body>

<nav>
  <a href="/" class="logo">HumMatch</a>
  <div class="nav-links">
    <a href="/song/" class="nav-link">Songs</a>
    <a href="/blog/" class="nav-link">Blog</a>
    <a href="/#try" class="nav-btn">Find My Songs</a>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="breadcrumb">
    <a href="/">HumMatch</a><span>›</span>
    <a href="/song/">Songs</a><span>›</span>
    Christian &amp; Gospel
  </div>
  <div class="hero-badge">✝ Christian &amp; Gospel</div>
  <h1>Top 100 Christian &amp; Gospel Songs to Sing</h1>
  <p class="hero-sub">
    From <strong>contemporary worship</strong> to <strong>classic hymns</strong> and <strong>soul-stirring gospel</strong> — every song rated for difficulty and matched to your vocal range.
    Whether you're leading worship, singing karaoke, or practicing at home, find the songs your voice was made for.
  </p>
  <div class="stats-row">
    <div class="stat-chip"><div class="num">100</div><div class="lbl">Songs catalogued</div></div>
    <div class="stat-chip"><div class="num">3</div><div class="lbl">Sub-categories</div></div>
    <div class="stat-chip"><div class="num">6</div><div class="lbl">Voice types covered</div></div>
    <div class="stat-chip"><div class="num">Free</div><div class="lbl">Vocal range test</div></div>
  </div>
</div>

<!-- VOCAL RANGE TOOL EMBED -->
<div style="max-width:1000px;margin:0 auto;padding:0 24px 36px">
  <div class="range-embed">
    <h2>🎤 Find Songs That Fit YOUR Voice</h2>
    <p>Not sure which of these songs you can actually sing? HumMatch compares your vocal range to every song's requirements — for free.</p>
    <div class="voice-types">
      <button class="voice-btn" onclick="selectVoice(this,'soprano')">Soprano</button>
      <button class="voice-btn" onclick="selectVoice(this,'mezzo')">Mezzo-Soprano</button>
      <button class="voice-btn" onclick="selectVoice(this,'alto')">Alto</button>
      <button class="voice-btn" onclick="selectVoice(this,'tenor')">Tenor</button>
      <button class="voice-btn" onclick="selectVoice(this,'baritone')">Baritone</button>
      <button class="voice-btn" onclick="selectVoice(this,'bass')">Bass</button>
    </div>
    <a href="/#try" class="btn-grad" id="range-cta">Test My Vocal Range Free →</a>
    <p style="margin-top:12px;font-size:0.78rem;color:var(--muted)">No account needed • Results in 60 seconds • Works on mobile</p>
  </div>
</div>

<!-- FILTERS -->
<div class="filters">
  <div class="filter-label">Filter by category</div>
  <div class="filter-row" id="cat-filters">
    <button class="filter-btn active" onclick="filterSongs('cat','all',this)">All (100)</button>
    <button class="filter-btn" onclick="filterSongs('cat','contemporary',this)">Contemporary Christian (35)</button>
    <button class="filter-btn" onclick="filterSongs('cat','gospel',this)">Gospel (35)</button>
    <button class="filter-btn" onclick="filterSongs('cat','hymn',this)">Traditional Hymns (30)</button>
  </div>
  <div class="filter-label">Filter by difficulty</div>
  <div class="filter-row" id="diff-filters">
    <button class="filter-btn active" onclick="filterSongs('diff','all',this)">All difficulties</button>
    <button class="filter-btn" onclick="filterSongs('diff','Easy',this)">Easy</button>
    <button class="filter-btn" onclick="filterSongs('diff','Medium',this)">Medium</button>
    <button class="filter-btn" onclick="filterSongs('diff','Hard',this)">Hard</button>
  </div>
</div>

<!-- COLUMN HEADERS -->
<div class="col-hdr">
  <span>Song / Artist</span>
  <span style="text-align:center">Category</span>
  <span style="text-align:center">Range</span>
  <span style="text-align:center">Difficulty</span>
  <span style="text-align:right">Best For</span>
</div>

<!-- SONG LIST: Contemporary Christian -->
