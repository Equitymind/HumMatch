<script>
  // Voice type selection
  let selectedVoice = null;
  function selectVoice(btn, type) {
    document.querySelectorAll('.voice-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    selectedVoice = type;
    const cta = document.getElementById('range-cta');
    const labels = { soprano:'Soprano', mezzo:'Mezzo-Soprano', alto:'Alto', tenor:'Tenor', baritone:'Baritone', bass:'Bass' };
    cta.textContent = `Find ${labels[type]} Songs on HumMatch →`;
    cta.href = `/#try?voice=${type}`;
  }

  // Filter logic
  let activeCat = 'all', activeDiff = 'all';
  function filterSongs(type, val, btn) {
    if (type === 'cat') {
      activeCat = val;
      document.querySelectorAll('#cat-filters .filter-btn').forEach(b => b.classList.remove('active'));
    } else {
      activeDiff = val;
      document.querySelectorAll('#diff-filters .filter-btn').forEach(b => b.classList.remove('active'));
    }
    btn.classList.add('active');
    document.querySelectorAll('.song-card').forEach(card => {
      const catMatch  = activeCat  === 'all' || card.dataset.cat  === activeCat;
      const diffMatch = activeDiff === 'all' || card.dataset.diff === activeDiff;
      card.classList.toggle('hidden', !(catMatch && diffMatch));
    });
    // Update visible counts
    const visible = document.querySelectorAll('.song-card:not(.hidden)').length;
    const allBtn = document.querySelector('#cat-filters .filter-btn');
    // Only update totals for "all" button label
  }

  // FAQ accordion
  function toggleFaq(el) {
    const item = el.parentElement;
    item.classList.toggle('open');
  }
</script>

</body>
