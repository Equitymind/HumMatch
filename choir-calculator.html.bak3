<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Choir Song Finder — Songs for Your Choir Size | HumMatch</title>
  <meta name="description" content="Free choir song finder. Enter your soprano, alto, tenor, and bass counts to instantly discover choral songs that work for your exact choir size and makeup.">
  <meta name="keywords" content="choir song finder, songs for my choir, SATB choir songs, choral music selector, choir repertoire finder, voice part calculator, find choir songs">
  <meta property="og:title" content="Choir Song Finder — Find Songs for Your Choir">
  <meta property="og:description" content="Enter your choir's voice part counts and instantly find perfectly matched choral repertoire. Free tool for choir directors.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://hummatch.com/choir-calculator.html">
  <link rel="canonical" href="https://hummatch.com/choir-calculator.html">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0d0b1a;
      --card: rgba(255,255,255,0.04);
      --border: rgba(124,58,237,0.15);
      --border-hover: rgba(168,85,247,0.35);
      --grad-1: #A855F7;
      --grad-2: #EC4899;
      --text: #e2e0f0;
      --muted: rgba(255,255,255,0.4);
      --green: #34d399;
      --yellow: #fbbf24;
      --radius: 14px;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      padding: 32px 16px 64px;
    }

    .page-wrap {
      max-width: 860px;
      margin: 0 auto;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 36px;
    }
    .header-badge {
      display: inline-block;
      background: rgba(168,85,247,0.15);
      border: 1px solid rgba(168,85,247,0.3);
      color: var(--grad-1);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 14px;
    }
    .header h1 {
      font-size: clamp(26px, 5vw, 40px);
      font-weight: 800;
      background: linear-gradient(135deg, var(--grad-1), var(--grad-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1.15;
      margin-bottom: 10px;
    }
    .header p {
      color: var(--muted);
      font-size: 15px;
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.6;
    }

    /* Calculator card */
    .calc-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 28px 24px 24px;
      margin-bottom: 28px;
    }
    .calc-card h2 {
      font-size: 14px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }
    .voice-inputs {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 20px;
    }
    @media (max-width: 480px) {
      .voice-inputs { grid-template-columns: repeat(2, 1fr); }
    }
    .voice-input-group label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 6px;
    }
    .voice-input-group .voice-label {
      font-size: 20px;
      font-weight: 800;
      display: block;
      margin-bottom: 4px;
    }
    .voice-input-group .voice-label.sop { color: #c084fc; }
    .voice-input-group .voice-label.alt { color: #f472b6; }
    .voice-input-group .voice-label.ten { color: #60a5fa; }
    .voice-input-group .voice-label.bas { color: #818cf8; }
    .voice-input-group input {
      width: 100%;
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--text);
      font-size: 22px;
      font-weight: 700;
      text-align: center;
      padding: 12px 8px;
      outline: none;
      transition: border-color 0.2s;
    }
    .voice-input-group input:focus { border-color: var(--border-hover); }
    .voice-input-group input::-webkit-outer-spin-button,
    .voice-input-group input::-webkit-inner-spin-button { -webkit-appearance: none; }
    .voice-input-group input[type=number] { -moz-appearance: textfield; }

    .calc-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .btn-primary {
      flex: 1;
      min-width: 140px;
      background: linear-gradient(135deg, var(--grad-1), var(--grad-2));
      border: none;
      border-radius: 12px;
      color: #fff;
      font-size: 15px;
      font-weight: 700;
      padding: 13px 20px;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
    }
    .btn-primary:hover { opacity: 0.9; }
    .btn-primary:active { transform: scale(0.98); }
    .btn-share {
      background: rgba(255,255,255,0.06);
      border: 1px solid var(--border);
      border-radius: 12px;
      color: var(--text);
      font-size: 14px;
      font-weight: 600;
      padding: 13px 18px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .btn-share:hover { border-color: var(--border-hover); background: rgba(168,85,247,0.08); }
    .share-feedback {
      font-size: 12px;
      color: var(--green);
      align-self: center;
      display: none;
    }
    .share-feedback.show { display: block; }

    /* Results summary */
    .results-summary {
      display: none;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 16px;
    }
    .results-summary.show { display: flex; }
    .results-count {
      font-size: 16px;
      font-weight: 700;
    }
    .results-count span {
      background: linear-gradient(135deg, var(--grad-1), var(--grad-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Filters */
    .filters {
      display: none;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 20px;
    }
    .filters.show { display: flex; }
    .filter-btn {
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--border);
      border-radius: 20px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 600;
      padding: 5px 13px;
      cursor: pointer;
      transition: all 0.15s;
    }
    .filter-btn:hover { border-color: var(--border-hover); color: var(--text); }
    .filter-btn.active {
      background: rgba(168,85,247,0.15);
      border-color: rgba(168,85,247,0.4);
      color: var(--grad-1);
    }

    /* Song grid */
    .song-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 14px;
    }
    .song-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      transition: border-color 0.2s, transform 0.15s;
      animation: fadeIn 0.25s ease;
    }
    .song-card:hover {
      border-color: var(--border-hover);
      transform: translateY(-2px);
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .song-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 8px;
      gap: 8px;
    }
    .song-title {
      font-size: 15px;
      font-weight: 700;
      line-height: 1.3;
    }
    .fit-badge {
      flex-shrink: 0;
      font-size: 16px;
      line-height: 1;
      margin-top: 1px;
    }
    .song-composer {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 10px;
    }
    .song-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      margin-bottom: 10px;
    }
    .tag {
      font-size: 11px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 6px;
    }
    .tag-arr {
      background: rgba(168,85,247,0.15);
      color: #c084fc;
      border: 1px solid rgba(168,85,247,0.25);
    }
    .tag-diff-beginner {
      background: rgba(52,211,153,0.12);
      color: #34d399;
      border: 1px solid rgba(52,211,153,0.25);
    }
    .tag-diff-intermediate {
      background: rgba(251,191,36,0.12);
      color: #fbbf24;
      border: 1px solid rgba(251,191,36,0.25);
    }
    .tag-diff-advanced {
      background: rgba(248,113,113,0.12);
      color: #f87171;
      border: 1px solid rgba(248,113,113,0.25);
    }
    .tag-genre {
      background: rgba(255,255,255,0.06);
      color: var(--muted);
      border: 1px solid rgba(255,255,255,0.1);
    }
    .song-desc {
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      line-height: 1.5;
      margin-bottom: 8px;
    }
    .balance-note {
      font-size: 11px;
      font-weight: 600;
      padding: 4px 8px;
      border-radius: 6px;
    }
    .balance-great {
      background: rgba(52,211,153,0.1);
      color: #34d399;
    }
    .balance-ok {
      background: rgba(251,191,36,0.1);
      color: #fbbf24;
    }

    /* Empty state */
    .empty-state {
      display: none;
      text-align: center;
      padding: 48px 24px;
      color: var(--muted);
    }
    .empty-state.show { display: block; }
    .empty-state .icon { font-size: 48px; margin-bottom: 16px; }
    .empty-state h3 { font-size: 18px; color: var(--text); margin-bottom: 8px; }
    .empty-state p { font-size: 14px; line-height: 1.6; }

    /* Initial prompt */
    .initial-prompt {
      text-align: center;
      padding: 48px 24px;
      color: var(--muted);
    }
    .initial-prompt .icon { font-size: 52px; margin-bottom: 16px; display: block; }
    .initial-prompt p { font-size: 15px; line-height: 1.7; max-width: 360px; margin: 0 auto; }
    .initial-prompt strong { color: var(--text); }

    /* Footer nav */
    .page-footer {
      margin-top: 48px;
      text-align: center;
      color: var(--muted);
      font-size: 13px;
    }
    .page-footer a {
      color: var(--grad-1);
      text-decoration: none;
    }
    .page-footer a:hover { text-decoration: underline; }
    .footer-sep { margin: 0 10px; }

    /* Responsive */
    @media (max-width: 600px) {
      .song-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="page-wrap">

    <header class="header">
      <div class="header-badge">Free Choir Tool</div>
      <h1>Choir Song Finder</h1>
      <p>Enter your choir's voice part counts — find songs that actually fit your singers.</p>
    </header>

    <!-- Calculator Input -->
    <div class="calc-card">
      <h2>How many singers per section?</h2>
      <div class="voice-inputs">
        <div class="voice-input-group">
          <span class="voice-label sop">S</span>
          <label for="inp-sop">Sopranos</label>
          <input type="number" id="inp-sop" min="0" max="999" placeholder="0" value="">
        </div>
        <div class="voice-input-group">
          <span class="voice-label alt">A</span>
          <label for="inp-alt">Altos</label>
          <input type="number" id="inp-alt" min="0" max="999" placeholder="0" value="">
        </div>
        <div class="voice-input-group">
          <span class="voice-label ten">T</span>
          <label for="inp-ten">Tenors</label>
          <input type="number" id="inp-ten" min="0" max="999" placeholder="0" value="">
        </div>
        <div class="voice-input-group">
          <span class="voice-label bas">B</span>
          <label for="inp-bas">Basses</label>
          <input type="number" id="inp-bas" min="0" max="999" placeholder="0" value="">
        </div>
      </div>
      <div class="calc-actions">
        <button class="btn-primary" onclick="findSongs()">Find Songs for My Choir</button>
        <button class="btn-share" onclick="shareLink()">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          Share
        </button>
        <span class="share-feedback" id="share-feedback">Link copied!</span>
      </div>
    </div>

    <!-- Results summary -->
    <div class="results-summary" id="results-summary">
      <div class="results-count" id="results-count"></div>
      <div style="display:flex;gap:6px;align-items:center;">
        <span style="font-size:12px;color:var(--muted)">Sort:</span>
        <select id="sort-sel" onchange="renderResults()" style="background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:12px;padding:4px 8px;outline:none;cursor:pointer;">
          <option value="fit">Best Fit</option>
          <option value="alpha">A–Z</option>
          <option value="diff">Easiest First</option>
        </select>
      </div>
    </div>

    <!-- Genre filters -->
    <div class="filters" id="genre-filters">
      <button class="filter-btn active" data-filter="all" onclick="setFilter('all',this)">All</button>
      <button class="filter-btn" data-filter="Classical" onclick="setFilter('Classical',this)">Classical</button>
      <button class="filter-btn" data-filter="Contemporary" onclick="setFilter('Contemporary',this)">Contemporary</button>
      <button class="filter-btn" data-filter="Gospel" onclick="setFilter('Gospel',this)">Gospel / Spiritual</button>
      <button class="filter-btn" data-filter="Pop" onclick="setFilter('Pop',this)">Pop</button>
      <button class="filter-btn" data-filter="Folk" onclick="setFilter('Folk',this)">Folk</button>
      <button class="filter-btn" data-filter="Broadway" onclick="setFilter('Broadway',this)">Broadway</button>
    </div>

    <!-- Song results -->
    <div id="song-grid" class="song-grid"></div>

    <!-- Empty state -->
    <div class="empty-state" id="empty-state">
      <div class="icon">&#x1F914;</div>
      <h3>No songs match this exact configuration</h3>
      <p>Try adding singers to more voice sections, or check out songs for smaller ensembles.</p>
    </div>

    <!-- Initial prompt (before search) -->
    <div class="initial-prompt" id="initial-prompt">
      <span class="icon">&#x1F3BC;</span>
      <p>Enter your choir's section counts above and click <strong>Find Songs</strong> to see repertoire matched to your exact voice makeup.</p>
    </div>

    <footer class="page-footer">
      <a href="/">HumMatch</a>
      <span class="footer-sep">&middot;</span>
      <a href="/for-choir-directors.html">For Choir Directors</a>
      <span class="footer-sep">&middot;</span>
      <a href="/index.html">Hum a Song</a>
    </footer>

  </div>

  <script>
    // ─── Song Database ────────────────────────────────────────────────────────
    // req: which voice parts are REQUIRED (S=soprano, A=alto, T=tenor, B=bass)
    // min: recommended minimum per part for a full sound
    // diff: beginner | intermediate | advanced
    // genre: Classical | Contemporary | Gospel | Pop | Folk | Broadway
    const SONGS = [
      // SATB — Classical
      { id:'c1', title:"Hallelujah Chorus", composer:"G.F. Handel", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:4,A:4,T:3,B:3},
        diff:"intermediate", genre:"Classical",
        desc:"The iconic finale from Messiah. A must for any SATB chorus." },
      { id:'c2', title:"Ave Verum Corpus", composer:"W.A. Mozart", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Classical",
        desc:"Gentle and meditative. Perfect for younger or smaller SATB choirs." },
      { id:'c3', title:"Ode to Joy", composer:"Beethoven (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Classical",
        desc:"Universal anthem. Instantly recognizable, crowd-pleasing closer." },
      { id:'c4', title:"How Lovely Is Thy Dwelling Place", composer:"Johannes Brahms", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:5,A:5,T:4,B:4},
        diff:"advanced", genre:"Classical",
        desc:"From A German Requiem. Rich Romantic harmonies, deeply expressive." },
      { id:'c5', title:"Water Night", composer:"Eric Whitacre", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:4,A:4,T:3,B:3},
        diff:"intermediate", genre:"Contemporary",
        desc:"Lush, atmospheric choral clusters. A modern favourite." },
      { id:'c6', title:"Sleep", composer:"Eric Whitacre", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:4,A:4,T:3,B:3},
        diff:"intermediate", genre:"Contemporary",
        desc:"Hypnotic and cinematic. Great for auditions and concerts alike." },
      { id:'c7', title:"Lux Aeterna", composer:"Edward Elgar", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:5,A:5,T:4,B:4},
        diff:"advanced", genre:"Classical",
        desc:"Solemn and majestic. Often performed at memorial services." },
      { id:'c8', title:"The Road Not Taken", composer:"Randall Thompson", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"intermediate", genre:"Contemporary",
        desc:"American classic. Poetry by Robert Frost set beautifully." },
      { id:'c9', title:"Cloudburst", composer:"Eric Whitacre", arr:"SATB + percussion",
        req:{S:1,A:1,T:1,B:1}, min:{S:6,A:6,T:5,B:5},
        diff:"advanced", genre:"Contemporary",
        desc:"Theatrical and thrilling. Singers simulate a rainstorm. Crowd favourite." },
      { id:'c10', title:"Gloria in Excelsis Deo", composer:"Antonio Vivaldi (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:4,A:3,T:2,B:2},
        diff:"intermediate", genre:"Classical",
        desc:"Joyful Baroque energy. Works beautifully with strings." },

      // SATB — Gospel & Spiritual
      { id:'g1', title:"Go Down Moses", composer:"Traditional Spiritual", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Gospel",
        desc:"Powerful and deep-rooted. Low baritone/bass lines give this real gravity." },
      { id:'g2', title:"Swing Low, Sweet Chariot", composer:"Traditional Spiritual", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Gospel",
        desc:"Beloved American spiritual. Easy to learn, beautiful in full harmony." },
      { id:'g3', title:"Wade in the Water", composer:"Traditional Spiritual", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Gospel",
        desc:"Rhythmic and energetic. Works with or without piano/band." },
      { id:'g4', title:"Total Praise", composer:"Richard Smallwood", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:4,A:4,T:3,B:3},
        diff:"intermediate", genre:"Gospel",
        desc:"Contemporary gospel anthem. Powerful climax. Ideal for worship concerts." },
      { id:'g5', title:"Ride the Chariot", composer:"Traditional (arr. W. Smith)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Gospel",
        desc:"Upbeat spiritual with call-and-response energy. Audiences love it." },

      // SATB — Pop Arrangements
      { id:'p1', title:"Bohemian Rhapsody", composer:"Queen (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:4,A:4,T:3,B:3},
        diff:"advanced", genre:"Pop",
        desc:"The ultimate choir showstopper. Requires confident soloists for the verses." },
      { id:'p2', title:"Fix You", composer:"Coldplay (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Pop",
        desc:"Emotional and uplifting. Accessible for beginner choirs. Audiences cry." },
      { id:'p3', title:"Africa", composer:"Toto (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"intermediate", genre:"Pop",
        desc:"80s nostalgia done right. Great for younger choirs and pop concerts." },
      { id:'p4', title:"Lean on Me", composer:"Bill Withers (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Pop",
        desc:"Simple, soulful, and moving. Perfect community choir repertoire." },
      { id:'p5', title:"Somewhere Over the Rainbow", composer:"Arlen (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Broadway",
        desc:"Timeless standard. Works at graduations, weddings, and concerts." },
      { id:'p6', title:"Don't Stop Believin'", composer:"Journey (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Pop",
        desc:"Crowd-pleaser every time. Easy harmonies, huge energy." },
      { id:'p7', title:"Hallelujah", composer:"Leonard Cohen (arr. SATB)", arr:"SATB",
        req:{S:1,A:1,T:1,B:1}, min:{S:3,A:3,T:2,B:2},
        diff:"beginner", genre:"Pop",
        desc:"Hauntingly beautiful. Works with a soloist and SATB choir underneath." },

      // SAB (Soprano + Alto + Bass, no tenor required)
      { id:'b1', title:"Danny Boy", composer:"Traditional (arr. SAB)", arr:"SAB",
        req:{S:1,A:1,T:0,B:1}, min:{S:3,A:3,T:0,B:2},
        diff:"beginner", genre:"Folk",
        desc:"Irish classic. The SAB arrangement is stunning without full SATB." },
      { id:'b2', title:"Simple Gifts", composer:"Traditional Shaker (arr. SAB)", arr:"SAB",
        req:{S:1,A:1,T:0,B:1}, min:{S:3,A:3,T:0,B:2},
        diff:"beginner", genre:"Folk",
        desc:"Clean, pure, and timeless. Works for any occasion." },
      { id:'b3', title:"Amazing Grace", composer:"Traditional (arr. SAB)", arr:"SAB",
        req:{S:1,A:1,T:0,B:1}, min:{S:3,A:3,T:0,B:2},
        diff:"beginner", genre:"Gospel",
        desc:"Universally beloved. The SAB version keeps all the important harmonies." },
      { id:'b4', title:"This Little Light of Mine", composer:"Traditional (arr. SAB)", arr:"SAB",
        req:{S:1,A:1,T:0,B:1}, min:{S:3,A:3,T:0,B:2},
        diff:"beginner", genre:"Gospel",
        desc:"Joyful and accessible. Great for community or church choirs." },
      { id:'b5', title:"From a Distance", composer:"Julie Gold (arr. SAB)", arr:"SAB",
        req:{S:1,A:1,T:0,B:1}, min:{S:3,A:3,T:0,B:2},
        diff:"beginner", genre:"Pop",
        desc:"Inspirational message, beautiful harmonies. No tenors? No problem." },

      // SSA (Women's or Treble Choir)
      { id:'w1', title:"A Ceremony of Carols", composer:"Benjamin Britten", arr:"SSA",
        req:{S:1,A:1,T:0,B:0}, min:{S:5,A:4,T:0,B:0},
        diff:"advanced", genre:"Classical",
        desc:"A complete choral cycle. Harp optional. Stunning for women's choir." },
      { id:'w2', title:"Someone Like You", composer:"Adele (arr. SSA)", arr:"SSA",
        req:{S:1,A:1,T:0,B:0}, min:{S:4,A:4,T:0,B:0},
        diff:"beginner", genre:"Pop",
        desc:"Intimate and emotional. Excellent for women's chorus pop concerts." },
      { id:'w3', title:"Viva la Vida", composer:"Coldplay (arr. SSA)", arr:"SSA",
        req:{S:1,A:1,T:0,B:0}, min:{S:4,A:4,T:0,B:0},
        diff:"intermediate", genre:"Pop",
        desc:"Anthemic and driving. The SSA version works surprisingly well." },
      { id:'w4', title:"Defying Gravity", composer:"Wicked (arr. SSA)", arr:"SSA",
        req:{S:1,A:1,T:0,B:0}, min:{S:4,A:4,T:0,B:0},
        diff:"intermediate", genre:"Broadway",
        desc:"Show-stopping musical theatre piece. Great for school choirs." },
      { id:'w5', title:"When I Was Your Man", composer:"Bruno Mars (arr. SA)", arr:"SA",
        req:{S:1,A:1,T:0,B:0}, min:{S:4,A:3,T:0,B:0},
        diff:"beginner", genre:"Pop",
        desc:"Two-part arrangement. Beautiful simplicity. Perfect for small groups." },

      // TTBB (Men's Choir)
      { id:'m1', title:"The Lion Sleeps Tonight", composer:"Weiss/Linda (arr. TTBB)", arr:"TTBB",
        req:{S:0,A:0,T:1,B:1}, min:{S:0,A:0,T:4,B:3},
        diff:"beginner", genre:"Pop",
        desc:"Fun, crowd-pleasing, and accessible. Audiences love it every time." },
      { id:'m2', title:"Old Man River", composer:"Kern/Hammerstein (arr. TTBB)", arr:"TTBB",
        req:{S:0,A:0,T:1,B:1}, min:{S:0,A:0,T:3,B:3},
        diff:"intermediate", genre:"Broadway",
        desc:"Deep, powerful, and moving. The bass solo is iconic." },
      { id:'m3', title:"Shenandoah", composer:"Traditional (arr. TTBB)", arr:"TTBB",
        req:{S:0,A:0,T:1,B:1}, min:{S:0,A:0,T:3,B:2},
        diff:"beginner", genre:"Folk",
        desc:"American folk masterpiece. Gorgeous in a men's arrangement." },
      { id:'m4', title:"Drink to Me Only", composer:"Traditional (arr. TTBB)", arr:"TTBB",
        req:{S:0,A:0,T:1,B:1}, min:{S:0,A:0,T:3,B:2},
        diff:"beginner", genre:"Folk",
        desc:"Classic English folk song. Warm harmonies, easy to learn." },
      { id:'m5', title:"O Fortuna", composer:"Carl Orff (arr. TTBB)", arr:"TTBB",
        req:{S:0,A:0,T:1,B:1}, min:{S:0,A:0,T:5,B:5},
        diff:"intermediate", genre:"Classical",
        desc:"From Carmina Burana. Epic and dramatic. Needs a big men's section." },

      // 2-part / Unison
      { id:'u1', title:"You Raise Me Up", composer:"Løvland/Graham (2-part)", arr:"2-Part",
        req:{S:1,A:1,T:0,B:0}, min:{S:3,A:3,T:0,B:0},
        diff:"beginner", genre:"Pop",
        desc:"Uplifting and singable. The 2-part version works for any treble choir." },
      { id:'u2', title:"Scarborough Fair", composer:"Traditional (2-part)", arr:"2-Part",
        req:{S:1,A:1,T:0,B:0}, min:{S:3,A:3,T:0,B:0},
        diff:"beginner", genre:"Folk",
        desc:"Haunting and beautiful. Works with or without instruments." },
      { id:'u3', title:"Dona Nobis Pacem", composer:"Traditional (round)", arr:"Unison/Round",
        req:{S:1,A:0,T:0,B:0}, min:{S:1,A:0,T:0,B:0},
        diff:"beginner", genre:"Classical",
        desc:"Latin round. Works for any choir with even one section. Great for beginners." },
      { id:'u4', title:"Jubilate Deo", composer:"Praetorius (round)", arr:"Unison/Round",
        req:{S:1,A:0,T:0,B:0}, min:{S:1,A:0,T:0,B:0},
        diff:"beginner", genre:"Classical",
        desc:"Joyful Renaissance round. Teach it in 10 minutes, perform it the same day." },
      { id:'u5', title:"For the Beauty of the Earth", composer:"Rutter (unison/2-part)", arr:"Unison",
        req:{S:1,A:0,T:0,B:0}, min:{S:2,A:0,T:0,B:0},
        diff:"beginner", genre:"Classical",
        desc:"John Rutter's beloved hymn. Suitable for any congregation or choir." },
    ];

    // ─── State ────────────────────────────────────────────────────────────────
    let matchedSongs = [];
    let activeFilter = 'all';

    // ─── Matching Logic ───────────────────────────────────────────────────────
    function getInputs() {
      return {
        S: parseInt(document.getElementById('inp-sop').value) || 0,
        A: parseInt(document.getElementById('inp-alt').value) || 0,
        T: parseInt(document.getElementById('inp-ten').value) || 0,
        B: parseInt(document.getElementById('inp-bas').value) || 0,
      };
    }

    function scoreSong(song, choir) {
      // Returns { canPerform, score, warnings }
      let canPerform = true;
      let score = 100;
      const warnings = [];

      ['S','A','T','B'].forEach(part => {
        if (song.req[part] > 0) {
          if (choir[part] < 1) {
            canPerform = false;
            return;
          }
          if (choir[part] < song.min[part]) {
            const shortfall = song.min[part] - choir[part];
            score -= 15 + shortfall * 3;
            const label = {S:'Soprano',A:'Alto',T:'Tenor',B:'Bass'}[part];
            warnings.push(`Light on ${label}s (${choir[part]} / rec. ${song.min[part]})`);
          }
        }
      });

      return { canPerform, score: Math.max(0, score), warnings };
    }

    // ─── Find Songs ───────────────────────────────────────────────────────────
    function findSongs() {
      const choir = getInputs();
      const totalSingers = choir.S + choir.A + choir.T + choir.B;

      document.getElementById('initial-prompt').style.display = 'none';

      matchedSongs = [];
      SONGS.forEach(song => {
        const { canPerform, score, warnings } = scoreSong(song, choir);
        if (canPerform && totalSingers > 0) {
          matchedSongs.push({ ...song, score, warnings });
        }
      });

      updateURL(choir);
      renderResults();
    }

    // ─── Render ───────────────────────────────────────────────────────────────
    function renderResults() {
      const sortBy = document.getElementById('sort-sel')?.value || 'fit';
      const diffOrder = { beginner: 0, intermediate: 1, advanced: 2 };

      let filtered = activeFilter === 'all'
        ? [...matchedSongs]
        : matchedSongs.filter(s => s.genre === activeFilter || (activeFilter === 'Gospel' && s.genre === 'Gospel'));

      // Sort
      if (sortBy === 'fit') filtered.sort((a,b) => b.score - a.score);
      else if (sortBy === 'alpha') filtered.sort((a,b) => a.title.localeCompare(b.title));
      else if (sortBy === 'diff') filtered.sort((a,b) => diffOrder[a.diff] - diffOrder[b.diff]);

      const grid = document.getElementById('song-grid');
      const summary = document.getElementById('results-summary');
      const filtersEl = document.getElementById('genre-filters');
      const emptyEl = document.getElementById('empty-state');
      const countEl = document.getElementById('results-count');

      summary.classList.add('show');
      filtersEl.classList.add('show');

      if (filtered.length === 0) {
        grid.innerHTML = '';
        emptyEl.classList.add('show');
        countEl.innerHTML = `<span>0</span> songs match`;
        return;
      }

      emptyEl.classList.remove('show');

      const choir = getInputs();
      const voiceDesc = buildVoiceDesc(choir);
      countEl.innerHTML = `<span>${filtered.length}</span> songs match your ${voiceDesc} choir`;

      grid.innerHTML = filtered.map(song => renderCard(song)).join('');
    }

    function buildVoiceDesc(choir) {
      const parts = [];
      if (choir.S > 0) parts.push(`${choir.S}S`);
      if (choir.A > 0) parts.push(`${choir.A}A`);
      if (choir.T > 0) parts.push(`${choir.T}T`);
      if (choir.B > 0) parts.push(`${choir.B}B`);
      return parts.join('/') || '';
    }

    function renderCard(song) {
      const diffClass = `tag-diff-${song.diff}`;
      const fitIcon = song.score >= 85 ? '✅' : song.score >= 60 ? '⚡' : '⚠️';

      let balanceHtml = '';
      if (song.warnings.length === 0) {
        balanceHtml = `<div class="balance-note balance-great">Great fit for your choir</div>`;
      } else {
        balanceHtml = `<div class="balance-note balance-ok">${song.warnings[0]}</div>`;
      }

      return `
        <div class="song-card">
          <div class="song-top">
            <div class="song-title">${song.title}</div>
            <div class="fit-badge" title="Fit score: ${song.score}">${fitIcon}</div>
          </div>
          <div class="song-composer">${song.composer}</div>
          <div class="song-tags">
            <span class="tag tag-arr">${song.arr}</span>
            <span class="tag ${diffClass}">${capitalize(song.diff)}</span>
            <span class="tag tag-genre">${song.genre}</span>
          </div>
          <div class="song-desc">${song.desc}</div>
          ${balanceHtml}
        </div>`;
    }

    function capitalize(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

    // ─── Filters ──────────────────────────────────────────────────────────────
    function setFilter(filter, btn) {
      activeFilter = filter;
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      renderResults();
    }

    // ─── Share ────────────────────────────────────────────────────────────────
    function updateURL(choir) {
      const params = new URLSearchParams();
      if (choir.S) params.set('s', choir.S);
      if (choir.A) params.set('a', choir.A);
      if (choir.T) params.set('t', choir.T);
      if (choir.B) params.set('b', choir.B);
      const url = `${location.pathname}?${params.toString()}`;
      history.replaceState({}, '', url);
    }

    function shareLink() {
      const choir = getInputs();
      updateURL(choir);
      const shareUrl = window.location.href;
      if (navigator.clipboard) {
        navigator.clipboard.writeText(shareUrl).then(() => {
          const fb = document.getElementById('share-feedback');
          fb.classList.add('show');
          setTimeout(() => fb.classList.remove('show'), 2500);
        });
      } else {
        prompt('Copy this link:', shareUrl);
      }
    }

    // ─── Load from URL params ─────────────────────────────────────────────────
    function loadFromURL() {
      const p = new URLSearchParams(location.search);
      if (p.get('s')) document.getElementById('inp-sop').value = p.get('s');
      if (p.get('a')) document.getElementById('inp-alt').value = p.get('a');
      if (p.get('t')) document.getElementById('inp-ten').value = p.get('t');
      if (p.get('b')) document.getElementById('inp-bas').value = p.get('b');
      if (p.get('s') || p.get('a') || p.get('t') || p.get('b')) {
        findSongs();
      }
    }

    // ─── Enter key support ────────────────────────────────────────────────────
    document.querySelectorAll('input[type=number]').forEach(inp => {
      inp.addEventListener('keydown', e => { if (e.key === 'Enter') findSongs(); });
    });

    loadFromURL();
  </script>
</body>
</html>
