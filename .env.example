# HumMatch Environment Variables
# Copy this file to .env and fill in the values

# === REQUIRED ===
ADMIN_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === RECOMMENDED ===
HUMMATCH_EMAIL_USER=
HUMMATCH_EMAIL_PASS=
DB_PATH=/data/hummatch.db

# === OPTIONAL ===
ANTHROPIC_API_KEY=
BASE_URL=https://hummatch.me
BUILD_VERSION=1.0.0
PORT=3000
