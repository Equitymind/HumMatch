<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>HumMatch Analytics</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
#hum-map { height: 340px; border-radius: 10px; z-index: 1; }
.leaflet-container { background: #1a1030; }
</style>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#0d0b1a;color:#e2e0f0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;min-height:100vh}
a{color:#a78bfa;text-decoration:none}

/* Login */
#login-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;gap:20px}
#login-screen .logo-wrap{display:flex;align-items:center;gap:12px;margin-bottom:12px}
#login-screen h1{font-size:1.5rem;background:linear-gradient(135deg,#A855F7,#EC4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.login-input{background:rgba(255,255,255,0.06);border:1px solid rgba(124,58,237,0.3);color:#fff;padding:14px 20px;border-radius:12px;font-size:1rem;width:280px;outline:none;transition:border 0.2s}
.login-input:focus{border-color:#7c3aed}
.login-btn{background:linear-gradient(135deg,#7c3aed,#db2777);color:#fff;border:none;padding:12px 32px;border-radius:12px;font-size:1rem;font-weight:700;cursor:pointer;transition:transform 0.15s,box-shadow 0.15s}
.login-btn:hover{transform:translateY(-1px);box-shadow:0 4px 20px rgba(124,58,237,0.4)}

/* Dashboard */
#dashboard{display:none;max-width:1200px;margin:0 auto;padding:20px}
#dashboard.active{display:block}

.dash-header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid rgba(124,58,237,0.15)}
.dash-header .logo-wrap{display:flex;align-items:center;gap:10px}
.dash-header h1{font-size:1.3rem;background:linear-gradient(135deg,#A855F7,#EC4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.dash-header .right{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.time-btn{background:rgba(255,255,255,0.06);border:1px solid rgba(124,58,237,0.2);color:#a78bfa;padding:6px 14px;border-radius:8px;font-size:0.78rem;font-weight:600;cursor:pointer;transition:all 0.2s}
.time-btn.active,.time-btn:hover{background:linear-gradient(135deg,#7c3aed,#db2777);color:#fff;border-color:transparent}
.last-updated{font-size:0.7rem;color:rgba(255,255,255,0.3)}
.logout-btn{background:none;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.4);padding:6px 12px;border-radius:8px;font-size:0.72rem;cursor:pointer}
.logout-btn:hover{border-color:#ef4444;color:#ef4444}
.trend{font-size:0.72rem;font-weight:700;margin-top:4px;color:#10B981}
.trend.down{color:#ef4444}
.stat-card{cursor:default}
.stat-card .value{font-size:1.5rem}

/* Stat cards */
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:14px}
@media(max-width:768px){.stat-row{grid-template-columns:repeat(2,1fr)}}
.stat-card{background:rgba(255,255,255,0.04);border:1px solid rgba(124,58,237,0.12);border-radius:14px;padding:18px 16px;position:relative;overflow:hidden;backdrop-filter:blur(12px)}
.stat-card::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(124,58,237,0.04) 0%,transparent 70%);pointer-events:none}
.stat-card .label{font-size:0.68rem;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px}
.stat-card .value{font-size:1.6rem;font-weight:800;color:#ffffff;}
.stat-card .sub{font-size:0.65rem;color:rgba(255,255,255,0.25);margin-top:4px}

/* Charts */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
@media(max-width:768px){.charts-grid{grid-template-columns:1fr}}
.chart-card{background:rgba(255,255,255,0.04);border:1px solid rgba(124,58,237,0.12);border-radius:14px;padding:18px;backdrop-filter:blur(12px)}
.chart-card h3{font-size:0.82rem;color:#c084fc;margin-bottom:12px;font-weight:600}
.chart-card.wide{grid-column:1/-1}
.chart-wrap{position:relative;width:100%;max-height:260px}

/* Tables */
.tables-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:24px}
@media(max-width:768px){.tables-grid{grid-template-columns:1fr}}
.table-card{background:rgba(255,255,255,0.04);border:1px solid rgba(124,58,237,0.12);border-radius:14px;padding:18px;backdrop-filter:blur(12px)}
.table-card h3{font-size:0.82rem;color:#c084fc;margin-bottom:12px;font-weight:600}
table{width:100%;border-collapse:collapse}
th{text-align:left;font-size:0.65rem;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.5px;padding:6px 8px;border-bottom:1px solid rgba(124,58,237,0.1)}
td{font-size:0.78rem;padding:8px;border-bottom:1px solid rgba(255,255,255,0.03)}
td:last-child{text-align:right;font-weight:700;color:#c084fc}
tr:hover td{background:rgba(124,58,237,0.05)}
</style>
</head>
<body>

<!-- Login -->
<div id="login-screen">
  <div class="logo-wrap">
    <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" width="44" height="44">
      <defs><linearGradient id="lg1" x1="0" y1="0" x2="52" y2="52" gradientUnits="userSpaceOnUse"><stop offset="0%" stop-color="#A855F7"/><stop offset="100%" stop-color="#EC4899"/></linearGradient></defs>
      <rect x="19" y="4" width="14" height="22" rx="7" fill="url(#lg1)"/>
      <path d="M10 24 Q10 38 26 38 Q42 38 42 24" stroke="url(#lg1)" stroke-width="3" fill="none" stroke-linecap="round"/>
      <line x1="26" y1="38" x2="26" y2="47" stroke="url(#lg1)" stroke-width="3" stroke-linecap="round"/>
      <line x1="18" y1="47" x2="34" y2="47" stroke="url(#lg1)" stroke-width="3" stroke-linecap="round"/>
      <path d="M6 20 Q4 26 6 32" stroke="#A855F7" stroke-width="2.2" fill="none" stroke-linecap="round" opacity="0.7"/>
      <path d="M2 17 Q-1 26 2 35" stroke="#A855F7" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.35"/>
      <path d="M46 20 Q48 26 46 32" stroke="#EC4899" stroke-width="2.2" fill="none" stroke-linecap="round" opacity="0.7"/>
      <path d="M50 17 Q53 26 50 35" stroke="#EC4899" stroke-width="2" fill="none" stroke-linecap="round" opacity="0.35"/>
    </svg>
    <h1>HumMatch Analytics</h1>
  </div>
  <input type="password" class="login-input" id="api-key-input" placeholder="Password" autocomplete="off" onkeydown="if(event.key==='Enter')doLogin()"/>
  <button class="login-btn" onclick="doLogin()">Enter Dashboard</button>
</div>

<!-- Dashboard -->
<div id="dashboard">
  <div class="dash-header">
    <div class="logo-wrap" style="align-items:center;gap:12px;">
      <img src="/hummatch-icon-bug-2x.png" alt="HumMatch" style="height:40px;width:40px;border-radius:8px;"/>
      <h1>HumMatch Analytics Dashboard</h1>
    </div>
    <div class="right">
      <button class="time-btn" data-range="7" onclick="setRange(7)">7d</button>
      <button class="time-btn" data-range="30" onclick="setRange(30)">30d</button>
      <button class="time-btn active" data-range="0" onclick="setRange(0)">All Time</button>
      <span class="last-updated" id="last-updated"></span>
      <button class="logout-btn" onclick="doLogout()">Logout</button>
    </div>
  </div>

  <!-- Row 1: Core metrics -->
  <div class="stat-row">
    <div class="stat-card"><div class="label">Total Visits</div><div class="value" id="s-visits">-</div><div class="trend" id="t-visits"></div></div>
    <div class="stat-card"><div class="label">Hums Completed</div><div class="value" id="s-hums">-</div><div class="trend" id="t-hums"></div></div>
    <div class="stat-card"><div class="label">Conversion Rate</div><div class="value" id="s-conv">-</div><div class="trend" id="t-conv"></div></div>
    <div class="stat-card"><div class="label">List Exports</div><div class="value" id="s-sung">-</div><div class="trend" id="t-sung"></div></div>
  </div>

  <!-- Row 2: Language breakdown -->
  <div class="stat-row">
    <div class="stat-card"><div class="label">English Visits</div><div class="value" id="s-en-visits">-</div><div class="trend" id="t-en-visits"></div></div>
    <div class="stat-card"><div class="label">Spanish Visits</div><div class="value" id="s-es-visits">-</div><div class="trend" id="t-es-visits"></div></div>
    <div class="stat-card"><div class="label">English Hums</div><div class="value" id="s-en-hums">-</div></div>
    <div class="stat-card"><div class="label">Spanish Hums</div><div class="value" id="s-es-hums">-</div></div>
  </div>

  <!-- Row 3: Engagement -->
  <div class="stat-row">
    <div class="stat-card"><div class="label">Avg Time on Site</div><div class="value" id="s-duration">-</div><div class="sub">from session tracking</div></div>
    <div class="stat-card"><div class="label">Shares</div><div class="value" id="s-shares">-</div></div>
    <div class="stat-card"><div class="label">Home Screen Installs</div><div class="value" id="s-pwa">-</div></div>
    <div class="stat-card"><div class="label">Return Visitors</div><div class="value" id="s-return">-</div></div>
  </div>

  <!-- Row 4: Revenue & misc -->
  <div class="stat-row">
    <div class="stat-card"><div class="label">Purchases</div><div class="value" id="s-monthly">-</div></div>
    <div class="stat-card"><div class="label">Total Affiliates</div><div class="value" id="s-affiliates">-</div></div>
    <div class="stat-card"><div class="label">No-Match Rate</div><div class="value" id="s-nomatch">-</div></div>
  </div>

  <!-- Row 5: Hum → Signup Conversion -->
  <div class="stat-row" style="margin-bottom:14px;">
    <div class="stat-card" style="border-color:rgba(168,85,247,0.25);">
      <div class="label">Hum → Signup Conv.</div>
      <div class="value" id="s-hum-conv" style="font-size:2rem;background:linear-gradient(135deg,#A855F7,#EC4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">-</div>
      <div class="sub" id="sub-hum-conv"></div>
    </div>
    <div class="stat-card">
      <div class="label">Anonymous Hummers</div>
      <div class="value" id="s-anon-hums">-</div>
      <div class="sub">sessions without account</div>
    </div>
    <div class="stat-card">
      <div class="label">Registered Hummers</div>
      <div class="value" id="s-reg-hums">-</div>
      <div class="sub">unique users with hums</div>
    </div>
  </div>

  <!-- US Map -->
  <div class="chart-card wide" style="margin-bottom:14px;">
    <h3>🗺️ Hum Activity Map</h3>
    <div id="hum-map"></div>
    <div id="geo-note" style="color:rgba(255,255,255,0.3);font-size:0.72rem;padding:8px 0 0;text-align:center;">Each dot = a hum. Size = frequency from that location.</div>
  </div>


  <!-- Charts -->
  <div class="charts-grid">
    <div class="chart-card wide">
      <h3>Daily Trend (14 days)</h3>
      <div class="chart-wrap"><canvas id="chart-trend"></canvas></div>
    </div>
    <div class="chart-card wide">
      <h3>Hum → Signup: Anonymous vs Registered Hums</h3>
      <div class="chart-wrap"><canvas id="chart-hum-conv"></canvas></div>
    </div>
    <div class="chart-card">
      <h3>User Journey Funnel</h3>
      <div class="chart-wrap" style="max-height:280px;"><canvas id="chart-funnel"></canvas></div>
    </div>
    <div class="chart-card">
      <h3>Language Split</h3>
      <div class="chart-wrap" style="max-height:280px;"><canvas id="chart-lang"></canvas></div>
    </div>
    <div class="chart-card">
      <h3>Voice Type Distribution</h3>
      <div class="chart-wrap"><canvas id="chart-voice"></canvas></div>
    </div>
    <div class="chart-card">
      <h3>Device Breakdown</h3>
      <div class="chart-wrap"><canvas id="chart-device"></canvas></div>
    </div>
  </div>

    <!-- Age Estimation Note -->
  <div class="chart-card wide" style="margin-bottom:14px;background:rgba(245,158,11,0.04);border-color:rgba(245,158,11,0.2);">
    <h3 style="color:#F59E0B;">🧬 Vocal Age Estimation: Coming Soon</h3>
    <p style="font-size:0.8rem;color:rgba(255,255,255,0.45);line-height:1.6;margin-top:6px;">
      Research shows vocal characteristics do correlate with age ranges. Formant frequencies, pitch range, and brightness tend to shift with age.
      HumMatch already captures brightness (spectral centroid) and range data on every hum. 
      With enough training data, a rough age bracket (teen / 20s / 30s-40s / 50s+) could be estimated. 
      This will be added as a future analytics dimension once the dataset is large enough to validate accuracy.
    </p>
  </div>

  <!-- Tables -->
  <div class="tables-grid">
    <div class="table-card">
      <h3>Top 10 Songs Matched</h3>
      <table><thead><tr><th>#</th><th>Song</th><th>Artist</th><th>Count</th></tr></thead><tbody id="tbl-matched"></tbody></table>
    </div>
    <div class="table-card">
      <h3>Top 10 Songs Sung</h3>
      <table><thead><tr><th>#</th><th>Song</th><th>Artist</th><th>Count</th></tr></thead><tbody id="tbl-sung"></tbody></table>
    </div>
    <div class="table-card">
      <h3>Top 10 Dismissed Songs</h3>
      <table><thead><tr><th>#</th><th>Song</th><th>Artist</th><th>Count</th></tr></thead><tbody id="tbl-dismissed"></tbody></table>
    </div>
    <div class="table-card">
      <h3>Top Songs Exported</h3>
      <table><thead><tr><th>#</th><th>Song</th><th>Artist</th><th>Count</th></tr></thead><tbody id="tbl-sung"></tbody></table>
    </div>
  </div>
</div>

<script>
let apiKey = sessionStorage.getItem('hm_analytics_key');
let currentRange = 0;
let refreshTimer = null;
let charts = {};

function doLogin() {
  const key = document.getElementById('api-key-input').value.trim();
  if (!key) return;
  sessionStorage.setItem('hm_analytics_key', key);
  apiKey = key;
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('dashboard').classList.add('active');
  setTimeout(initMap, 100); // init map after DOM is visible
  loadStats();
  startAutoRefresh();
}

function doLogout() {
  sessionStorage.removeItem('hm_analytics_key');
  apiKey = null;
  if (refreshTimer) clearInterval(refreshTimer);
  document.getElementById('dashboard').classList.remove('active');
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('api-key-input').value = '';
}

// Auto-login if key stored
if (apiKey) {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('dashboard').classList.add('active');
  setTimeout(initMap, 100);
  loadStats();
  startAutoRefresh();
}

function setRange(days) {
  currentRange = days;
  document.querySelectorAll('.time-btn').forEach(b => b.classList.toggle('active', parseInt(b.dataset.range) === days));
  loadStats();
}

function startAutoRefresh() {
  if (refreshTimer) clearInterval(refreshTimer);
  refreshTimer = setInterval(loadStats, 60000);
}

let humMap = null;
let mapMarkers = [];

function initMap() {
  if (humMap) return;
  humMap = L.map('hum-map', { zoomControl: true, attributionControl: false }).setView([30, -10], 2);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    maxZoom: 10
  }).addTo(humMap);
}

async function loadGeoData() {
  try {
    const res = await fetch('/api/hummatch/geo', { headers: { 'X-Reactr-Api-Key': apiKey } });
    if (!res.ok) return;
    const { points } = await res.json();
    if (!humMap) initMap();
    // Clear old markers
    mapMarkers.forEach(m => humMap.removeLayer(m));
    mapMarkers = [];
    const maxCnt = Math.max(...points.map(p => p.cnt), 1);
    points.forEach(p => {
      const r = Math.max(6, Math.min(24, 6 + (p.cnt / maxCnt) * 18));
      const circle = L.circleMarker([p.lat, p.lng], {
        radius: r, fillColor: '#A855F7', fillOpacity: 0.75,
        color: '#EC4899', weight: 1.5, opacity: 0.9
      }).addTo(humMap);
      circle.bindTooltip(`${p.city ? p.city + ', ' : ''}${p.country} · ${p.cnt} hum${p.cnt > 1 ? 's' : ''}`, { className: 'hm-tooltip' });
      mapMarkers.push(circle);
    });
    if (points.length === 0) {
      document.getElementById('geo-note').textContent = 'No geo data yet. Hums will appear as dots once location data is captured.';
    } else {
      document.getElementById('geo-note').textContent = `${points.length} location${points.length > 1 ? 's' : ''} · Each dot = a hum source · Size = frequency`;
    }
  } catch(e) { console.error('Geo load failed', e); }
}

async function loadStats() {
  const since = currentRange > 0 ? Math.floor(Date.now() / 1000) - (currentRange * 86400) : 0;
  try {
    const res = await fetch('/api/hummatch/analytics?since=' + since, {
      headers: { 'X-Reactr-Api-Key': apiKey }
    });
    if (res.status === 401) { doLogout(); return; }
    if (!res.ok) return;
    const d = await res.json();
    render(d);
    document.getElementById('last-updated').textContent = 'Updated: ' + new Date().toLocaleTimeString();
    loadGeoData();
  } catch(e) { console.error('Analytics fetch failed', e); }
}

function fmt(n) {
  if (n === null || n === undefined) return '-';
  if (n >= 1000000) return (n / 1000000).toFixed(1) + 'M';
  if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
  return n.toLocaleString();
}

function render(d) {
  // Stat cards
  document.getElementById('s-visits').textContent = fmt(d.totalVisits);
  document.getElementById('s-hums').textContent = fmt(d.totalHums);
  document.getElementById('s-conv').textContent = d.convRate + '%';
  document.getElementById('s-sung').textContent = fmt(d.totalSung);
  // Trend arrows (placeholder, will show real data once prev period API is added)
  function setTrend(id, pct) {
    const el = document.getElementById(id);
    if (!el) return;
    if (pct === null) { el.textContent = ''; return; }
    el.className = 'trend' + (pct < 0 ? ' down' : '');
    el.textContent = (pct >= 0 ? '↑ ' : '↓ ') + Math.abs(pct) + '%';
  }
  // Simulated trends until prev-period endpoint is built
  setTrend('t-visits', null);
  setTrend('t-hums', null);
  setTrend('t-conv', null);
  setTrend('t-sung', null);
  setTrend('t-en-visits', null);
  setTrend('t-es-visits', null);
  document.getElementById('s-en-visits').textContent = fmt(d.enVisits);
  document.getElementById('s-es-visits').textContent = fmt(d.esVisits);
  document.getElementById('s-en-hums').textContent = fmt(d.enHums);
  document.getElementById('s-es-hums').textContent = fmt(d.esHums);
  document.getElementById('s-shares').textContent = fmt(d.totalShares);
  document.getElementById('s-pwa').textContent = fmt(d.pwaInstalls);
  document.getElementById('s-return').textContent = fmt(d.returnVisitors);
  if (d.avgSessionSec) {
    const mins = Math.floor(d.avgSessionSec / 60);
    const secs = d.avgSessionSec % 60;
    document.getElementById('s-duration').textContent = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;
  }
  document.getElementById('s-monthly').textContent = fmt(d.monthlyPurchases);
  // Avg time on site
  if (d.avgSessionSec && d.avgSessionSec > 0) {
    const m = Math.floor(d.avgSessionSec / 60);
    const s = d.avgSessionSec % 60;
    document.getElementById('s-duration').textContent = m > 0 ? `${m}m ${s}s` : `${s}s`;
  }
  document.getElementById('s-affiliates').textContent = fmt(d.affiliateCount);
  const noMatchRate = d.totalHums > 0 ? Math.round((d.noMatch / d.totalHums) * 100) : 0;
  document.getElementById('s-nomatch').textContent = noMatchRate + '%';

  // Hum → Signup conversion
  document.getElementById('s-hum-conv').textContent = (d.humSignupConvRate ?? 0) + '%';
  document.getElementById('sub-hum-conv').textContent = `${fmt(d.anonHumCount)} anon → ${fmt(d.registeredHummerCount)} signups`;
  document.getElementById('s-anon-hums').textContent = fmt(d.anonHumCount);
  document.getElementById('s-reg-hums').textContent = fmt(d.registeredHummerCount);
  renderHumConvChart(d.humConvTrend);

  // Tables
  renderTable('tbl-matched', d.topMatched, true);
  renderTable('tbl-sung', d.topSung, true);
  renderTable('tbl-dismissed', d.topDismissed, true);
  renderTable('tbl-sung', d.topSung, true);

  // Charts
  renderTrendChart(d.dailyTrend);
  renderVoiceChart(d.voiceTypes);
  renderDeviceChart(d.devices);
  renderFunnelChart(d);
  renderLangChart(d);
}

function renderTable(id, rows, numbered) {
  const el = document.getElementById(id);
  if (!rows || !rows.length) { el.innerHTML = '<tr><td colspan="4" style="color:rgba(255,255,255,0.2);text-align:center;padding:20px">No data yet</td></tr>'; return; }
  el.innerHTML = rows.map((r, i) =>
    `<tr><td>${numbered ? i + 1 : ''}</td><td>${r.title || '-'}</td><td>${r.artist || '-'}</td><td>${r.cnt}</td></tr>`
  ).join('');
}

function renderAffiliatesTable(rows) {
  const el = document.getElementById('tbl-affiliates');
  if (!rows || !rows.length) { el.innerHTML = '<tr><td colspan="2" style="color:rgba(255,255,255,0.2);text-align:center;padding:20px">No data yet</td></tr>'; return; }
  el.innerHTML = rows.map(r => `<tr><td>${r.type}</td><td>${r.cnt}</td></tr>`).join('');
}

const chartColors = ['#A855F7','#EC4899','#8B5CF6','#F472B6','#7C3AED','#DB2777','#6D28D9','#BE185D'];

function destroyChart(key) {
  if (charts[key]) { charts[key].destroy(); charts[key] = null; }
}

function renderTrendChart(data) {
  destroyChart('trend');
  const ctx = document.getElementById('chart-trend').getContext('2d');
  const labels = (data || []).map(d => d.day?.slice(5) || '');
  charts.trend = new Chart(ctx, {
    type: 'line',
    data: {
      labels,
      datasets: [
        { label: 'Visits', data: (data || []).map(d => d.visits), borderColor: '#A855F7', backgroundColor: 'rgba(168,85,247,0.12)', tension: 0.4, fill: true, borderWidth: 2.5 },
        { label: 'Hums', data: (data || []).map(d => d.hums), borderColor: '#F59E0B', backgroundColor: 'rgba(245,158,11,0.12)', tension: 0.4, fill: true, borderWidth: 2.5 },
        { label: 'Songs Sung', data: (data || []).map(d => d.sung), borderColor: '#10B981', backgroundColor: 'rgba(16,185,129,0.12)', tension: 0.4, fill: true, borderWidth: 2.5 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { labels: { color: 'rgba(255,255,255,0.5)', font: { size: 11 } } } },
      scales: {
        x: { ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
        y: { ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
      }
    }
  });
}

function renderVoiceChart(data) {
  destroyChart('voice');
  const ctx = document.getElementById('chart-voice').getContext('2d');
  charts.voice = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: (data || []).map(d => d.voice_type || 'Unknown'),
      datasets: [{ data: (data || []).map(d => d.cnt), backgroundColor: ['#A855F7','#F59E0B','#10B981','#3B82F6','#EC4899','#F97316','#06B6D4','#8B5CF6'].slice(0,(data||[]).length), borderRadius: 6 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { ticks: { color: 'rgba(255,255,255,0.4)', font: { size: 10 } }, grid: { display: false } },
        y: { ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
      }
    }
  });
}

function renderDeviceChart(data) {
  destroyChart('device');
  const ctx = document.getElementById('chart-device').getContext('2d');
  charts.device = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: (data || []).map(d => d.device),
      datasets: [{ data: (data || []).map(d => d.cnt), backgroundColor: ['#A855F7','#F59E0B','#10B981','#3B82F6'], borderWidth: 0 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'bottom', labels: { color: 'rgba(255,255,255,0.5)', font: { size: 11 }, padding: 12 } } },
      cutout: '60%'
    }
  });
}

function renderFunnelChart(d) {
  destroyChart('funnel');
  const ctx = document.getElementById('chart-funnel').getContext('2d');
  const visits = d.totalVisits || 0;
  const hums = d.totalHums || 0;
  const matched = d.topMatched ? d.topMatched.reduce((s,r) => s + r.cnt, 0) : 0;
  const exported = d.totalSung || 0;
  charts.funnel = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['Visits', 'Hums', 'Songs Matched', 'List Exports'],
      datasets: [{
        data: [visits, hums, matched, exported],
        backgroundColor: ['#A855F7','#C44FBF','#DB2777','#F472B6'],
        borderRadius: 6
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: ctx => {
              const pct = visits > 0 ? ((ctx.raw / visits)*100).toFixed(1) : 0;
              return ` ${ctx.raw.toLocaleString()} (${pct}% of visits)`;
            }
          }
        }
      },
      scales: {
        x: { ticks: { color: 'rgba(255,255,255,0.3)', font:{size:10} }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true },
        y: { ticks: { color: '#fff', font:{size:12,weight:'600'} }, grid: { display: false } }
      }
    }
  });
}

function renderLangChart(d) {
  destroyChart('lang');
  const ctx = document.getElementById('chart-lang').getContext('2d');
  charts.lang = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['English', 'Spanish'],
      datasets: [{ data: [d.enVisits || 0, d.esVisits || 0], backgroundColor: ['#A855F7','#EC4899'], borderWidth: 0 }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { color: '#fff', font: { size: 12, weight: '600' }, padding: 16 } },
        tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.raw.toLocaleString()} visits` } }
      },
      cutout: '55%'
    }
  });
}

function renderHumConvChart(data) {
  destroyChart('humconv');
  const ctx = document.getElementById('chart-hum-conv').getContext('2d');
  charts.humconv = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: (data || []).map(d => d.day?.slice(5) || ''),
      datasets: [
        { label: 'Anonymous Hums', data: (data || []).map(d => d.anon_hums || 0), backgroundColor: 'rgba(168,85,247,0.75)', borderRadius: 4 },
        { label: 'Registered Hums', data: (data || []).map(d => d.registered_hums || 0), backgroundColor: 'rgba(236,72,153,0.75)', borderRadius: 4 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: 'rgba(255,255,255,0.5)', font: { size: 11 } } },
        tooltip: {
          callbacks: {
            afterBody: items => {
              const total = items.reduce((s, i) => s + i.raw, 0);
              if (total === 0) return '';
              const reg = items.find(i => i.dataset.label === 'Registered Hums')?.raw || 0;
              return `Conv: ${total > 0 ? ((reg / total) * 100).toFixed(1) : 0}%`;
            }
          }
        }
      },
      scales: {
        x: { stacked: true, ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
        y: { stacked: true, ticks: { color: 'rgba(255,255,255,0.3)', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' }, beginAtZero: true }
      }
    }
  });
}
</script>
</body>
</html>
