ug":"shoop-salt-n-pepa","title":"Shoop","artist":"Salt-N-Pepa","artistSlug":"salt-n-pepa","loNote":"D♯3","hiNote":"A♯4","semitones":19,"diffCat":"easy"},{"slug":"chica-ideal-sebasti-n-yatra","title":"Chica Ideal","artist":"Sebastián Yatra","artistSlug":"sebasti-n-yatra","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"falta-de-amor-sebasti-n-yatra","title":"Falta de Amor","artist":"Sebastián Yatra","artistSlug":"sebasti-n-yatra","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"la-botica-del-amor-sebasti-n-yatra","title":"La Botica del Amor","artist":"Sebastián Yatra","artistSlug":"sebasti-n-yatra","loNote":"D3","hiNote":"G4","semitones":17,"diffCat":"easy"},{"slug":"no-hay-nadie-m-s-sebasti-n-yatra","title":"No Hay Nadie Más","artist":"Sebastián Yatra","artistSlug":"sebasti-n-yatra","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"robarte-un-beso-sebasti-n-yatra","title":"Robarte un Beso","artist":"Sebastián Yatra","artistSlug":"sebasti-n-yatra","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"sutra-sebasti-n-yatra","title":"Sutra","artist":"Sebastián Yatra","artistSlug":"sebasti-n-yatra","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"traicionera-sebasti-n-yatra","title":"Traicionera","artist":"Sebastián Yatra","artistSlug":"sebasti-n-yatra","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"un-a-o-sebasti-n-yatra","title":"Un Año","artist":"Sebastián Yatra","artistSlug":"sebasti-n-yatra","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"a-pedir-tu-mano-sin-bandera","title":"A Pedir tu Mano","artist":"Sin Bandera","artistSlug":"sin-bandera","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"entra-en-mi-vida-sin-bandera","title":"Entra en Mi Vida","artist":"Sin Bandera","artistSlug":"sin-bandera","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"kil-metros-sin-bandera","title":"Kilómetros","artist":"Sin Bandera","artistSlug":"sin-bandera","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"que-me-alcance-la-vida-sin-bandera","title":"Que Me Alcance la Vida","artist":"Sin Bandera","artistSlug":"sin-bandera","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"te-vi-venir-sin-bandera","title":"Te Vi Venir","artist":"Sin Bandera","artistSlug":"sin-bandera","loNote":"D3","hiNote":"A4","semitones":19,"diffCat":"easy"},{"slug":"cuando-pase-el-temblor-soda-stereo","title":"Cuando Pase el Temblor","artist":"Soda Stereo","artistSlug":"soda-stereo","loNote":"D3","hiNote":"G4","semitones":17,"diffCat":"easy"},{"slug":"de-m-sica-ligera-soda-stereo","title":"De Música Ligera","artist":"Soda Stereo","artistSlug":"soda-stereo","loNote":"D3","hiNote":"G4","semitones":17,"diffCat":"easy"},{"slug":"en-la-ciudad-de-la-furia-soda-stereo","title":"En la Ciudad de la Furia","artist":"Soda Stereo","artistSlug":"soda-stereo","loNote":"D3","hiNote":"G4","semitones":17,"diffCat":"easy"},{"slug":"nada-personal-soda-stereo","title":"Nada Personal","artist":"Soda Stereo","artistSlug":"soda-stereo","loNote":"D3","hiNote":"F4","semitones":15,"diffCat":"easy"},{"slug":"persiana-americana-soda-stereo","title":"Persiana Americana","artist":"Soda Stereo","artistSlug":"soda-stereo","loNote":"D3","hiNote":"G4","semitones":17,"diffCat":"easy"},{"slug":"primavera-cero-soda-stereo","title":"Primavera Cero","artist":"Soda Stereo","artistSlug":"soda-stereo","loNote":"D3","hiNote":"G4","semitones":17,"diffCat":"easy"},{"slug":"tr-tame-suavemente-soda-stereo","title":"Trátame Suavemente","artist":"Soda Stereo","artistSlug":"soda-stereo","loNote":"D3","hiNote":"F4","semitones":15,"diffCat":"easy"},{"slug":"zoom-soda-stereo","title":"Zoom","artist":"Soda Stereo","artistSlug":"soda-stereo","loNote":"D3","hiNote":"G4","semitones":17,"diffCat":"easy"},{"slug":"walk-like-an-egyptian-the-bangles","title":"Walk Like an Egyptian","artist":"The Bangles","artistSlug":"the-bangles","loNote":"E3","hiNote":"A♯4","semitones":18,"diffCat":"easy"},{"slug":"california-dreamin-the-mamas-the-papas","title":"California Dreamin'","artist":"The Mamas & The Papas","artistSlug":"the-mamas-the-papas","loNote":"C3","hiNote":"G♯4","semitones":20,"diffCat":"easy"},{"slug":"ill-take-you-there-the-staple-singers","title":"I'll Take You There","artist":"The Staple Singers","artistSlug":"the-staple-singers","loNote":"C3","hiNote":"G♯4","semitones":20,"diffCat":"easy"},{"slug":"baby-love-the-supremes","title":"Baby Love","artist":"The Supremes","artistSlug":"the-supremes","loNote":"E3","hiNote":"C5","semitones":20,"diffCat":"easy"},{"slug":"fast-car-tracy-chapman","title":"Fast Car","artist":"Tracy Chapman","artistSlug":"tracy-chapman","loNote":"B2","hiNote":"G4","semitones":20,"diffCat":"easy"},{"slug":"low-rider-war","title":"Low Rider","artist":"War","artistSlug":"war","loNote":"D♯2","hiNote":"A♯3","semitones":19,"diffCat":"easy"}];
const DIFF_COLORS = {easy:'#22c55e',medium:'#f59e0b',hard:'#ef4444'};
let filtered = [...SONGS];

function escHtml(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

function renderGrid() {
  const g = document.getElementById('songGrid');
  if (!filtered.length) { g.innerHTML = '<p style="color:rgba(255,255,255,0.4);grid-column:1/-1;padding:20px 0">No songs found.</p>'; return; }
  g.innerHTML = filtered.map(s => `<a href="/song/${s.slug}" class="song-card">
    <div class="sc-title">${escHtml(s.title)}</div>
    <div class="sc-artist"><a href="/artist/${s.artistSlug}" style="color:var(--muted);text-decoration:none" onclick="event.stopPropagation()">${escHtml(s.artist)}</a></div>
    <div class="sc-meta">
      <span class="sc-tag">${s.loNote}–${s.hiNote}</span>
      <span class="sc-tag">${s.semitones} semi.</span>
      <span class="sc-tag diff-tag" style="color:${DIFF_COLORS[s.diffCat]}">${s.diffCat.charAt(0).toUpperCase()+s.diffCat.slice(1)}</span>
    </div>
  </a>`).join('');
  document.getElementById('countBadge').textContent = filtered.length + ' songs';
}

function filterSongs() {
  const q = document.getElementById('searchInput').value.toLowerCase().trim();
  filtered = q ? SONGS.filter(s => s.title.toLowerCase().includes(q) || s.artist.toLowerCase().includes(q)) : [...SONGS];
  sortAndRender();
}

function sortAndRender() {
  const v = document.getElementById('sortSelect').value;
  if (v === 'title')         filtered.sort((a,b) => a.title.localeCompare(b.title));
  else if (v === 'semitones') filtered.sort((a,b) => a.semitones - b.semitones);
  else if (v === 'semitones-desc') filtered.sort((a,b) => b.semitones - a.semitones);
  else if (v === 'artist')   filtered.sort((a,b) => a.artist.localeCompare(b.artist));
  renderGrid();
}

renderGrid();
</script>
</body>
</html>